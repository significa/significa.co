---
import BaseLayout from "@/layouts/base.astro";
import { getClients, getProjects } from "@/lib/collections";

const featuredProjects = (await getProjects()).slice(0, 3);
const clients = await getClients();
---

<BaseLayout
  title="What we do"
  description="Product design, development, and strategy. We help companies build digital products people love."
>
  <!-- Intro -->
  <section class="intro">
    <div class="intro-inner">
      <h1>
        <span class="intro-muted">We don't do everything. We do a few things very well.</span>{" "}
        Strategy, design, and engineering for digital products.
      </h1>
    </div>
  </section>

  <!-- Services -->
  <section class="services">
    <div class="services-inner">
      <div class="services-grid">
        <article class="service-card">
          <span class="service-number" aria-hidden="true">01</span>
          <h2 class="service-title">Strategy</h2>
          <p class="service-description">
            Research, workshops, and roadmaps. Sometimes you need to step back before you build forward. We help you figure out
            what to build and why — before a single pixel is pushed.
          </p>
          <ul class="service-details">
            <li>User research</li>
            <li>Product discovery</li>
            <li>Technical audits</li>
            <li>Roadmap planning</li>
          </ul>
        </article>

        <article class="service-card">
          <span class="service-number" aria-hidden="true">02</span>
          <h2 class="service-title">Design</h2>
          <p class="service-description">
            UI, UX, branding, and prototyping. From first sketch to production-ready screens. Interfaces that are clear,
            accessible, and built around real user needs — not assumptions.
          </p>
          <ul class="service-details">
            <li>Product design</li>
            <li>Interface design</li>
            <li>Design systems</li>
            <li>Prototyping</li>
          </ul>
        </article>

        <article class="service-card">
          <span class="service-number" aria-hidden="true">03</span>
          <h2 class="service-title">Engineering</h2>
          <p class="service-description">
            Web, mobile, and infrastructure. We build what we design. Our stack choices serve the product, not the other way
            around. Clean code, tested, ready for the real world.
          </p>
          <ul class="service-details">
            <li>Web applications</li>
            <li>Mobile apps</li>
            <li>E-commerce</li>
            <li>APIs & infrastructure</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="process">
    <div class="process-inner">
      <h2 class="section-heading">How we work</h2>
      <div class="process-grid">
        <div class="process-step">
          <h3 class="process-step-title">Discover</h3>
          <p class="process-step-description">
            Understand the problem, the users, and the business context. We challenge assumptions and align on what success
            looks like before we start building.
          </p>
        </div>
        <div class="process-step">
          <h3 class="process-step-title">Define</h3>
          <p class="process-step-description">
            Turn insights into a clear plan. Information architecture, user flows, and a design direction that everyone believes
            in.
          </p>
        </div>
        <div class="process-step">
          <h3 class="process-step-title">Build</h3>
          <p class="process-step-description">
            Design and engineering work in parallel, not in sequence. Short cycles, constant feedback, working software every
            week.
          </p>
        </div>
        <div class="process-step">
          <h3 class="process-step-title">Launch</h3>
          <p class="process-step-description">
            Ship it. We handle the details — performance, SEO, analytics, accessibility — so you launch with confidence, not
            anxiety.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats">
    <div class="stats-inner">
      <dl class="stats-grid">
        <div class="stat-item">
          <dd class="stat-value">80+</dd>
          <dt class="stat-label">Projects delivered</dt>
        </div>
        <div class="stat-item">
          <dd class="stat-value">3.2x</dd>
          <dt class="stat-label">Avg. conversion uplift</dt>
        </div>
        <div class="stat-item">
          <dd class="stat-value">84.7%</dd>
          <dt class="stat-label">Customer satisfaction</dt>
        </div>
      </dl>
    </div>
  </section>

  <!-- Featured work -->
  {
    featuredProjects.length > 0 && (
      <section class="featured-work">
        <div class="featured-work-inner">
          <div class="featured-work-header">
            <h2 class="section-heading">Selected work</h2>
            <a href="/projects" class="see-all-link">
              All projects →
            </a>
          </div>
          <ul class="work-list">
            {featuredProjects.map((project) => (
              <li class="work-item">
                <a href={`/projects/${project.id}`}>
                  <div class="work-item-content">
                    <h3 class="work-item-title">{project.data.title}</h3>
                    {project.data.tagline && <p class="work-item-tagline">{project.data.tagline}</p>}
                  </div>
                  <div class="work-item-tags">
                    {project.data.tags.slice(0, 3).map((tag) => (
                      <span class="work-tag">{tag}</span>
                    ))}
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <!-- Client logos -->
  {
    clients.length > 0 && (
      <section class="clients">
        <div class="clients-inner">
          <h2 class="section-heading">Companies we've worked with</h2>
          <ul>
            {clients.map((client) => (
              <li>
                {client.data.url ? (
                  <a href={client.data.url} target="_blank" rel="noopener noreferrer" title={client.data.name}>
                    <span class="client-name">{client.data.name}</span>
                  </a>
                ) : (
                  <span class="client-name">{client.data.name}</span>
                )}
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <!-- CTA -->
  <section class="cta">
    <div class="cta-inner">
      <h2>Have a project in mind?</h2>
      <p>Tell us about it. We'll figure out together whether we're the right fit.</p>
      <a href="/work-with-us" class="cta-link">Work with us →</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* --------------------------------------------------------
       Intro
       -------------------------------------------------------- */
  .intro {
    padding: 8rem var(--gutter) 4rem;
  }

  .intro-inner {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
  }

  .intro h1 {
    font-size: var(--text-3xl);
    font-weight: var(--weight-normal);
    line-height: var(--leading-tight);
  }

  .intro-muted {
    color: var(--color-text-muted);
  }

  /* --------------------------------------------------------
       Section heading (reused)
       -------------------------------------------------------- */
  .section-heading {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 2rem;
  }

  /* --------------------------------------------------------
       Services
       -------------------------------------------------------- */
  .services {
    padding: 0 var(--gutter) 4rem;
  }

  .services-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .service-card {
    background: var(--color-surface-alt);
    padding: 2rem;
    border-radius: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .service-number {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-weight: var(--weight-medium);
  }

  .service-title {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
  }

  .service-description {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  .service-details {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .service-details li {
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  @media (max-width: 1024px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }

  /* --------------------------------------------------------
       Process
       -------------------------------------------------------- */
  .process {
    padding: 0 var(--gutter) 4rem;
  }

  .process-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .process-step {
    padding: 1.5rem 0;
    border-top: 2px solid var(--color-text);
  }

  .process-step-title {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    margin-bottom: 0.75rem;
  }

  .process-step-description {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  @media (max-width: 768px) {
    .process-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .process-grid {
      grid-template-columns: 1fr;
    }
  }

  /* --------------------------------------------------------
       Stats
       -------------------------------------------------------- */
  .stats {
    padding: 4rem var(--gutter);
  }

  .stats-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    text-align: center;
  }

  .stat-item {
    padding: 3rem 1rem;
    background: var(--color-surface-alt);
    border-radius: 0.5rem;
  }

  .stat-value {
    font-size: clamp(2.5rem, 2rem + 3vw, 4rem);
    font-weight: var(--weight-bold);
    line-height: 1;
    margin-bottom: 0.75rem;
  }

  .stat-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }

  /* --------------------------------------------------------
       Featured work
       -------------------------------------------------------- */
  .featured-work {
    padding: 0 var(--gutter) 4rem;
  }

  .featured-work-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .featured-work-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }

  .see-all-link {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .see-all-link:hover {
    color: var(--color-text);
  }

  .work-list {
    list-style: none;
    border-top: 1px solid var(--color-border);
  }

  .work-item a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    color: var(--color-text);
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .work-item a:hover {
    opacity: 0.7;
    color: var(--color-text);
  }

  .work-item-title {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
  }

  .work-item-tagline {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }

  .work-item-tags {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .work-tag {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    padding: 0.25rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 2rem;
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .work-item a {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
  }

  /* --------------------------------------------------------
       Clients
       -------------------------------------------------------- */
  .clients {
    padding: 0 var(--gutter) 4rem;
  }

  .clients-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .clients ul {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    list-style: none;
  }

  .clients li a {
    color: var(--color-text);
    text-decoration: none;
    opacity: 0.7;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .clients li a:hover {
    opacity: 1;
    color: var(--color-text);
  }

  .client-name {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    white-space: nowrap;
  }

  /* --------------------------------------------------------
       CTA
       -------------------------------------------------------- */
  .cta {
    padding: 4rem var(--gutter) 8rem;
  }

  .cta-inner {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
    text-align: center;
  }

  .cta h2 {
    font-size: var(--text-2xl);
    margin-bottom: 1rem;
  }

  .cta p {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    line-height: var(--leading-normal);
  }

  .cta-link {
    display: inline-block;
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 0.15em;
    text-decoration-thickness: 1px;
    transition: text-decoration-thickness var(--duration-fast) var(--ease-out);
  }

  .cta-link:hover {
    color: var(--color-text);
    text-decoration-thickness: 2px;
  }
</style>
