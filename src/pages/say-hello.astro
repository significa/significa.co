---
/**
 * /say-hello — Contact
 *
 * Functional, direct. No manifesto moment. The page exists to
 * convert a considering visitor into a conversation.
 *
 *   1. Direct statement — start with an email.
 *   2. Contact strip — proof-strip pattern for details.
 *   3. What happens next — 3 steps, not 5.
 *   4. Client voice + proof strip.
 */

import BaseLayout from "@/layouts/base.astro";
import Eyebrow from "@/components/ui/eyebrow.astro";
import SectionHeader from "@/components/ui/section-header.astro";
import ProofList from "@/components/ui/proof-list.astro";
import QaList from "@/components/ui/qa-list.astro";

const steps = [
  {
    n: "01",
    q: "Conversation",
    a: "No pitch deck. No sales call. A conversation about the problem, the timeline, and whether we're the right fit. If we're not, we'll say so.",
  },
  {
    n: "02",
    q: "Proposal",
    a: "A clear scope with a price and a timeline. No hidden phases. No 'discovery as a prerequisite'. If we need discovery, the proposal says why.",
  },
  {
    n: "03",
    q: "One team",
    a: "A small, dedicated team: designers and engineers working together from day one. Weekly check-ins. Direct access to the people making the decisions.",
  },
];
---

<BaseLayout
  title="Hello — Significa"
  description="Tell us what you're building and why it matters. We'll reply within two working days with an honest answer about whether we're the right team."
>
  <!-- ============================================================
       1. Direct statement
       ============================================================ -->
  <section class="hero" aria-labelledby="hero-h">
    <Eyebrow>Hello</Eyebrow>
    <h1 id="hero-h" class="hero-statement">Start with an email.</h1>
    <p class="hero-deck">
      Tell us what you're building and why it matters. We'll read it, think about it, and reply within two working days with an
      honest answer about whether we're the right team.
    </p>
  </section>

  <!-- ============================================================
       2. Contact strip
       ============================================================ -->
  <section class="contact" aria-label="Contact details">
    <ProofList>
      <div class="proof-row">
        <dt class="proof-label">Email</dt>
        <dd class="proof-values">
          <a href="mailto:hello@significa.co" class="contact-link">hello@significa.co</a>
        </dd>
      </div>
      <div class="proof-row">
        <dt class="proof-label">Studio</dt>
        <dd class="proof-values">
          <span class="proof-item">Rua Morgado Mateus 45, Porto</span>
        </dd>
      </div>
      <div class="proof-row">
        <dt class="proof-label">Hours</dt>
        <dd class="proof-values">
          <span class="proof-item">Mon-Fri, 9am-6pm WET</span>
        </dd>
      </div>
    </ProofList>
  </section>

  <!-- ============================================================
       3. What happens next
       ============================================================ -->
  <section class="next" aria-labelledby="next-h">
    <header class="next-header">
      <Eyebrow>What happens next</Eyebrow>
      <SectionHeader id="next-h">From email to one team.</SectionHeader>
    </header>

    <QaList items={steps} />
  </section>
</BaseLayout>

<style>
  /* ============================================================
     Page rhythm
     ============================================================ */

  section {
    padding-inline: var(--gutter);
    padding-block: clamp(5rem, 10vw, 10rem);
  }

  /* ============================================================
     1. Hero
     ============================================================ */

  .hero {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-block: clamp(4rem, 8vw, 7rem);
  }

  .hero-statement {
    font-family: var(--font-display);
    font-weight: 200;
    font-size: var(--text-4xl);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tighter);
    margin: 0;
    max-width: 22ch;
    color: var(--color-ink);
  }

  .hero-deck {
    margin-top: 2.5rem;
    font-size: var(--text-xl);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
    max-width: var(--max-width-prose);
  }

  /* ============================================================
     2. Contact strip
     ============================================================ */

  .contact {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .contact-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink);
    line-height: var(--leading-relaxed);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .contact-link:hover {
    color: var(--color-accent);
  }

  /* ============================================================
     3. What happens next
     ============================================================ */

  .next {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .next-header {
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }
</style>
