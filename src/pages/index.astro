---
/**
 * Homepage
 *
 * Per the brand docs. Order optimised for narrative flow:
 *
 *   1. Hero — position statement + capability breadth in the deck.
 *   2. Proof — recognition + clients, thin mono strips.
 *   3. Featured — DIA, told richly: story prose + structured metadata
 *      + integrated client voice, ending with a case-study link.
 *   4. Manifesto moment — "Judgement is the work." One line, standalone.
 *   5. Recent work — compact editorial index.
 *   6. Numbers — since / team / projects / recognitions.
 *   7. Three questions — the judgment layer, placed at the close where
 *      a considering visitor is ready to read them.
 *
 * Italics are reserved for the manifesto moment only. Links use the
 * .link-call pattern (no underline, animated arrow on hover).
 */

import BaseLayout from "@/layouts/base.astro";
import Egg from "@/components/ui/egg.astro";
import { getEntry } from "astro:content";
import { getProjects, getClients } from "@/lib/collections";
import { cdnUrl } from "@/lib/cdn";
import { webSiteJsonLd } from "@/lib/seo";

const featured = await getEntry("projects", "dia");
const allProjects = (await getProjects()).filter((p) => p.id !== "dia").slice(0, 8);
const clients = await getClients();

const recognitions = [
  "Red Dot",
  "iF Design",
  "German Design Council",
  "European Design",
  "Good Design",
  "Awwwards",
];

// Metadata for the DIA feature. Kept here inline because it's curated copy,
// not a straight dump of the project frontmatter (e.g. "Role" is a homepage
// framing, not a field on the content entry).
const featuredMeta = [
  { label: "Client", value: "The Fertility Partnership" },
  { label: "Role", value: "Strategy, Design, Engineering" },
  { label: "Deliverables", value: "iOS + Android apps, CMS, Brand identity" },
  { label: "Industry", value: "Healthcare, Femtech" },
  { label: "Recognition", value: "Red Dot · iF · German Gold · Good Design · European Gold" },
];

const services = [
  {
    n: "01",
    q: "How do you know when the work is done?",
    a: "When the thing does what it's meant to without extra — no leftover complexity, no speculative features, no visible seams. That takes more rounds than shipping the spec, but the result is work that ages better, breaks less, and doesn't need a rewrite in eighteen months. The test is whether we'd be happy to maintain this in year three.",
  },
  {
    n: "02",
    q: "How do you decide what not to build?",
    a: "Every brief contains features that won't earn their place in the final product. Cutting them isn't about shipping less — it's about making what remains feel more considered. We identify what to trim early, say so out loud, and have the honest conversation. Saying no to a feature is how you get to say yes to craft.",
  },
  {
    n: "03",
    q: "What does it cost when we're wrong?",
    a: "We're wrong sometimes. The cost shows up in extra rounds, missed assumptions, or features that didn't earn their place. We absorb that cost when it's ours and we say so. We don't externalise it as scope creep or invoice it as additional discovery.",
  },
];

const numbers = [
  { label: "Founded", value: "2015" },
  { label: "Designers & engineers", value: "35+" },
  { label: "Projects shipped", value: "80+" },
  { label: "International recognitions", value: "20+" },
];

const structuredData = [webSiteJsonLd()];
---

<BaseLayout
  title="Significa — A design & engineering studio in Porto"
  description="Significa is a design and engineering studio in Porto. We make digital products — platforms, e-commerce, apps, design systems — for businesses that want complexity met with care."
  structuredData={structuredData}
>
  <!-- ============================================================
       1. Hero — position + capability breadth
       ============================================================ -->
  <section class="hero" aria-labelledby="hero-h">
    <p class="eyebrow">A design &amp; engineering studio <span class="eyebrow-sep">/</span> Porto</p>
    <h1 id="hero-h" class="hero-statement">
      We exist to prove that <em>rigour</em> and <em>beauty</em> are not opposites.
    </h1>
    <p class="hero-deck">
      Designers and engineers working as one team. We make digital products — platforms,
      e-commerce, apps, design systems — for businesses that want complexity met with care, not
      avoided.
    </p>
  </section>

  <!-- ============================================================
       2. Proof — two compact mono strips
       ============================================================ -->
  <section class="proof" aria-label="Credibility">
    <dl class="proof-list">
      <div class="proof-row">
        <dt class="proof-label">Recognised by</dt>
        <dd class="proof-values">
          {recognitions.map((r) => <span class="proof-item">{r}</span>)}
        </dd>
      </div>
      <div class="proof-row">
        <dt class="proof-label">Trusted by</dt>
        <dd class="proof-values">
          {clients.map((c) => <span class="proof-item">{c.data.name}</span>)}
        </dd>
      </div>
    </dl>
  </section>

  <!-- ============================================================
       3. Featured project — rich. Eyebrow + statement + image,
       then a two-column grid (prose + structured metadata), then
       an integrated voice block from the client, then the link.
       All one section so the rhythm reads as a single case.
       ============================================================ -->
  {
    featured && (
      <section class="featured" aria-labelledby="featured-h">
        <div class="featured-inner">
          <p class="eyebrow">
            Recent work <span class="eyebrow-sep">/</span> {featured.data.client}{" "}
            <span class="eyebrow-sep">/</span> 2022
          </p>

          <h2 id="featured-h" class="featured-statement">
            A period tracker brief that grew into a fertility companion.
          </h2>

          <figure class="featured-figure">
            <div class="featured-image">
              <img
                src={cdnUrl(featured.data.thumbnail, { width: 1800, quality: 88 })}
                alt={featured.data.altText ?? `${featured.data.title} — ${featured.data.tagline}`}
                width="1800"
                height="1200"
                loading="lazy"
                decoding="async"
              />
            </div>
          </figure>

          <div class="featured-grid">
            <div class="featured-prose">
              <p>
                TFP came to us looking for a competitor in a market full of period trackers. Six
                weeks of discovery reframed what the project was. The final product logs cycles,
                forecasts fertility, teaches, and builds a relationship rather than a dataset —
                a companion, not a tracker.
              </p>
              <p>
                Five international design awards later, including a <em>Red Dot</em>, Dia stood
                alone in its category. Not because it shouted louder, but because it understood
                better.
              </p>
            </div>

            <dl class="featured-meta">
              {featuredMeta.map((m) => (
                <div class="featured-meta-row">
                  <dt class="featured-meta-label">{m.label}</dt>
                  <dd class="featured-meta-value">{m.value}</dd>
                </div>
              ))}
            </dl>
          </div>

          <!-- Integrated client voice. Sits below the 2-col grid,
               aligned with the prose column width to read as an
               attached coda, not a separate section. -->
          <aside class="featured-voice" aria-label="Client voice">
            <p class="featured-voice-label">A voice from this project</p>
            <blockquote class="featured-voice-quote">
              <p>
                Dia started as a simple tracker brief. Six weeks of discovery with Significa
                reframed what we were building. We ended up with a product we&rsquo;re proud of
                — bigger than we&rsquo;d scoped, and better for it.
              </p>
              <footer>
                <cite>
                  <strong>Chakameh Shafii</strong>
                  <span>Former Director at TFP, Head of Dia</span>
                </cite>
              </footer>
            </blockquote>
          </aside>

          <p class="featured-link-row">
            <a href={`/projects/${featured.id}`} class="link-call">
              <span class="link-label">Read the case study</span>
              <span class="link-arrow" aria-hidden="true">&rarr;</span>
            </a>
          </p>
        </div>
      </section>
    )
  }

  <!-- ============================================================
       4. Manifesto moment — the one earned italic. Stands alone.
       ============================================================ -->
  <section class="moment" aria-labelledby="moment-h">
    <h2 id="moment-h" class="moment-line">
      <em>Judgement<br />is the work.</em>
    </h2>
    <p class="moment-attr">
      <Egg variant="fill" class="moment-egg" />
      &nbsp; From the North Star <span class="eyebrow-sep">/</span>
      <a href="/about" class="moment-link">read what we believe</a>
    </p>
  </section>

  <!-- ============================================================
       5. Recent work — compact editorial index
       ============================================================ -->
  {
    allProjects.length > 0 && (
      <section class="index" aria-labelledby="index-h">
        <header class="index-header">
          <p class="eyebrow">More work</p>
          <h2 id="index-h" class="section-statement">Recent projects.</h2>
        </header>

        <ol class="index-list" role="list">
          {allProjects.map((p, i) => (
            <li class="index-row">
              <a href={`/projects/${p.id}`} class="index-link">
                <span class="index-num">{String(i + 2).padStart(2, "0")}</span>
                <span class="index-title">{p.data.title}</span>
                <span class="index-tagline">{p.data.tagline}</span>
                <span class="index-year">{new Date(p.data.date).getFullYear()}</span>
                <span class="index-mark" aria-hidden="true">&rarr;</span>
              </a>
            </li>
          ))}
        </ol>

        <p class="index-link-row">
          <a href="/projects" class="link-call">
            <span class="link-label">All work</span>
            <span class="link-arrow" aria-hidden="true">&rarr;</span>
          </a>
        </p>
      </section>
    )
  }

  <!-- ============================================================
       6. Three questions — what working with us means. Judgment
       layer, depth after the index so a considering visitor finds
       it with enough attention to read.
       ============================================================ -->
  <section class="questions" aria-labelledby="questions-h">
    <header class="questions-header">
      <p class="eyebrow">What working with us means</p>
      <h2 id="questions-h" class="section-statement">Three questions we answer on every project.</h2>
      <p class="section-deck">
        We don&rsquo;t sell a process. We sell the judgment that goes into the work — the
        decisions that determine whether a product ages well or needs a rewrite in eighteen
        months. Below, the three we come back to.
      </p>
    </header>

    <ol class="qa-list" role="list">
      {
        services.map((s) => (
          <li class="qa">
            <p class="qa-num">{s.n}</p>
            <h3 class="qa-q">{s.q}</h3>
            <p class="qa-a">{s.a}</p>
          </li>
        ))
      }
    </ol>

    <p class="questions-link-row">
      <a href="/services" class="link-call">
        <span class="link-label">How we actually deliver</span>
        <span class="link-arrow" aria-hidden="true">&rarr;</span>
      </a>
    </p>
  </section>

  <!-- ============================================================
       7. Numbers — single compact row. Quiet close before footer.
       ============================================================ -->
  <section class="numbers" aria-label="Studio in numbers">
    <dl class="numbers-row">
      {
        numbers.map((n) => (
          <div class="numbers-item">
            <dt class="numbers-label">{n.label}</dt>
            <dd class="numbers-value">{n.value}</dd>
          </div>
        ))
      }
    </dl>
  </section>
</BaseLayout>

<style>
  /* ============================================================
     Page rhythm
     ============================================================ */

  section {
    padding-inline: var(--gutter);
    padding-block: clamp(5rem, 10vw, 10rem);
  }

  /* ============================================================
     Eyebrow
     ============================================================ */

  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    line-height: var(--leading-relaxed);
    margin: 0 0 2.5rem;
  }

  .eyebrow-sep {
    color: var(--color-ink-faint);
    margin-inline: 0.35em;
  }

  /* ============================================================
     Section statement
     ============================================================ */

  .section-statement {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-3xl);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    margin: 0;
    max-width: 28ch;
    color: var(--color-ink);
  }

  .section-deck {
    margin-block: 1.5rem 0;
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
    max-width: var(--max-width-prose);
  }

  /* ============================================================
     link-call
     ============================================================ */

  .link-call {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5em;
    color: var(--color-ink);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .link-call:hover {
    color: var(--color-accent);
  }

  .link-arrow {
    display: inline-block;
    transition: transform var(--duration-slower) var(--ease-editorial);
  }

  .link-call:hover .link-arrow {
    transform: translateX(0.45em);
  }

  /* ============================================================
     1. Hero
     ============================================================ */

  .hero {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-block: clamp(5rem, 12vw, 12rem);
  }

  .hero-statement {
    font-family: var(--font-display);
    font-weight: 200;
    font-size: var(--text-display-1);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tighter);
    margin: 0;
    max-width: 18ch;
    color: var(--color-ink);
  }

  .hero-deck {
    margin-top: 3rem;
    font-size: var(--text-xl);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
    max-width: var(--max-width-prose);
  }

  /* ============================================================
     2. Proof
     ============================================================ */

  .proof {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .proof-list {
    margin: 0;
    border-top: 1px solid var(--color-rule);
  }

  .proof-row {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 2rem;
    align-items: center;
    padding-block: 1.25rem;
    border-bottom: 1px solid var(--color-rule);
  }

  .proof-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    margin: 0;
    line-height: var(--leading-relaxed);
  }

  .proof-values {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2rem;
  }

  .proof-item {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink);
    line-height: var(--leading-relaxed);
  }

  @media (max-width: 720px) {
    .proof-row {
      grid-template-columns: 1fr;
      gap: 0.5rem;
      align-items: start;
    }
  }

  /* ============================================================
     3. Featured project — eyebrow + statement + image +
     (prose | meta) + voice + link, all one section.
     ============================================================ */

  .featured-inner {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .featured-statement {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-4xl);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 clamp(3rem, 6vw, 5rem);
    max-width: 22ch;
    color: var(--color-ink);
  }

  .featured-figure {
    margin: 0 0 clamp(3rem, 6vw, 5rem);
  }

  .featured-image {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border-radius: var(--radius-image);
    background: var(--color-paper-alt);
  }

  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--duration-slowest) var(--ease-editorial);
  }

  .featured-image:hover img {
    transform: scale(1.015);
  }

  .featured-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 4rem;
    align-items: start;
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .featured-prose {
    max-width: 44ch;
  }

  .featured-prose p {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    margin-block: 0 1.25em;
  }

  .featured-prose p:last-child {
    margin-bottom: 0;
  }

  .featured-prose em {
    font-style: italic;
    color: var(--color-ink);
  }

  /* Structured metadata column */

  .featured-meta {
    margin: 0;
    display: grid;
    gap: 0;
    border-top: 1px solid var(--color-rule);
  }

  .featured-meta-row {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 1rem;
    padding-block: 0.9rem;
    border-bottom: 1px solid var(--color-rule);
    align-items: baseline;
  }

  .featured-meta-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    margin: 0;
    line-height: var(--leading-relaxed);
  }

  .featured-meta-value {
    font-size: var(--text-sm);
    color: var(--color-ink);
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* Integrated voice. Aligned with prose width — reads as a coda
     to the story, not a separate section. */

  .featured-voice {
    max-width: var(--max-width-prose);
    margin: 0 0 clamp(2.5rem, 5vw, 4rem);
  }

  .featured-voice-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    margin: 0 0 1.25rem;
  }

  .featured-voice-quote {
    margin: 0;
  }

  /* Body-sans italic rather than Editorial display — keeps this a
     quieter coda that doesn't compete with the manifesto moment
     immediately after. */
  .featured-voice-quote p {
    font-family: var(--font-sans);
    font-weight: var(--weight-normal);
    font-style: italic;
    font-size: var(--text-xl);
    line-height: var(--leading-normal);
    letter-spacing: 0;
    margin: 0 0 1.5rem;
    color: var(--color-ink);
    max-width: 52ch;
  }

  .featured-voice-quote footer {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
  }

  .featured-voice-quote cite {
    font-style: normal;
    display: inline;
  }

  .featured-voice-quote strong {
    color: var(--color-ink);
    font-weight: var(--weight-normal);
  }

  .featured-voice-quote strong::after {
    content: " / ";
    color: var(--color-ink-faint);
    font-weight: var(--weight-normal);
    margin-inline: 0.1em;
  }

  .featured-link-row {
    margin: 0;
  }

  @media (max-width: 880px) {
    .featured-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .featured-statement {
      font-size: var(--text-3xl);
    }

    .featured-voice-quote p {
      font-size: var(--text-lg);
    }
  }

  /* ============================================================
     4. Manifesto moment
     ============================================================ */

  .moment {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-block: clamp(7rem, 16vw, 16rem);
    text-align: center;
  }

  .moment-line {
    font-family: var(--font-display);
    font-weight: 200; /* Ultralight italic — what this face was cut for at scale */
    font-style: italic;
    font-size: var(--text-display-2);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tighter);
    margin: 0;
    color: var(--color-ink);
  }

  .moment-attr {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    margin-top: 4rem;
    display: inline-flex;
    align-items: center;
  }

  .moment-egg {
    color: var(--color-accent);
    height: 0.85em;
  }

  .moment-link {
    color: inherit;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .moment-link:hover {
    color: var(--color-accent);
  }

  /* ============================================================
     5. Recent work index
     ============================================================ */

  .index {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .index-header {
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .index-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
  }

  .index-link {
    display: grid;
    grid-template-columns: 3rem auto 1fr auto 1.5rem;
    align-items: baseline;
    column-gap: 1.5rem;
    padding-block: 1.4rem;
    padding-inline: 0.5rem;
    color: var(--color-ink);
    transition:
      background-color var(--duration-normal) var(--ease-out),
      color var(--duration-normal) var(--ease-out);
    margin-inline: -0.5rem;
  }

  .index-link:hover {
    background: var(--color-paper-alt);
    color: var(--color-accent);
  }

  .index-num {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    font-variant-numeric: tabular-nums;
    transition: color var(--duration-normal) var(--ease-out);
  }

  .index-link:hover .index-num {
    color: var(--color-accent);
  }

  .index-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-xl);
    line-height: 1;
    color: var(--color-ink);
    transition: color var(--duration-normal) var(--ease-out);
  }

  .index-link:hover .index-title {
    color: var(--color-accent);
  }

  .index-tagline {
    font-size: var(--text-sm);
    color: var(--color-ink-faint);
    text-align: right;
    line-height: var(--leading-snug);
    transition: color var(--duration-normal) var(--ease-out);
    max-width: 36ch;
    justify-self: end;
  }

  .index-link:hover .index-tagline {
    color: var(--color-ink-muted);
  }

  .index-year {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    font-variant-numeric: tabular-nums;
    min-width: 3rem;
    text-align: right;
    transition: color var(--duration-normal) var(--ease-out);
  }

  .index-link:hover .index-year {
    color: var(--color-accent);
  }

  .index-mark {
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    color: var(--color-accent);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    line-height: 1;
    opacity: 0;
