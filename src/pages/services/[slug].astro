---
/**
 * /services/[slug] — Service sub-page
 *
 * Lightweight editorial page per service discipline. Kept for SEO.
 * Structure: eyebrow → statement → deck → MDX prose → featured
 * projects (index pattern) → link-call close.
 */

import { getCollection, getEntry, render } from "astro:content";
import BaseLayout from "@/layouts/base.astro";
import Eyebrow from "@/components/ui/eyebrow.astro";
import LinkCall from "@/components/ui/link-call.astro";
import IndexList from "@/components/ui/index-list.astro";
import { mdxComponents } from "@/components/mdx/components";

export async function getStaticPaths() {
  const services = await getCollection("services");
  return services.map((service) => ({
    params: { slug: service.id },
    props: { service },
  }));
}

const { service } = Astro.props;
const { Content } = await render(service);

const seo = service.data.seo;
const title = seo?.metaTitle ?? `${service.data.title} — Significa`;
const description = seo?.metaDescription ?? service.data.tagline;
const ogImage = seo?.ogImage ?? service.data.thumbnail;

const featuredProjects = service.data.featuredProjects?.length
  ? await Promise.all(service.data.featuredProjects.map((ref) => getEntry(ref)))
  : [];
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <article>
    <!-- ============================================================
         Header
         ============================================================ -->
    <header class="service-header">
      <Eyebrow>
        Services <span class="sep">/</span>
        {service.data.title}
      </Eyebrow>
      <h1 class="service-heading">{service.data.title}</h1>
      {service.data.tagline && <p class="service-deck">{service.data.tagline}</p>}
    </header>

    <!-- ============================================================
         MDX body
         ============================================================ -->
    <div class="service-content">
      <div class="service-content-inner prose">
        <Content components={mdxComponents} />
      </div>
    </div>

    <!-- ============================================================
         Featured projects — editorial index
         ============================================================ -->
    {
      featuredProjects.length > 0 && (
        <section class="projects" aria-labelledby="projects-h">
          <Eyebrow id="projects-h">
            Related work
          </Eyebrow>
          <IndexList items={featuredProjects.filter(Boolean).map((project, i) => ({
            href: `/projects/${project!.id}`,
            title: project!.data.title,
            tagline: project!.data.tagline ?? "",
            date: String(new Date(project!.data.date).getFullYear()),
            num: String(i + 1).padStart(2, "0"),
          }))} />
        </section>
      )
    }

    <!-- ============================================================
         Close
         ============================================================ -->
    <div class="service-close">
      <LinkCall href="/say-hello">Start a conversation</LinkCall>
    </div>
  </article>
</BaseLayout>

<style>
  /* ============================================================
     Header
     ============================================================ */

  .service-header {
    max-width: var(--max-width-wide);
    margin-inline: auto;
    padding-inline: var(--gutter);
    padding-block: clamp(4rem, 8vw, 7rem) clamp(2rem, 4vw, 3rem);
  }

  .service-heading {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-4xl);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0;
    max-width: 22ch;
    color: var(--color-ink);
  }

  .service-deck {
    margin-top: 1.5rem;
    font-size: var(--text-xl);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
    max-width: var(--max-width-prose);
  }

  @media (max-width: 768px) {
    .service-heading {
      font-size: var(--text-3xl);
    }
  }

  /* ============================================================
     MDX body
     ============================================================ */

  .service-content {
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .service-content-inner {
    max-width: var(--max-width-narrow);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ============================================================
     Featured projects
     ============================================================ */

  .projects {
    max-width: var(--max-width-wide);
    margin-inline: auto;
    padding-inline: var(--gutter);
    padding-block: clamp(5rem, 10vw, 8rem);
    border-block-start: 1px solid var(--color-rule);
  }

  /* ============================================================
     Close
     ============================================================ */

  .service-close {
    max-width: var(--max-width-wide);
    margin-inline: auto;
    padding-inline: var(--gutter);
    padding-block: clamp(3rem, 6vw, 5rem);
    border-block-start: 1px solid var(--color-rule);
  }
</style>
