---
import BaseLayout from "@/layouts/base.astro";
---

<BaseLayout
  title="B Corp Certified — Significa"
  description="Significa is a Certified B Corporation. We meet the highest standards of social and environmental impact across Governance, Workers, Community, Environment, and Customers."
>
  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="hero">
    <div class="hero-inner">
      <p class="eyebrow">Certified B Corporation</p>
      <h1>Significa is a <strong>B&nbsp;Corp Certified Digital&nbsp;Agency</strong>.</h1>
    </div>
  </section>

  <!-- ============================================================
       INTRO CARD
       ============================================================ -->
  <section class="intro-card-section">
    <div class="intro-card-inner">
      <div class="intro-card">
        <h2>What makes us a B Corp?</h2>
        <p>Explore the steps we're taking to drive continuous improvement and positive change.</p>
        <a
          href="https://www.bcorporation.net/en-us/find-a-b-corp/company/significa/"
          target="_blank"
          rel="noopener noreferrer"
          class="cta-button"
        >
          View our B Corp profile →
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       WHAT IS A B CORP
       ============================================================ -->
  <section class="content-section">
    <div class="content-section-inner">
      <div class="content-block">
        <h2>What's a B Corp?</h2>
        <p>
          A Certified B Corporation is a business that meets the highest standards of social and environmental impact across
          five key areas: Governance, Workers, Community, Environment, and Customers. Certification ensures that Significa
          operates with transparency, fairness, and accountability.
        </p>
      </div>

      <ul class="pillars-grid">
        <li class="pillar-card">
          <span class="pillar-number" aria-hidden="true">01</span>
          <h3 class="pillar-name">Governance</h3>
          <p class="pillar-description">Transparent decision-making and ethical leadership that serves all stakeholders.</p>
        </li>
        <li class="pillar-card">
          <span class="pillar-number" aria-hidden="true">02</span>
          <h3 class="pillar-name">Workers</h3>
          <p class="pillar-description">
            Fair compensation, career development, and a workplace where people genuinely thrive.
          </p>
        </li>
        <li class="pillar-card">
          <span class="pillar-number" aria-hidden="true">03</span>
          <h3 class="pillar-name">Community</h3>
          <p class="pillar-description">Supporting local economies, diverse suppliers, and the communities around us.</p>
        </li>
        <li class="pillar-card">
          <span class="pillar-number" aria-hidden="true">04</span>
          <h3 class="pillar-name">Environment</h3>
          <p class="pillar-description">
            Reducing our footprint, measuring our impact, and contributing to a healthier planet.
          </p>
        </li>
        <li class="pillar-card">
          <span class="pillar-number" aria-hidden="true">05</span>
          <h3 class="pillar-name">Customers</h3>
          <p class="pillar-description">Building products that are ethical, inclusive, accessible, and genuinely useful.</p>
        </li>
      </ul>
    </div>
  </section>

  <!-- ============================================================
       WHY B CORP
       ============================================================ -->
  <section class="why-section">
    <div class="why-section-inner">
      <div class="why-text">
        <h2>Why B Corp?</h2>
        <p>
          We strive to create meaningful experiences that improve lives. Becoming a B Corp reinforces our commitment to
          designing and building products that are ethically, inclusively, and sustainably. It's about how we build, for whom,
          and the positive impact we aim to create for our people, our clients, our users, and the communities we serve.
        </p>
      </div>
      <div class="why-image">
        <img
          src="https://cdn.significa.co/about/bcorp-certificate.jpg"
          alt="Significa B Corp certificate"
          width="960"
          height="640"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <!-- ============================================================
       WHAT'S NEXT
       ============================================================ -->
  <section class="next-section">
    <div class="next-section-inner">
      <h2>What's next?</h2>
      <p>
        Becoming certified is only the beginning. B Lab, like Significa, believes in continuous improvement, which is why we're
        already working on increasing our score and impact towards recertification in 2028.
      </p>
      <a href="/impact" class="link-arrow">See how we build with impact →</a>
    </div>
  </section>

  <!-- ============================================================
       FINAL CTA
       ============================================================ -->
  <section class="final-cta">
    <div class="final-cta-inner">
      <h2>Want to build something that does good?</h2>
      <p>Work with a team that holds itself to a higher standard.</p>
      <a href="/work-with-us" class="cta-button-large">Get in touch</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============================================================
     Shared utilities
     ============================================================ */
  .eyebrow {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .link-arrow {
    display: inline-block;
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .link-arrow:hover {
    color: var(--color-text);
  }

  .cta-button {
    display: inline-block;
    padding: 0.8125rem 1.75rem;
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    border-radius: 0.375rem;
    background: var(--color-text);
    color: var(--color-surface);
    transition:
      opacity var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }
  .cta-button:hover {
    opacity: 0.82;
    transform: translateY(-1px);
  }

  .cta-button-large {
    display: inline-block;
    padding: 1rem 2.5rem;
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    border-radius: 0.375rem;
    background: var(--color-text);
    color: var(--color-surface);
    transition:
      opacity var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }
  .cta-button-large:hover {
    opacity: 0.82;
    transform: translateY(-1px);
  }

  /* ============================================================
     HERO
     ============================================================ */
  .hero {
    padding: 9rem var(--gutter) 6rem;
  }

  .hero-inner {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
  }

  .hero h1 {
    font-size: clamp(2rem, 1.25rem + 3vw, 3.25rem);
    font-weight: var(--weight-normal);
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .hero h1 strong {
    font-weight: var(--weight-bold);
  }

  /* ============================================================
     INTRO CARD
     ============================================================ */
  .intro-card-section {
    padding: 0 var(--gutter) 7rem;
  }

  .intro-card-inner {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
  }

  .intro-card {
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }

  .intro-card h2 {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .intro-card p {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    max-width: 50ch;
  }

  .intro-card .cta-button {
    margin-top: 0.5rem;
  }

  /* ============================================================
     WHAT IS A B CORP
     ============================================================ */
  .content-section {
    background: var(--color-surface-alt);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 7rem var(--gutter);
  }

  .content-section-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 5rem;
  }

  .content-block h2 {
    font-size: clamp(1.5rem, 1.25rem + 1.5vw, 2.25rem);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    margin-bottom: 1.25rem;
  }

  .content-block p {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    max-width: 65ch;
  }

  /* Five-pillar grid */
  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1px;
    list-style: none;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .pillar-card {
    background: var(--color-surface);
    padding: 2.25rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .pillar-card:hover {
    background: var(--color-surface-alt);
  }

  .pillar-number {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }

  .pillar-name {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .pillar-description {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
  }

  @media (max-width: 1024px) {
    .pillars-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 640px) {
    .pillars-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 420px) {
    .pillars-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ============================================================
     WHY B CORP
     ============================================================ */
  .why-section {
    padding: 7rem var(--gutter);
  }

  .why-section-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .why-text h2 {
    font-size: clamp(1.5rem, 1.25rem + 1.5vw, 2.25rem);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    margin-bottom: 1.5rem;
  }

  .why-text p {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    max-width: 55ch;
  }

  .why-image img {
    width: 100%;
    height: auto;
    border-radius: 0.5rem;
    display: block;
  }

  @media (max-width: 860px) {
    .why-section-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  /* ============================================================
     WHAT'S NEXT
     ============================================================ */
  .next-section {
    background: var(--color-surface-alt);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 7rem var(--gutter);
  }

  .next-section-inner {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
  }

  .next-section h2 {
    font-size: clamp(1.5rem, 1.25rem + 1.5vw, 2.25rem);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    margin-bottom: 1.25rem;
  }

  .next-section p {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    max-width: 60ch;
    margin-bottom: 2rem;
  }

  /* ============================================================
     FINAL CTA
     ============================================================ */
  .final-cta {
    padding: 9rem var(--gutter);
  }

  .final-cta-inner {
    max-width: 36rem;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .final-cta h2 {
    font-size: clamp(1.75rem, 1.25rem + 2vw, 2.75rem);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
  }

  .final-cta p {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
  }

  .final-cta .cta-button-large {
    margin-top: 0.5rem;
  }
</style>
