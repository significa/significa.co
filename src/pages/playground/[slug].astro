---
/**
 * /playground/[slug] — Lab project detail
 *
 * Same editorial register as blog posts. Eyebrow meta, display title,
 * prose.css body. Lightweight. The work speaks.
 */

import { render } from "astro:content";
import BaseLayout from "@/layouts/base.astro";
import Eyebrow from "@/components/ui/eyebrow.astro";
import LinkCall from "@/components/ui/link-call.astro";
import { mdxComponents } from "@/components/mdx/components";
import { getPlayground } from "@/lib/collections";
import { cdnUrl } from "@/lib/cdn";

export async function getStaticPaths() {
  const playground = await getPlayground();
  return playground.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);

const seo = item.data.seo;
const title = seo?.metaTitle ?? item.data.title;
const description = seo?.metaDescription ?? item.data.description;
const ogImage = seo?.ogImage ?? item.data.thumbnail;

const formattedDate = item.data.date.toLocaleDateString("en-GB", {
  year: "numeric",
  month: "long",
});
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <article class="lab">
    <header class="lab-header">
      <Eyebrow>
        <time datetime={item.data.date.toISOString()}>{formattedDate}</time>
        {
          item.data.repoUrl && (
            <>
              <span class="sep">/</span>
              <a href={item.data.repoUrl} target="_blank" rel="noopener noreferrer">
                GitHub
              </a>
            </>
          )
        }
      </Eyebrow>
      <h1 class="lab-title">{item.data.title}</h1>
      {item.data.description && <p class="lab-deck">{item.data.description}</p>}
    </header>

    {
      item.data.thumbnail && (
        <div class="lab-hero">
          <img
            src={cdnUrl(item.data.thumbnail, { width: 1600, quality: 85 })}
            alt={item.data.altText ?? item.data.title}
            width="1600"
            height="900"
            loading="eager"
            decoding="async"
          />
        </div>
      )
    }

    <div class="lab-content">
      <div class="lab-content-inner prose">
        <Content components={mdxComponents} />
      </div>
    </div>

    <footer class="lab-footer">
      <LinkCall href="/playground">Back to playground</LinkCall>
    </footer>
  </article>
</BaseLayout>

<style>
  .lab-header {
    max-width: var(--max-width-narrow);
    margin-inline: auto;
    padding-inline: var(--gutter);
    padding-block: clamp(4rem, 8vw, 7rem) clamp(2rem, 4vw, 3rem);
  }

  .lab-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-4xl);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0;
    color: var(--color-ink);
  }

  .lab-deck {
    margin-block-start: 1.5rem;
    font-size: var(--text-xl);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
  }

  @media (max-width: 768px) {
    .lab-title {
      font-size: var(--text-3xl);
    }

    .lab-deck {
      font-size: var(--text-lg);
    }
  }

  .lab-hero {
    max-width: var(--max-width-narrow);
    margin-inline: auto;
    padding-inline: var(--gutter);
    padding-block-end: clamp(2rem, 4vw, 3rem);
  }

  .lab-hero img {
    width: 100%;
    height: auto;
    max-height: 480px;
    object-fit: cover;
    display: block;
    border-radius: var(--radius-image);
  }

  .lab-content {
    padding-block: 0 clamp(3rem, 6vw, 5rem);
  }

  .lab-content-inner {
    max-width: var(--max-width-narrow);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  .lab-footer {
    max-width: var(--max-width-narrow);
    margin-inline: auto;
    padding-inline: var(--gutter);
    padding-block: clamp(2rem, 4vw, 3rem) clamp(5rem, 10vw, 8rem);
    border-block-start: 1px solid var(--color-rule);
  }
</style>
