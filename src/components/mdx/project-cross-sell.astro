---
import { getEntry } from "astro:content";
import { cdnUrl, DEFAULT_QUALITY } from "@/lib/cdn";
import { contentError } from "@/lib/content-errors";

interface Props {
  project: string;
  title?: string;
  description?: string;
}

const { project: slug, title, description } = Astro.props;

if (!slug) {
  contentError("ProjectCrossSell", Astro.url.pathname, "Missing required prop: project");
}

const project = await getEntry("projects", slug);

if (!project) {
  contentError(
    "ProjectCrossSell",
    Astro.url.pathname,
    `Project "${slug}" not found. Check the slug exists in src/content/projects/.`
  );
}

const thumbnailSrc = cdnUrl(project.data.thumbnail, {
  width: 400,
  quality: DEFAULT_QUALITY,
});
---

<aside class="cross-sell">
  <a href={`/work/${project.id}`} class="cross-sell-link">
    {
      project.data.thumbnail && (
        <img
          src={thumbnailSrc}
          alt={project.data.altText ?? project.data.title}
          loading="lazy"
          decoding="async"
          class="cross-sell-thumb"
        />
      )
    }
    <div class="cross-sell-body">
      <span class="cross-sell-title">{project.data.title}</span>
      {project.data.tagline && <span class="cross-sell-tagline">{project.data.tagline}</span>}
    </div>
    <span class="cross-sell-arrow" aria-hidden="true">&rarr;</span>
  </a>
</aside>

<style>
  .cross-sell {
    margin: 2.5rem 0;
  }

  .cross-sell-link {
    display: grid;
    grid-template-columns: 5rem 1fr auto;
    align-items: center;
    gap: 1.5rem;
    padding: 1rem;
    margin-inline: -1rem;
    border-radius: 6px;
    color: var(--color-ink);
    transition:
      background-color var(--duration-normal) var(--ease-out),
      color var(--duration-normal) var(--ease-out);
  }

  .cross-sell-link:hover {
    background: var(--color-paper-alt);
    color: var(--color-accent);
  }

  .cross-sell-thumb {
    width: 5rem;
    height: 3.5rem;
    object-fit: cover;
    border-radius: 4px;
    display: block;
    background: var(--color-paper-alt);
  }

  .cross-sell-body {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .cross-sell-title {
    font-weight: var(--weight-medium);
    font-size: var(--text-xl);
    line-height: 1;
    letter-spacing: var(--tracking-tight);
    transition: color var(--duration-normal) var(--ease-out);
  }

  .cross-sell-link:hover .cross-sell-title {
    color: var(--color-accent);
  }

  .cross-sell-tagline {
    font-size: var(--text-sm);
    color: var(--color-ink-faint);
    line-height: var(--leading-snug);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .cross-sell-arrow {
    color: var(--color-accent);
    font-size: var(--text-base);
    opacity: 0;
    transform: translateX(-0.4em);
    transition:
      opacity var(--duration-normal) var(--ease-editorial),
      transform var(--duration-normal) var(--ease-editorial);
  }

  .cross-sell-link:hover .cross-sell-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  @media (max-width: 640px) {
    .cross-sell-link {
      grid-template-columns: 4rem 1fr auto;
      gap: 1rem;
    }

    .cross-sell-thumb {
      width: 4rem;
      height: 3rem;
    }

    .cross-sell-tagline {
      display: none;
    }
  }
</style>
