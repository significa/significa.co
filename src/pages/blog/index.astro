---
import BaseLayout from "@/layouts/base.astro";
import { getPosts } from "@/lib/collections";
import { cdnUrl } from "@/lib/cdn";

const allPosts = await getPosts();

// Separate featured post (most recent)
const featuredPost = allPosts[0];
const recentPosts = allPosts.slice(1);

// Extract all unique tags from posts
const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags || []))].sort();

// Calculate reading time helper
function calculateReadingTime(post: (typeof allPosts)[number]): number {
  const wordCount = post.body?.split(/\s+/).length ?? 0;
  return wordCount > 0 ? Math.ceil(wordCount / 200) : 5;
}

// Format date helper
function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

const INITIAL_COUNT = 6;
---

<BaseLayout
  title="Blog"
  description="Thoughts on design, engineering, product strategy, and building digital products that work beautifully."
>
  <!-- Blog Header -->
  <section class="blog-header">
    <div class="blog-header-inner">
      <h1 class="blog-title">We think things through.</h1>
      <p class="blog-description">
        Insights on design, development, and building products from our team of designers, developers, and product managers.
      </p>
    </div>
  </section>

  <!-- Featured Post -->
  {
    featuredPost && (
      <section class="featured-post">
        <div class="featured-post-inner">
          <a href={`/blog/${featuredPost.id}`} class="featured-link">
            {featuredPost.data.thumbnail && (
              <div class="featured-image">
                <img
                  src={cdnUrl(featuredPost.data.thumbnail, { width: 1200, quality: 85 })}
                  alt={featuredPost.data.title}
                  width="1200"
                  height="675"
                  loading="eager"
                  decoding="async"
                />
              </div>
            )}
            <div class="featured-content">
              <div class="featured-meta">
                <span class="featured-label">Featured</span>
                <time datetime={featuredPost.data.date.toISOString()}>{formatDate(featuredPost.data.date)}</time>
                <span class="meta-separator">•</span>
                <span class="reading-time">{calculateReadingTime(featuredPost)} min read</span>
              </div>
              <h2 class="featured-title">{featuredPost.data.title}</h2>
              {featuredPost.data.description && <p class="featured-description">{featuredPost.data.description}</p>}
              {featuredPost.data.tags && featuredPost.data.tags.length > 0 && (
                <ul class="featured-tags">
                  {featuredPost.data.tags.map((tag) => (
                    <li class="tag-badge">{tag}</li>
                  ))}
                </ul>
              )}
            </div>
          </a>
        </div>
      </section>
    )
  }

  <!-- Tag Filter (Client-side enhanced) -->
  {
    allTags.length > 0 && (
      <section class="tag-filter">
        <div class="tag-filter-inner">
          <label class="filter-label">Filter by topic:</label>
          <div class="tag-buttons">
            <button class="tag-button active" data-tag="all">
              All
            </button>
            {allTags.map((tag) => (
              <button class="tag-button" data-tag={tag}>
                {tag}
              </button>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- Blog Grid -->
  {
    recentPosts.length > 0 ? (
      <section class="blog-grid">
        <div class="blog-grid-inner">
          {recentPosts.map((post, index) => (
            <article
              class="blog-card"
              data-tags={JSON.stringify(post.data.tags || [])}
              data-index={index}
              style={index >= INITIAL_COUNT ? "display: none;" : ""}
            >
              <a href={`/blog/${post.id}`} class="card-link">
                {post.data.thumbnail && (
                  <div class="card-image">
                    <img
                      src={cdnUrl(post.data.thumbnail, { width: 600, quality: 80 })}
                      alt={post.data.title}
                      width="600"
                      height="400"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                )}
                <div class="card-content">
                  <div class="card-meta">
                    <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
                    <span class="meta-separator">•</span>
                    <span class="reading-time">{calculateReadingTime(post)} min read</span>
                  </div>
                  <h2 class="card-title">{post.data.title}</h2>
                  {post.data.description && <p class="card-description">{post.data.description}</p>}
                  {post.data.tags && post.data.tags.length > 0 && (
                    <ul class="card-tags">
                      {post.data.tags.map((tag) => (
                        <li class="tag-badge">{tag}</li>
                      ))}
                    </ul>
                  )}
                </div>
              </a>
            </article>
          ))}
        </div>

        <!-- Load More -->
        {recentPosts.length > INITIAL_COUNT && (
          <div class="load-more-wrapper">
            <button class="load-more-button" id="load-more-btn">
              Load more
            </button>
          </div>
        )}
      </section>
    ) : (
      <section class="empty-state">
        <div class="empty-state-inner">
          <p>No posts yet. Check back soon!</p>
        </div>
      </section>
    )
  }

  <!-- Newsletter CTA (Optional) -->
  <section class="newsletter-cta">
    <div class="newsletter-cta-inner">
      <h2>Stay updated</h2>
      <p>Get insights on design, development, and building products delivered to your inbox.</p>
      <a href="/say-hello" class="cta-button">Get in touch</a>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ INITIAL_COUNT }} is:inline>
  const BATCH_SIZE = INITIAL_COUNT;

  function init() {
    const buttons = document.querySelectorAll(".tag-button");
    const cards = document.querySelectorAll(".blog-card");
    const loadMoreBtn = document.getElementById("load-more-btn");

    if (!cards.length) return;

    let activeTag = "all";
    // How many cards in the current filtered set have been revealed
    let visibleCount = BATCH_SIZE;

    // ----------------------------------------------------------------
    // Core helpers
    // ----------------------------------------------------------------

    /** Returns all cards that match the current tag filter, in DOM order */
    function getFilteredCards() {
      return Array.from(cards).filter((card) => {
        if (activeTag === "all") return true;
        try {
          const tags = JSON.parse(card.dataset.tags || "[]");
          return tags.includes(activeTag);
        } catch {
          return false;
        }
      });
    }

    /** Re-renders card visibility and load-more button state */
    function render() {
      const filtered = getFilteredCards();

      cards.forEach((card) => {
        card.style.display = "none";
      });

      filtered.slice(0, visibleCount).forEach((card) => {
        card.style.display = "";
      });

      if (loadMoreBtn) {
        if (filtered.length > visibleCount) {
          loadMoreBtn.style.display = "";
          const remaining = filtered.length - visibleCount;
          loadMoreBtn.textContent =
            remaining <= BATCH_SIZE
              ? `Load ${remaining} more`
              : `Load more`;
        } else {
          loadMoreBtn.style.display = "none";
        }
      }
    }

    // ----------------------------------------------------------------
    // Tag filter
    // ----------------------------------------------------------------
    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const tag = button.dataset.tag;
        if (!tag) return;

        activeTag = tag;
        visibleCount = BATCH_SIZE;

        buttons.forEach((btn) => btn.classList.remove("active"));
        button.classList.add("active");

        render();
      });
    });

    // ----------------------------------------------------------------
    // Load more
    // ----------------------------------------------------------------
    if (loadMoreBtn) {
      loadMoreBtn.addEventListener("click", () => {
        visibleCount += BATCH_SIZE;
        render();
      });
    }

    // Initial render (respects the server-side hidden state but hands
    // control fully to JS from this point on)
    render();
  }

  init();
  document.addEventListener("astro:after-swap", init);
</script>

<style>
  /* ============================================================
     Blog Header
     ============================================================ */
  .blog-header {
    padding: 8rem var(--gutter) 4rem;
    background: var(--color-surface);
  }

  .blog-header-inner {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
    text-align: center;
  }

  .blog-title {
    font-size: var(--text-4xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin-bottom: 1.5rem;
  }

  .blog-description {
    font-size: var(--text-xl);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .blog-title {
      font-size: var(--text-3xl);
    }

    .blog-description {
      font-size: var(--text-lg);
    }
  }

  /* ============================================================
     Featured Post
     ============================================================ */
  .featured-post {
    padding: 0 var(--gutter) 4rem;
  }

  .featured-post-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .featured-link {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    text-decoration: none;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow: hidden;
    background: var(--color-surface);
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .featured-link:hover {
    border-color: var(--color-text);
  }

  .featured-image {
    height: 100%;
    overflow: hidden;
    background: var(--color-surface-alt);
  }

  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .featured-link:hover .featured-image img {
    transform: scale(1.05);
  }

  .featured-content {
    padding: 3rem;
  }

  .featured-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .featured-label {
    padding: 0.25rem 0.5rem;
    background: var(--color-text);
    color: var(--color-surface);
    border-radius: 0.25rem;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .meta-separator {
    opacity: 0.5;
  }

  .featured-title {
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    margin-bottom: 1rem;
  }

  .featured-description {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .featured-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
  }

  @media (max-width: 968px) {
    .featured-link {
      grid-template-columns: 1fr;
    }

    .featured-image {
      height: 300px;
    }

    .featured-content {
      padding: 2rem;
    }

    .featured-title {
      font-size: var(--text-2xl);
    }
  }

  /* ============================================================
     Tag Filter
     ============================================================ */
  .tag-filter {
    padding: 0 var(--gutter) 3rem;
  }

  .tag-filter-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .filter-label {
    display: block;
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .tag-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tag-button {
    padding: 0.5rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 2rem;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-out);
    text-transform: capitalize;
  }

  .tag-button:hover {
    border-color: var(--color-text);
    color: var(--color-text);
  }

  .tag-button.active {
    background: var(--color-text);
    color: var(--color-surface);
    border-color: var(--color-text);
  }

  /* ============================================================
     Blog Grid
     ============================================================ */
  .blog-grid {
    padding: 0 var(--gutter) 4rem;
  }

  .blog-grid-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .blog-card {
    display: flex;
    flex-direction: column;
  }

  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow: hidden;
    background: var(--color-surface);
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .card-link:hover {
    border-color: var(--color-text);
  }

  .card-image {
    width: 100%;
    height: 240px;
    overflow: hidden;
    background: var(--color-surface-alt);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .card-link:hover .card-image img {
    transform: scale(1.05);
  }

  .card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex-grow: 1;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .card-title {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .card-description {
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
    flex-grow: 1;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin-top: auto;
  }

  .tag-badge {
    padding: 0.25rem 0.625rem;
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: capitalize;
  }

  /* ============================================================
     Load More
     ============================================================ */
  .load-more-wrapper {
    display: flex;
    justify-content: center;
    padding-top: 1rem;
  }

  .load-more-button {
    padding: 0.75rem 2.5rem;
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    font-family: inherit;
    color: var(--color-text);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 2rem;
    cursor: pointer;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }

  .load-more-button:hover {
    border-color: var(--color-text);
    color: var(--color-text);
  }

  /* ============================================================
     Empty State
     ============================================================ */
  .empty-state {
    padding: 4rem var(--gutter);
  }

  .empty-state-inner {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
    text-align: center;
  }

  .empty-state p {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  /* ============================================================
     Newsletter CTA
     ============================================================ */
  .newsletter-cta {
    padding: 6rem var(--gutter);
    background: var(--color-surface-alt);
  }

  .newsletter-cta-inner {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
    text-align: center;
  }

  .newsletter-cta h2 {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    margin-bottom: 1rem;
  }

  .newsletter-cta p {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .cta-button {
    display: inline-block;
    padding: 1rem 2.5rem;
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    border-radius: 0.5rem;
    background: var(--color-text);
    color: var(--color-surface);
    border: 2px solid var(--color-text);
    transition: all var(--duration-fast) var(--ease-out);
  }

  .cta-button:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }
</style>
