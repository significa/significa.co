---
/**
 * /b-corp — B Corp certification
 *
 * The B Corp story is a differentiator. Present it with editorial
 * weight, not as a badge collection. Structure:
 *   1. Position statement — what it means, not what it is.
 *   2. Five pillars — numbered list, not cards.
 *   3. Why — the honest reason, not the corporate one.
 *   4. What's next — recertification commitment.
 *   5. Close — link-call to impact page.
 */

import BaseLayout from "@/layouts/base.astro";
import Eyebrow from "@/components/ui/eyebrow.astro";
import SectionHeader from "@/components/ui/section-header.astro";
import QaList from "@/components/ui/qa-list.astro";
import LinkCall from "@/components/ui/link-call.astro";
import { cdnUrl } from "@/lib/cdn";

const pillars = [
  {
    n: "01",
    q: "Governance",
    a: "Transparent decision-making and ethical leadership that serves all stakeholders. Not a board formality. An active constraint on how we make every call.",
  },
  {
    n: "02",
    q: "Workers",
    a: "Fair compensation, career development, and a workplace where people genuinely thrive. Period leave, unlimited learning stipend, mental health support. The specifics matter more than the principles.",
  },
  {
    n: "03",
    q: "Community",
    a: "Supporting local economies, diverse suppliers, and the communities around us. We're in Porto. The city shapes the studio, and the studio should give back.",
  },
  {
    n: "04",
    q: "Environment",
    a: "Reducing our footprint, measuring our impact, contributing to a healthier planet. A digital studio's footprint is smaller than a factory's, but it's not zero, and pretending otherwise is dishonest.",
  },
  {
    n: "05",
    q: "Customers",
    a: "Building products that are ethical, inclusive, accessible, and genuinely useful. The certification makes us prove it, not just claim it.",
  },
];
---

<BaseLayout
  title="B Corp Certified — Significa"
  description="Significa is a Certified B Corporation. We meet the highest standards of social and environmental impact across Governance, Workers, Community, Environment, and Customers."
>
  <!-- ============================================================
       1. Position statement
       ============================================================ -->
  <section class="hero" aria-labelledby="hero-h">
    <Eyebrow>Certified B Corporation</Eyebrow>
    <h1 id="hero-h" class="hero-heading">
      Certification is a constraint.<br />Constraints make better companies.
    </h1>
    <p class="hero-deck">
      B Corp certification means an external body audits how we treat people, the planet, and the communities around us. We
      sought it because accountability is easier when someone else is checking.
    </p>
    <p class="hero-link">
      <LinkCall href="https://www.bcorporation.net/en-us/find-a-b-corp/company/significa/"> View our B Corp profile </LinkCall>
    </p>
  </section>

  <!-- ============================================================
       2. Five pillars — what gets measured
       ============================================================ -->
  <section class="pillars" aria-labelledby="pillars-h">
    <header class="pillars-header">
      <Eyebrow>What gets measured</Eyebrow>
      <SectionHeader id="pillars-h">Five areas, audited.</SectionHeader>
    </header>
    <QaList items={pillars} />
  </section>

  <!-- ============================================================
       3. Why — with image
       ============================================================ -->
  <section class="why" aria-labelledby="why-h">
    <div class="why-inner">
      <div class="why-text">
        <Eyebrow>Why B Corp</Eyebrow>
        <h2 id="why-h" class="why-heading">Because "we care" is easy to say and impossible to verify.</h2>
        <p class="why-prose">
          Every agency claims to care about impact. B Corp is the version where someone checks. The certification process forced
          us to formalise things we were already doing, fix things we were neglecting, and commit to things we were avoiding.
          That's the point.
        </p>
      </div>
      <figure class="why-figure">
        <img
          src={cdnUrl("https://cdn.significa.co/about/bcorp-certificate.jpg", { width: 960, quality: 85 })}
          alt="Significa B Corp certificate"
          width="960"
          height="640"
          loading="lazy"
          decoding="async"
        />
      </figure>
    </div>
  </section>

  <!-- ============================================================
       4. What's next
       ============================================================ -->
  <section class="next" aria-labelledby="next-h">
    <Eyebrow>What's next</Eyebrow>
    <h2 id="next-h" class="next-heading">Recertification in 2028.</h2>
    <p class="next-prose">
      Certification is not a trophy. B Lab requires recertification because improvement is the point, not the badge. We're
      already working on increasing our score and impact. The goal is to be measurably better at the next audit, not just to
      pass it again.
    </p>
  </section>

  <!-- ============================================================
       5. Close
       ============================================================ -->
  <footer class="close">
    <LinkCall href="/impact">See how we build with impact</LinkCall>
  </footer>
</BaseLayout>

<style>
  section {
    padding-inline: var(--gutter);
    padding-block: clamp(5rem, 10vw, 10rem);
  }

  /* ── Hero ── */

  .hero {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-block: clamp(5rem, 8vw, 10rem) clamp(5rem, 10vw, 10rem);
  }

  .hero-heading {
    font-family: var(--font-display);
    font-weight: 200;
    font-size: var(--text-display-2);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tighter);
    margin: 0;
    max-width: 20ch;
    color: var(--color-ink);
  }

  .hero-deck {
    margin-block: 2.5rem 0;
    font-size: var(--text-xl);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
    max-width: var(--max-width-prose);
  }

  .hero-link {
    margin-block-start: 2rem;
  }

  @media (max-width: 768px) {
    .hero-heading {
      font-size: var(--text-4xl);
    }
  }

  /* ── Pillars ── */

  .pillars {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .pillars-header {
    margin-block-end: clamp(3rem, 6vw, 5rem);
  }

  /* ── Why ── */

  .why {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .why-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 6rem);
    align-items: center;
  }

  .why-heading {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-3xl);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 1.5rem;
    color: var(--color-ink);
  }

  .why-prose {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
    max-width: 48ch;
  }

  .why-figure {
    margin: 0;
  }

  .why-figure img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-image);
  }

  @media (max-width: 860px) {
    .why-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .why-heading {
      font-size: var(--text-2xl);
    }
  }

  /* ── Next ── */

  .next {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    border-block-start: 1px solid var(--color-rule);
  }

  .next-heading {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-3xl);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 1.5rem;
    color: var(--color-ink);
  }

  .next-prose {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
    max-width: var(--max-width-prose);
  }

  /* ── Close ── */

  .close {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-inline: var(--gutter);
    padding-block: 0 clamp(5rem, 10vw, 8rem);
  }
</style>
