---
/**
 * Homepage
 *
 * Per the brand docs. Order optimised for narrative flow:
 *
 *   1. Hero — position statement + capability breadth in the deck.
 *   2. Proof — recognition + clients, thin mono strips.
 *   3. Featured — DIA as linear narrative: hook → story → image
 *      (proof) → client voice (coda) → metadata strip → link.
 *   4. Manifesto moment — "Judgement is the work." One line, standalone.
 *   5. Recent work — compact editorial index.
 *   6. Numbers — since / team / projects / recognitions.
 *   7. Three questions — the judgment layer, placed at the close where
 *      a considering visitor is ready to read them.
 *
 * Italics are reserved for the manifesto moment only. Links use the
 * .link-call pattern (no underline, animated arrow on hover).
 */

import BaseLayout from "@/layouts/base.astro";
import Egg from "@/components/ui/egg.astro";
import { getEntry } from "astro:content";
import { getProjects, getClients } from "@/lib/collections";
import { cdnUrl } from "@/lib/cdn";
import { webSiteJsonLd } from "@/lib/seo";

const featured = await getEntry("projects", "dia");
const allProjects = (await getProjects()).filter((p) => p.id !== "dia").slice(0, 8);
const clients = await getClients();

const recognitions = ["Red Dot", "iF Design", "German Design Council", "European Design", "Good Design", "Awwwards"];

// Metadata for the DIA feature. Kept here inline because it's curated copy,
// not a straight dump of the project frontmatter (e.g. "Role" is a homepage
// framing, not a field on the content entry).
const featuredMeta = [
  { label: "Client", value: "The Fertility Partnership" },
  { label: "Role", value: "Strategy, Design, Engineering" },
  { label: "Deliverables", value: "iOS + Android apps, CMS, Brand identity" },
  { label: "Industry", value: "Healthcare, Femtech" },
  { label: "Recognition", value: "Red Dot · iF · German Gold · Good Design · European Gold" },
];

const services = [
  {
    n: "01",
    q: "How do you know when the work is done?",
    a: "When the thing does what it's meant to without extra — no leftover complexity, no speculative features, no visible seams. That takes more rounds than shipping the spec, but the result is work that ages better, breaks less, and doesn't need a rewrite in eighteen months. The test is whether we'd be happy to maintain this in year three.",
  },
  {
    n: "02",
    q: "How do you decide what not to build?",
    a: "Every brief contains features that won't earn their place in the final product. Cutting them isn't about shipping less — it's about making what remains feel more considered. We identify what to trim early, say so out loud, and have the honest conversation. Saying no to a feature is how you get to say yes to craft.",
  },
  {
    n: "03",
    q: "What does it cost when we're wrong?",
    a: "We're wrong sometimes. The cost shows up in extra rounds, missed assumptions, or features that didn't earn their place. We absorb that cost when it's ours and we say so. We don't externalise it as scope creep or invoice it as additional discovery.",
  },
];

// Numbers that answer unspoken client anxieties: stability, depth,
// trust, and the one-team differentiator. Verify figures with ops.
const numbers = [
  { label: "In business since", value: "2015" },
  { label: "Client NPS", value: "87" },
  { label: "Repeat engagements", value: "3 in 4" },
  { label: "Outsourced work", value: "0%" },
];

const structuredData = [webSiteJsonLd()];
---

<BaseLayout
  title="Significa — A design & engineering studio in Porto"
  description="Significa is a design and engineering studio in Porto. We make digital products — platforms, e-commerce, apps, design systems — for businesses that want complexity met with care."
  structuredData={structuredData}
>
  <!-- ============================================================
       1. Hero — position + capability breadth
       ============================================================ -->
  <section class="hero" aria-labelledby="hero-h">
    <p class="eyebrow">A design &amp; engineering studio <span class="eyebrow-sep">/</span> Porto</p>
    <h1 id="hero-h" class="hero-statement">
      We exist to prove that <em>rigour</em> and <em>beauty</em> are not opposites.
    </h1>
    <p class="hero-deck">
      Designers and engineers working as one team. We make digital products — platforms, e-commerce, apps, design systems — for
      businesses that want complexity met with care, not avoided.
    </p>
  </section>

  <!-- ============================================================
       2. Proof — two compact mono strips
       ============================================================ -->
  <section class="proof" aria-label="Credibility">
    <dl class="proof-list">
      <div class="proof-row">
        <dt class="proof-label">Recognised by</dt>
        <dd class="proof-values">
          {recognitions.map((r) => <span class="proof-item">{r}</span>)}
        </dd>
      </div>
      <div class="proof-row">
        <dt class="proof-label">Trusted by</dt>
        <dd class="proof-values">
          {clients.map((c) => <span class="proof-item">{c.data.name}</span>)}
        </dd>
      </div>
    </dl>
  </section>

  <!-- ============================================================
       3. Featured project — linear narrative: hook → story → image
       (as proof) → client voice (coda) → metadata strip → link.
       One reading direction, no grid splits.
       ============================================================ -->
  {
    featured && (
      <section class="featured" aria-labelledby="featured-h">
        <div class="featured-inner">
          <p class="eyebrow">
            Recent work <span class="eyebrow-sep">/</span> {featured.data.client} <span class="eyebrow-sep">/</span> 2022
          </p>

          <h2 id="featured-h" class="featured-statement">
            A period tracker brief that grew into a fertility companion.
          </h2>

          <div class="featured-prose">
            <p>
              TFP came to us looking for a competitor in a market full of period trackers. Six weeks of discovery reframed what
              the project was. The final product logs cycles, forecasts fertility, teaches, and builds a relationship rather
              than a dataset, a companion, not a tracker.
            </p>
            <p>
              Five international design awards later, including a <em>Red Dot</em>, Dia stood alone in its category. Not because
              it shouted louder, but because it understood better.
            </p>
          </div>

          <figure class="featured-figure">
            <div class="featured-image">
              <img
                src={cdnUrl(featured.data.thumbnail, { width: 1800, quality: 88 })}
                alt={featured.data.altText ?? `${featured.data.title} — ${featured.data.tagline}`}
                width="1800"
                height="1200"
                loading="lazy"
                decoding="async"
              />
            </div>
          </figure>

          <aside class="featured-voice" aria-label="Client voice">
            <blockquote class="featured-voice-quote">
              <p>
                Dia started as a simple tracker brief. Six weeks of discovery with Significa reframed what we were building. We
                ended up with a product we&rsquo;re proud of, bigger than we&rsquo;d scoped, and better for it.
              </p>
              <footer>
                <cite>
                  <strong>Chakameh Shafii</strong>
                  <span>Former Director at TFP, Head of Dia</span>
                </cite>
              </footer>
            </blockquote>
          </aside>

          <dl class="featured-meta">
            {featuredMeta.map((m) => (
              <div class="featured-meta-item">
                <dt class="featured-meta-label">{m.label}</dt>
                <dd class="featured-meta-value">{m.value}</dd>
              </div>
            ))}
          </dl>

          <p class="featured-link-row">
            <a href={`/projects/${featured.id}`} class="link-call">
              <span class="link-label">Read the case study</span>
              <span class="link-arrow" aria-hidden="true">
                &rarr;
              </span>
            </a>
          </p>
        </div>
      </section>
    )
  }

  <!-- ============================================================
       4. Manifesto moment — the one earned italic. Stands alone.
       ============================================================ -->
  <section class="moment" aria-labelledby="moment-h">
    <h2 id="moment-h" class="moment-line">
      <em>Judgement<br />is the work.</em>
    </h2>
    <p class="moment-attr">
      <Egg variant="fill" class="moment-egg" />
      &nbsp; From the North Star <span class="eyebrow-sep">/</span>
      <a href="/about" class="moment-link">read what we believe</a>
    </p>
  </section>

  <!-- ============================================================
       5. Recent work — compact editorial index
       ============================================================ -->
  {
    allProjects.length > 0 && (
      <section class="index" aria-labelledby="index-h">
        <header class="index-header">
          <p class="eyebrow">More work</p>
          <h2 id="index-h" class="section-statement">
            Recent projects.
          </h2>
        </header>

        <ol class="index-list" role="list">
          {allProjects.map((p, i) => (
            <li class="index-row">
              <a href={`/projects/${p.id}`} class="index-link">
                <span class="index-num">{String(i + 2).padStart(2, "0")}</span>
                <span class="index-title">{p.data.title}</span>
                <span class="index-tagline">{p.data.tagline}</span>
                <span class="index-year">{new Date(p.data.date).getFullYear()}</span>
                <span class="index-mark" aria-hidden="true">
                  &rarr;
                </span>
              </a>
            </li>
          ))}
        </ol>

        <p class="index-link-row">
          <a href="/projects" class="link-call">
            <span class="link-label">All work</span>
            <span class="link-arrow" aria-hidden="true">
              &rarr;
            </span>
          </a>
        </p>
      </section>
    )
  }

  <!-- ============================================================
       6. Three questions — what working with us means. Judgment
       layer, depth after the index so a considering visitor finds
       it with enough attention to read.
       ============================================================ -->
  <section class="questions" aria-labelledby="questions-h">
    <header class="questions-header">
      <p class="eyebrow">What working with us means</p>
      <h2 id="questions-h" class="section-statement">Three questions we answer on every project.</h2>
      <p class="section-deck">
        We don&rsquo;t sell a process. We sell the judgment that goes into the work — the decisions that determine whether a
        product ages well or needs a rewrite in eighteen months. Below, the three we come back to.
      </p>
    </header>

    <ol class="qa-list" role="list">
      {
        services.map((s) => (
          <li class="qa">
            <p class="qa-num">{s.n}</p>
            <h3 class="qa-q">{s.q}</h3>
            <p class="qa-a">{s.a}</p>
          </li>
        ))
      }
    </ol>

    <p class="questions-link-row">
      <a href="/services" class="link-call">
        <span class="link-label">How we actually deliver</span>
        <span class="link-arrow" aria-hidden="true">&rarr;</span>
      </a>
    </p>
  </section>

  <!-- ============================================================
       7. Numbers — single compact row. Quiet close before footer.
       ============================================================ -->
  <section class="numbers" aria-label="Studio in numbers">
    <dl class="numbers-row">
      {
        numbers.map((n) => (
          <div class="numbers-item">
            <dt class="numbers-label">{n.label}</dt>
            <dd class="numbers-value">{n.value}</dd>
          </div>
        ))
      }
    </dl>
  </section>
</BaseLayout>

<style>
  /* ============================================================
     Page rhythm
     ============================================================ */

  section {
    padding-inline: var(--gutter);
    padding-block: clamp(5rem, 10vw, 10rem);
  }

  /* ============================================================
     1. Hero
     ============================================================ */

  .hero {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-block: clamp(5rem, 12vw, 12rem);
  }

  .hero-statement {
    font-family: var(--font-display);
    font-weight: 200;
    font-size: var(--text-display-1);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tighter);
    margin: 0;
    max-width: 18ch;
    color: var(--color-ink);
  }

  .hero-deck {
    margin-top: 3rem;
    font-size: var(--text-xl);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
    max-width: var(--max-width-prose);
  }

  /* ============================================================
     2. Proof — layout only; pattern styles are global
     ============================================================ */

  .proof {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  /* ============================================================
     3. Featured project — eyebrow + statement + image +
     (prose | meta) + voice + link, all one section.
     ============================================================ */

  .featured-inner {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .featured-statement {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-4xl);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 clamp(2rem, 4vw, 3rem);
    max-width: 22ch;
    color: var(--color-ink);
  }

  /* Prose flows directly from the statement — tight coupling */

  .featured-prose {
    max-width: 52ch;
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .featured-prose p {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    margin-block: 0 1.25em;
  }

  .featured-prose p:last-child {
    margin-bottom: 0;
  }

  .featured-prose em {
    font-style: italic;
    color: var(--color-ink);
  }

  /* Image comes after the story — proof, not decoration */

  .featured-figure {
    margin: 0 0 clamp(2.5rem, 5vw, 4rem);
  }

  .featured-image {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border-radius: var(--radius-image);
    background: var(--color-paper-alt);
  }

  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--duration-slowest) var(--ease-editorial);
  }

  .featured-image:hover img {
    transform: scale(1.015);
  }

  .featured-link-row {
    margin: 0;
  }

  @media (max-width: 880px) {
    .featured-statement {
      font-size: var(--text-3xl);
    }
  }

  /* 4. Manifesto moment — pattern styles are global */

  /* ============================================================
     5. Recent work index
     ============================================================ */

  /* Index — layout only; pattern styles are global */

  .index {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .index-header {
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  /* ============================================================
     6. Numbers
     ============================================================ */

  /* Numbers — layout only; pattern styles are global */

  .numbers {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-block: clamp(2rem, 4vw, 3rem);
  }

  /* ============================================================
     7. Three questions (close of page)
     ============================================================ */

  /* Questions — layout only; QA pattern styles are global */

  .questions {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .questions-header {
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .questions-link-row {
    margin-top: 3rem;
  }
</style>
