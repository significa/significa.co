---
import { ClientRouter } from "astro:transitions";
import SEO from "@/components/seo.astro";
import Header from "@/components/header.astro";
import Footer from "@/components/footer.astro";
import { organizationJsonLd } from "@/lib/seo";
import "@/styles/global.css";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  type?: "website" | "article";
  publishedAt?: Date;
  structuredData?: object | object[];
}

const { title, description, ogImage, type, publishedAt, structuredData } = Astro.props;

// Include Organization schema on all pages, plus any custom schemas
const allSchemas = structuredData
  ? [organizationJsonLd(), ...(Array.isArray(structuredData) ? structuredData : [structuredData])]
  : organizationJsonLd();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO title={title} description={description} ogImage={ogImage} type={type} publishedAt={publishedAt} jsonLd={allSchemas} />
    <ClientRouter />
    <script>
      // Always scroll to top on hard refresh and on every view transition
      window.history.scrollRestoration = "manual";
      document.addEventListener("astro:after-swap", () => window.scrollTo(0, 0));
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
