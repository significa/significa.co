---
import BaseLayout from "@/layouts/base.astro";
import { getProjects } from "@/lib/collections";
import { getCollection } from "astro:content";
import { cdnUrl } from "@/lib/cdn";
import ProjectFilters from "@/components/ui/project-filters";
import "@/components/ui/project-filters.css";

const projects = await getProjects();
const allAwards = await getCollection("awards");

// Group awards by project
const awardsByProject = new Map<string, Array<{ award: string; year: number; url?: string }>>();
for (const award of allAwards) {
  const projectId = award.data.project.id;
  if (!awardsByProject.has(projectId)) {
    awardsByProject.set(projectId, []);
  }
  awardsByProject.get(projectId)!.push({
    award: award.data.award,
    year: award.data.year,
    url: award.data.url,
  });
}

// Prepare data for the client component
const projectsData = projects.map((project) => ({
  id: project.id,
  title: project.data.title,
  tagline: project.data.tagline,
  thumbnail: project.data.thumbnail ? cdnUrl(project.data.thumbnail, { width: 800, quality: 85 }) : undefined,
  industry: project.data.industry || [],
  deliverable: project.data.deliverable || [],
  awards: awardsByProject.get(project.id) || [],
}));

// Extract unique industries and deliverables
const industries = Array.from(new Set(projects.flatMap((p) => p.data.industry || []))).sort();

const deliverables = Array.from(new Set(projects.flatMap((p) => p.data.deliverable || []))).sort();
---

<BaseLayout title="Projects — Significa" description="Selected work from Significa's portfolio.">
  <div class="page">
    <header class="page-header">
      <h1>Projects.</h1>
    </header>

    <ProjectFilters projects={projectsData} industries={industries} deliverables={deliverables} client:load />

    <!-- Fallback for no JavaScript -->
    <noscript>
      <div class="projects-grid">
        {
          projects.map((project) => {
            const projectAwards = awardsByProject.get(project.id) || [];
            const thumbnailUrl = project.data.thumbnail ? cdnUrl(project.data.thumbnail, { width: 800, quality: 85 }) : null;

            return (
              <article class="project-card">
                <a href={`/projects/${project.id}`} class="project-link">
                  {thumbnailUrl && (
                    <div class="project-thumbnail">
                      <img src={thumbnailUrl} alt={project.data.title} loading="lazy" decoding="async" />
                    </div>
                  )}

                  <div class="project-info">
                    <h2 class="project-title">{project.data.title}</h2>
                    {project.data.tagline && <p class="project-tagline">{project.data.tagline}</p>}

                    {projectAwards.length > 0 && (
                      <ul class="awards-list" role="list">
                        {projectAwards.slice(0, 5).map((award) => (
                          <li class="award-badge">
                            <span class="award-name">{award.award}</span>
                          </li>
                        ))}
                      </ul>
                    )}

                    <span class="view-project">View project →</span>
                  </div>
                </a>
              </article>
            );
          })
        }
      </div>
    </noscript>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--gutter);
    padding-block: 4rem 6rem;
  }

  .page-header {
    margin-block-end: 3rem;
  }

  .page-header h1 {
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
  }

  /* Noscript fallback styles */
  noscript .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 400px), 1fr));
    gap: 3rem 2rem;
  }

  noscript .project-card {
    display: flex;
    flex-direction: column;
  }

  noscript .project-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: var(--color-text);
  }

  noscript .project-thumbnail {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    background: var(--color-surface-alt);
    border-radius: 12px;
    overflow: hidden;
    margin-block-end: 1.25rem;
  }

  noscript .project-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  noscript .project-info {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  noscript .project-title {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    margin: 0;
  }

  noscript .project-tagline {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin: 0;
  }

  noscript .awards-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
  }

  noscript .award-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: var(--text-xs);
    padding: 0.375rem 0.75rem;
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: 6px;
  }

  noscript .award-name {
    font-weight: var(--weight-medium);
  }

  noscript .view-project {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-primary);
    margin-top: auto;
    padding-top: 0.5rem;
  }

  @media (max-width: 768px) {
    .page {
      padding-block: 3rem 4rem;
    }

    .page-header h1 {
      font-size: var(--text-2xl);
    }

    noscript .projects-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    noscript .project-title {
      font-size: var(--text-lg);
    }

    noscript .project-tagline {
      font-size: var(--text-sm);
    }
  }
</style>
