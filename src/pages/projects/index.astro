---
import Base from "@/layouts/base.astro";
import { getPublishedProjects } from "@/lib/collections";

const projects = await getPublishedProjects();
---

<Base title="Projects" description="Selected work from Significa's portfolio.">
  <section>
    <h1>Projects</h1>
    {
      projects.length === 0 ? (
        <p>No projects yet.</p>
      ) : (
        <ul>
          {projects.map((project) => (
            <li>
              <a href={`/projects/${project.id}`}>
                <h2>{project.data.title}</h2>
                {project.data.tagline && <p>{project.data.tagline}</p>}
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</Base>
