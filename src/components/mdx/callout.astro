---
import { contentError } from "@/lib/content-errors";

interface Props {
  title: string;
  href?: string;
  cta?: string;
}

const { title, href, cta } = Astro.props;

if (!title) {
  contentError("Callout", Astro.url.pathname, "Callout requires a title prop");
}

if (href && !cta) {
  contentError("Callout", Astro.url.pathname, 'Callout with href requires a cta prop (e.g. cta="Learn more")');
}

const isExternal = href?.startsWith("http://") || href?.startsWith("https://");
---

<aside class="callout">
  <span class="callout-title">{title}</span>
  <div class="callout-body">
    <slot />
  </div>
  {
    href && cta && (
      <a href={href} class="callout-cta" {...(isExternal ? { target: "_blank", rel: "noopener noreferrer" } : {})}>
        {cta} →
      </a>
    )
  }
</aside>

<style>
  .callout {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 2rem 0;
    padding: 1.5rem;
    background: var(--color-paper-alt);
    border-radius: var(--radius-image);
  }

  .callout-title {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-normal);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
  }

  .callout-body {
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-ink);
  }

  .callout-body :global(p) {
    margin: 0;
  }

  .callout-body :global(ul),
  .callout-body :global(ol) {
    margin: 0.75rem 0 0;
    padding-inline-start: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1.25rem;
  }

  .callout-body :global(li) {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-ink);
    margin: 0;
  }

  .callout-body :global(strong) {
    font-weight: var(--weight-medium);
  }

  .callout-cta {
    align-self: flex-start;
    margin-top: 0.5rem;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-ink);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .callout-cta:hover {
    color: var(--color-accent);
  }
</style>
