---
import { cdnUrl, cdnSrcset, DEFAULT_QUALITY } from "../../lib/cdn";
import { contentError } from "../../lib/content-errors";

interface Props {
  /** Asset path or full URL. Relative paths get the CDN hostname prepended. */
  src: string;
  /** Accessible alt text (required) */
  alt: string;
  /** Intrinsic image width in pixels (prevents CLS) */
  width: number;
  /** Intrinsic image height in pixels (prevents CLS) */
  height: number;
  /** Optional figure caption */
  caption?: string;
  /** Set true for above-the-fold / LCP images */
  eager?: boolean;
  /** Responsive sizes attribute */
  sizes?: string;
  /** Bunny Optimizer quality (0-100) */
  quality?: number;
}

const {
  src,
  alt,
  width,
  height,
  caption,
  eager = false,
  sizes = "100vw",
  quality = DEFAULT_QUALITY,
} = Astro.props;

if (!src)
  contentError("MediaImage", Astro.url.pathname, "Missing required prop: src");
if (!alt)
  contentError("MediaImage", Astro.url.pathname, "Missing required prop: alt");
if (!width)
  contentError(
    "MediaImage",
    Astro.url.pathname,
    "Missing required prop: width",
  );
if (!height)
  contentError(
    "MediaImage",
    Astro.url.pathname,
    "Missing required prop: height",
  );

const imgSrc = cdnUrl(src, { width: 960, quality });
const srcset = cdnSrcset(src, { quality });
// Only set sizes when we have a srcset
const imgSizes = srcset ? sizes : undefined;
---

{
  caption ? (
    <figure>
      <img
        src={imgSrc}
        srcset={srcset}
        sizes={imgSizes}
        alt={alt}
        width={width}
        height={height}
        loading={eager ? "eager" : "lazy"}
        fetchpriority={eager ? "high" : "auto"}
        decoding={eager ? "sync" : "async"}
      />
      <figcaption>{caption}</figcaption>
    </figure>
  ) : (
    <img
      src={imgSrc}
      srcset={srcset}
      sizes={sizes}
      alt={alt}
      width={width}
      height={height}
      loading={eager ? "eager" : "lazy"}
      fetchpriority={eager ? "high" : "auto"}
      decoding={eager ? "sync" : "async"}
    />
  )
}
