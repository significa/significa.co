---
/**
 * Header
 *
 * Editorial chrome. Wordmark left, mono nav right. Not sticky — let the
 * page breathe. The nav is short on purpose: four items, no CTA button.
 * The contact ask lives in /hello, not in the chrome.
 */

import Wordmark from "@/components/ui/wordmark.astro";
import Egg from "@/components/ui/egg.astro";

const navItems = [
  { label: "Work", href: "/projects" },
  { label: "About", href: "/about" },
  { label: "Journal", href: "/blog" },
  { label: "Hello", href: "/say-hello" },
];

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath.startsWith(href + "/");
}
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="header-brand" aria-label="Significa, home">
      <Wordmark class="header-wordmark" />
    </a>

    <nav class="header-nav" aria-label="Main navigation">
      <ul role="list">
        {
          navItems.map((item) => (
            <li>
              <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <button class="header-menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-menu" aria-label="Open menu">
      <span class="header-menu-bar" aria-hidden="true"></span>
      <span class="header-menu-bar" aria-hidden="true"></span>
    </button>
  </div>

  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav class="mobile-nav" aria-label="Mobile navigation">
      <ul role="list">
        {
          navItems.map((item) => (
            <li>
              <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
                <span class="mobile-nav-label">{item.label}</span>
                <Egg variant="fill" class="mobile-nav-mark" />
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  function initMobileMenu() {
    const toggle = document.querySelector<HTMLButtonElement>(".header-menu-toggle");
    const menu = document.getElementById("mobile-menu");
    const header = document.querySelector<HTMLElement>(".site-header");

    if (!toggle || !menu || !header) return;

    function open() {
      toggle!.setAttribute("aria-expanded", "true");
      toggle!.setAttribute("aria-label", "Close menu");
      menu!.setAttribute("aria-hidden", "false");
      header!.classList.add("is-menu-open");
      document.body.style.overflow = "hidden";
    }

    function close() {
      toggle!.setAttribute("aria-expanded", "false");
      toggle!.setAttribute("aria-label", "Open menu");
      menu!.setAttribute("aria-hidden", "true");
      header!.classList.remove("is-menu-open");
      document.body.style.overflow = "";
    }

    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      isOpen ? close() : open();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && toggle.getAttribute("aria-expanded") === "true") {
        close();
        toggle.focus();
      }
    });

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => close());
    });
  }

  initMobileMenu();
  document.addEventListener("astro:after-swap", initMobileMenu);
</script>

<style>
  /* ============================================================
     Header shell — editorial, not app-like. Not sticky.
     ============================================================ */
  .site-header {
    background-color: var(--color-paper);
  }

  .header-inner {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding: 1.75rem var(--gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .header-brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: var(--color-ink);
  }

  .header-wordmark {
    height: 1.5em;
  }

  /* ============================================================
     Nav — mono, uppercase, small. Active = ink. Inactive = muted.
     ============================================================ */
  .header-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 2rem;
  }

  .header-nav a {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .header-nav a:hover,
  .header-nav a[aria-current="page"] {
    color: var(--color-ink);
  }

  .header-nav a[aria-current="page"] {
    color: var(--color-accent);
  }

  /* ============================================================
     Mobile menu toggle — minimal, two-bar, animates to X
     ============================================================ */
  .header-menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.25rem;
    height: 2.25rem;
    padding: 0.5rem;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 110;
  }

  .header-menu-bar {
    display: block;
    width: 100%;
    height: 1.5px;
    background-color: var(--color-ink);
    transition: transform var(--duration-normal) var(--ease-out);
    transform-origin: center;
  }

  .is-menu-open .header-menu-bar:nth-child(1) {
    transform: translateY(3.25px) rotate(45deg);
  }

  .is-menu-open .header-menu-bar:nth-child(2) {
    transform: translateY(-3.25px) rotate(-45deg);
  }

  /* ============================================================
     Mobile menu — full screen, editorial, egg marks per item
     ============================================================ */
  .mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 100;
    background-color: var(--color-paper);
    padding: 6rem var(--gutter) 2rem;
    overflow-y: auto;
    opacity: 0;
    transition: opacity var(--duration-normal) var(--ease-out);
  }

  .is-menu-open .mobile-menu {
    opacity: 1;
  }

  .mobile-nav {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: calc(100vh - 8rem);
  }

  .mobile-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .mobile-nav a {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1em;
    padding: 0.65rem 0;
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 400;
    line-height: var(--leading-tight);
    color: var(--color-ink);
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .mobile-nav a:hover {
    color: var(--color-accent);
  }

  .mobile-nav a[aria-current="page"] {
    color: var(--color-accent);
    font-style: italic;
  }

  .mobile-nav-mark {
    color: var(--color-accent);
    height: 0.55em;
    opacity: 0;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .mobile-nav a:hover .mobile-nav-mark,
  .mobile-nav a[aria-current="page"] .mobile-nav-mark {
    opacity: 1;
  }

  /* ============================================================
     Responsive
     ============================================================ */
  @media (max-width: 720px) {
    .header-nav {
      display: none;
    }

    .header-menu-toggle {
      display: flex;
    }

    .mobile-menu[aria-hidden="false"] {
      display: block;
      opacity: 1;
    }
  }
</style>
