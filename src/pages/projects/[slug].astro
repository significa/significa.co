---
import { getEntry, render } from "astro:content";
import BaseLayout from "@/layouts/base.astro";
import { mdxComponents } from "@/components/mdx/components";
import { getProjects, getAwardsForProject } from "@/lib/collections";
import { cdnUrl } from "@/lib/cdn";
import { pageWithProjectJsonLd } from "@/lib/seo";

export async function getStaticPaths() {
  const projects = await getProjects();
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const showreelVideo = project.data.showreelVideo;
const showreelCover = project.data.showreelCover ?? project.data.heroImage;

const seo = project.data.seo;
const title = seo?.metaTitle ?? project.data.title;
const description = seo?.metaDescription ?? project.data.tagline ?? project.data.title;
const ogImage = seo?.ogImage ?? project.data.heroImage ?? project.data.thumbnail;

const [relatedProjects, projectAwards] = await Promise.all([
  project.data.relatedProjects?.length
    ? Promise.all(project.data.relatedProjects.map((ref) => getEntry(ref)))
    : Promise.resolve([]),
  getAwardsForProject(project.id),
]);

const structuredData = pageWithProjectJsonLd(
  {
    title: project.data.title,
    description: project.data.tagline ?? project.data.title,
    url: `https://significa.co/projects/${project.id}`,
    image: ogImage,
    datePublished: project.data.date,
    client: project.data.client,
    tags: project.data.tags,
    deliverable: project.data.deliverable,
    industry: project.data.industry,
    awards: projectAwards.map((a) => `${a.data.award} ${a.data.year}`),
  },
  [
    { name: "Home", url: "https://significa.co" },
    { name: "Projects", url: "https://significa.co/projects" },
    { name: project.data.title, url: `https://significa.co/projects/${project.id}` },
  ]
);

const formattedDate = project.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
});

function formatLabel(str: string): string {
  return str
    .split("-")
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(" ");
}
---

<BaseLayout title={title} description={description} ogImage={ogImage} structuredData={structuredData}>
  <article class="project">
    <!-- Hero -->
    <header class="project-hero">
      <div class="project-hero-text">
        <p class="project-eyebrow">Case study</p>
        <h1 class="project-title">{project.data.title}</h1>
        {project.data.tagline && <p class="project-tagline">{project.data.tagline}</p>}
      </div>

      {
        project.data.heroImage && !showreelVideo && (
          <div class="project-hero-image">
            <img
              src={cdnUrl(project.data.heroImage, { width: 1920, quality: 85 })}
              srcset={[
                `${cdnUrl(project.data.heroImage, { width: 960, quality: 85 })} 960w`,
                `${cdnUrl(project.data.heroImage, { width: 1280, quality: 85 })} 1280w`,
                `${cdnUrl(project.data.heroImage, { width: 1920, quality: 85 })} 1920w`,
              ].join(", ")}
              sizes="100vw"
              alt={project.data.altText ?? project.data.title}
              width="1920"
              height="1080"
              loading="eager"
              fetchpriority="high"
              decoding="sync"
            />
          </div>
        )
      }
    </header>

    <!-- Showreel -->
    {
      showreelVideo && (
        <section class="project-showreel">
          <div class="project-showreel-inner">
            <div class="project-showreel-media" data-showreel>
              <video src={showreelVideo} width="1920" height="1080" loop muted playsinline preload="none" data-showreel-video />
              {showreelCover && (
                <div class="showreel-cover" data-showreel-cover aria-hidden="true">
                  <img src={cdnUrl(showreelCover, { width: 1920, quality: 85 })} alt="" draggable="false" />
                </div>
              )}
              <button class="showreel-cursor" type="button" data-showreel-cursor aria-label="Play showreel video">
                <span class="showreel-cursor-icon" aria-hidden="true">
                  ▶
                </span>
              </button>
            </div>
          </div>
        </section>
      )
    }

    <!-- Metadata bar -->
    <div class="project-meta-bar">
      <dl class="project-meta-list">
        {
          project.data.client && (
            <div class="project-meta-item">
              <dt>Client</dt>
              <dd>{project.data.client}</dd>
            </div>
          )
        }
        <div class="project-meta-item">
          <dt>Year</dt>
          <dd>{formattedDate}</dd>
        </div>
        {
          project.data.industry && project.data.industry.length > 0 && (
            <div class="project-meta-item">
              <dt>Industry</dt>
              <dd>{project.data.industry.map(formatLabel).join(", ")}</dd>
            </div>
          )
        }
        {
          project.data.deliverable && project.data.deliverable.length > 0 && (
            <div class="project-meta-item">
              <dt>Deliverables</dt>
              <dd>{project.data.deliverable.map(formatLabel).join(", ")}</dd>
            </div>
          )
        }
        {
          project.data.tags && project.data.tags.length > 0 && (
            <div class="project-meta-item">
              <dt>Services</dt>
              <dd>
                <ul class="project-tags" role="list">
                  {project.data.tags.map((tag) => (
                    <li class="project-tag">{formatLabel(tag)}</li>
                  ))}
                </ul>
              </dd>
            </div>
          )
        }
      </dl>
    </div>

    <!-- MDX body -->
    <div class="project-content">
      <div class="project-content-inner">
        <Content components={mdxComponents} />
      </div>
    </div>

    <!-- Related projects -->
    {
      relatedProjects.length > 0 && (
        <aside class="related-projects">
          <div class="related-inner">
            <h2 class="related-heading">More work</h2>
            <ul class="related-list" role="list">
              {relatedProjects.map(
                (related) =>
                  related && (
                    <li>
                      <a href={`/projects/${related.id}`} class="related-card">
                        {related.data.thumbnail && (
                          <div class="related-card-image">
                            <img
                              src={cdnUrl(related.data.thumbnail, { width: 800, height: 450, quality: 80 })}
                              alt={related.data.title}
                              width="800"
                              height="450"
                              loading="lazy"
                              decoding="async"
                            />
                          </div>
                        )}
                        <div class="related-card-body">
                          <span class="related-card-title">{related.data.title}</span>
                          {related.data.tagline && <span class="related-card-tagline">{related.data.tagline}</span>}
                          <span class="related-card-cta">View case study →</span>
                        </div>
                      </a>
                    </li>
                  )
              )}
            </ul>
          </div>
        </aside>
      )
    }

    <!-- CTA -->
    <div class="project-cta">
      <div class="project-cta-inner">
        <p class="project-cta-label">Ready to build something?</p>
        <h2 class="project-cta-heading">We design and build digital products that matter.</h2>
        <a href="/say-hello" class="project-cta-button">Get a quote</a>
      </div>
    </div>
  </article>
</BaseLayout>

<!-- Showreel cursor-following button — vanilla JS, no island needed -->
<script>
  function initShowreel() {
    const section = document.querySelector<HTMLElement>("[data-showreel]");
    const cursor = document.querySelector<HTMLButtonElement>("[data-showreel-cursor]");
    const video = document.querySelector<HTMLVideoElement>("[data-showreel-video]");
    if (!section || !cursor || !video) return;

    let isPlaying = false;

    function positionAt(e: MouseEvent) {
      if (!cursor) return;
      const x = e.clientX - cursor.offsetWidth / 2;
      const y = e.clientY - cursor.offsetHeight / 2;
      cursor.style.translate = `${x}px ${y}px`;
    }

    function updateCursorIcon() {
      if (!cursor) return;
      const icon = cursor.querySelector(".showreel-cursor-icon");
      if (icon) {
        icon.textContent = isPlaying ? "❚❚" : "▶";
      }
    }

    const cover = document.querySelector<HTMLElement>("[data-showreel-cover]");

    function toggleVideo() {
      if (!video) return;
      if (isPlaying) {
        video.pause();
        isPlaying = false;
      } else {
        video.play();
        isPlaying = true;
        if (cover) cover.style.display = "none";
      }
      updateCursorIcon();
    }

    section.addEventListener("mouseenter", (e: MouseEvent) => {
      positionAt(e);
      cursor.style.opacity = "1";
      cursor.style.scale = "1";
    });

    section.addEventListener("mouseleave", () => {
      cursor.style.opacity = "0";
      cursor.style.scale = "0.5";
    });

    section.addEventListener("mousemove", (e: MouseEvent) => {
      positionAt(e);
    });

    section.addEventListener("click", toggleVideo);
    cursor.addEventListener("click", (e) => {
      e.stopPropagation();
      toggleVideo();
    });

    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    if (prefersReducedMotion.matches) {
      cursor.style.display = "none";
    }
    prefersReducedMotion.addEventListener("change", (e) => {
      cursor.style.display = e.matches ? "none" : "";
    });
  }

  initShowreel();
  document.addEventListener("astro:after-swap", initShowreel);
</script>

<style>
  /* ============================================================
     Showreel
     ============================================================ */
  .project-showreel {
    padding: 0 var(--gutter) 4rem;
  }

  .project-showreel-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .project-showreel-media {
    position: relative;
    border-radius: 0.5rem;
    overflow: hidden;
    cursor: none;
  }

  .project-showreel-media video {
    width: 100%;
    height: auto;
    display: block;
  }

  .project-showreel-media .showreel-cover {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .project-showreel-media .showreel-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .showreel-cursor {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 10;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--color-text);
    color: var(--color-surface);
    border: none;
    border-radius: 2rem;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    pointer-events: none;
    opacity: 0;
    scale: 0.5;
    transition:
      opacity var(--duration-fast) var(--ease-out),
      scale var(--duration-fast) cubic-bezier(0.34, 1.56, 0.64, 1);
    will-change: translate, scale;
    white-space: nowrap;
  }

  .showreel-cursor-icon {
    font-size: 0.625rem;
  }

  @media (hover: none) {
    .project-showreel-media {
      cursor: default;
    }

    .showreel-cursor {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%) !important;
      opacity: 1 !important;
      pointer-events: auto;
    }
  }

  /* ============================================================
     Hero
     ============================================================ */
  .project-hero {
    padding-block-start: 6rem;
  }

  .project-hero-text {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--gutter);
    padding-block-end: 3rem;
  }

  .project-eyebrow {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-block-end: 1rem;
  }

  .project-title {
    font-size: var(--text-4xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin-block-end: 1.25rem;
  }

  .project-tagline {
    font-size: var(--text-xl);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
    max-width: 42rem;
  }

  .project-hero-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-surface-alt);
  }

  .project-hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 768px) {
    .project-hero {
      padding-block-start: 4rem;
    }

    .project-title {
      font-size: var(--text-3xl);
    }

    .project-tagline {
      font-size: var(--text-lg);
    }
  }

  /* ============================================================
     Metadata bar
     ============================================================ */
  .project-meta-bar {
    border-block: 1px solid var(--color-border);
  }

  .project-meta-list {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--gutter);
    padding-block: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 2rem 3.5rem;
  }

  .project-meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .project-meta-item dt {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }

  .project-meta-item dd {
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    color: var(--color-text);
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    padding: 0;
  }

  .project-tag {
    display: inline-block;
    padding: 0.25rem 0.625rem;
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: 99px;
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  /* ============================================================
     MDX content
     ============================================================ */
  .project-content {
    padding-block: 5rem;
    padding-inline: var(--gutter);
  }

  .project-content-inner {
    max-width: var(--max-width-narrow);
    margin-inline: auto;
  }

  /* Prose typography */
  .project-content-inner :global(p) {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text);
    margin-block-end: 1.5rem;
  }

  .project-content-inner :global(h2) {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin-block-start: 3.5rem;
    margin-block-end: 1.25rem;
  }

  .project-content-inner :global(h3) {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin-block-start: 2.5rem;
    margin-block-end: 1rem;
  }

  .project-content-inner :global(h4) {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin-block-start: 2rem;
    margin-block-end: 0.75rem;
  }

  .project-content-inner :global(ul),
  .project-content-inner :global(ol) {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text);
    padding-inline-start: 1.5rem;
    margin-block-end: 1.5rem;
  }

  .project-content-inner :global(li) {
    margin-block-end: 0.5rem;
  }

  .project-content-inner :global(a) {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 0.15em;
    text-decoration-thickness: 1px;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .project-content-inner :global(a:hover) {
    opacity: 0.7;
  }

  .project-content-inner :global(strong) {
    font-weight: var(--weight-semibold);
  }

  .project-content-inner :global(em) {
    font-style: italic;
  }

  .project-content-inner :global(blockquote) {
    border-inline-start: 3px solid var(--color-border);
    padding-inline-start: 1.5rem;
    margin-block: 2.5rem;
    margin-inline: 0;
  }

  .project-content-inner :global(blockquote p) {
    font-size: var(--text-xl);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
    font-style: italic;
    margin-block-end: 0.75rem;
  }

  .project-content-inner :global(blockquote strong) {
    display: block;
    font-size: var(--text-base);
    font-style: normal;
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  .project-content-inner :global(hr) {
    border: none;
    border-block-start: 1px solid var(--color-border);
    margin-block: 3rem;
  }

  /* Awards list — rendered from MDX markdown under a "## Awards" heading */
  .project-content-inner :global(h2 + ul),
  .project-content-inner :global(h2 + ul li) {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .project-content-inner :global(h2 + ul) {
    border-block-start: 1px solid var(--color-border);
    margin-block-end: 1.5rem;
  }

  .project-content-inner :global(h2 + ul li) {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    padding-block: 0.625rem;
    border-block-end: 1px solid var(--color-border);
    color: var(--color-text);
    margin: 0;
  }

  .project-content-inner :global(h2 + ul li strong) {
    font-weight: var(--weight-medium);
    flex-shrink: 0;
  }

  .project-content-inner :global(h2 + ul li::after) {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--color-border);
    align-self: center;
    min-width: 1rem;
  }

  /* ============================================================
     Media layout — data-layout on figure / div / img
     full   = full viewport width (default)
     wide   = --max-width (1152px), centered
     medium = prose column width, no breakout
     small  = half prose column, centered
     ============================================================ */

  /* Consistent vertical spacing around all media — above and below, always */
  .project-content-inner :global(figure),
  .project-content-inner :global(div:has(> video)),
  .project-content-inner :global(img[data-layout]) {
    margin-block: 3rem;
  }

  /* Images and videos inside wrappers always fill their wrapper */
  .project-content-inner :global(figure img),
  .project-content-inner :global(figure video),
  .project-content-inner :global(div:has(> video) video),
  .project-content-inner :global(img[data-layout]) {
    width: 100%;
    height: auto;
    display: block;
  }

  /* full — break out to full viewport width (default for all media) */
  .project-content-inner :global([data-layout="full"]),
  .project-content-inner :global(figure:not([data-layout])),
  .project-content-inner :global(img:not([data-layout]):not(figure img)),
  .project-content-inner :global(div:has(> video):not([data-layout])),
  .project-content-inner :global(.metrics),
  .project-content-inner :global(.cross-sell) {
    width: 100vw;
    max-width: 100vw;
    margin-inline-start: calc(50% - 50vw);
  }

  /* wide — centered at --max-width, still breaks out of prose column */
  .project-content-inner :global([data-layout="wide"]) {
    width: min(var(--max-width), 100vw);
    max-width: 100vw;
    margin-inline-start: calc(50% - min(var(--max-width), 100vw) / 2);
  }

  /* medium — stays within the prose column, no breakout */
  .project-content-inner :global([data-layout="medium"]) {
    width: 100%;
  }

  /* small — half the prose column width, centered */
  .project-content-inner :global([data-layout="small"]) {
    width: 50%;
    margin-inline: auto;
    display: block;
  }

  .project-content-inner :global(figcaption) {
    max-width: var(--max-width-narrow);
    margin-inline: auto;
    padding-inline: var(--gutter);
    padding-block-start: 0.75rem;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-align: center;
  }

  .project-content-inner :global(.metrics) {
    padding-inline: var(--gutter);
    padding-block: 3rem;
    background: var(--color-surface-alt);
    border-block: 1px solid var(--color-border);
    margin-block: 2.5rem;
  }

  .project-content-inner :global(.metrics > *) {
    max-width: var(--max-width);
    margin-inline: auto;
  }

  .project-content-inner :global(.cross-sell) {
    padding-inline: var(--gutter);
    margin-block: 2.5rem;
  }

  .project-content-inner :global(.cross-sell > *) {
    max-width: var(--max-width);
    margin-inline: auto;
  }

  @media (max-width: 768px) {
    .project-content {
      padding-block: 3rem;
    }

    .project-content-inner :global(p),
    .project-content-inner :global(ul),
    .project-content-inner :global(ol) {
      font-size: var(--text-base);
    }

    .project-content-inner :global(blockquote p) {
      font-size: var(--text-lg);
    }
  }

  /* ============================================================
     Related projects
     ============================================================ */
  .related-projects {
    border-block-start: 1px solid var(--color-border);
    padding-block: 5rem;
    padding-inline: var(--gutter);
    background: var(--color-surface-alt);
  }

  .related-inner {
    max-width: var(--max-width);
    margin-inline: auto;
  }

  .related-heading {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    margin-block-end: 2.5rem;
  }

  .related-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 28rem), 1fr));
    gap: 1.5rem;
    padding: 0;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow: hidden;
    background: var(--color-surface);
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .related-card:hover {
    border-color: var(--color-text);
  }

  .related-card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-surface-alt);
  }

  .related-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .related-card:hover .related-card-image img {
    transform: scale(1.04);
  }

  .related-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    flex: 1;
  }

  .related-card-title {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
