---
interface Props {
  as?: "h1" | "h2" | "h3";
  id?: string;
  class?: string;
}

const { as: Tag = "h2", id, class: className } = Astro.props;
---

<Tag id={id} class:list={["section-statement", "type-heading-lg", className]}>
  <slot />
</Tag>

<style>
  .section-statement {
    margin: 0;
    max-width: 28ch;
  }
</style>
