---
import { getCollection, getEntry, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import MediaImage from "../../components/mdx/MediaImage.astro";
import MediaVideo from "../../components/mdx/MediaVideo.astro";
import ComparisonBlock from "../../components/mdx/ComparisonBlock.astro";
import Metrics from "../../components/mdx/Metrics.astro";
import ProjectCrossSell from "../../components/mdx/ProjectCrossSell.astro";
import { articleJsonLd } from "../../lib/seo";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const mdxComponents = {
  MediaImage,
  MediaVideo,
  ComparisonBlock,
  Metrics,
  ProjectCrossSell,
};

const seo = post.data.seo;
const title = seo?.metaTitle ?? post.data.title;
const description = seo?.metaDescription ?? `${post.data.title} — Significa Blog`;

const relatedProjects = post.data.relatedProjects?.length
  ? await Promise.all(
      post.data.relatedProjects.map((ref) => getEntry(ref))
    )
  : [];
---

<Base
  title={title}
  description={description}
  ogImage={seo?.ogImage}
  type="article"
  publishedAt={post.data.date}
>
  <article>
    <header>
      <h1>{post.data.title}</h1>
      <time datetime={post.data.date.toISOString()}>
        {post.data.date.toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
        })}
      </time>
      {post.data.author && <p>By {post.data.author}</p>}
    </header>
    <Content components={mdxComponents} />
    {relatedProjects.length > 0 && (
      <aside>
        <h2>Related Projects</h2>
        <ul>
          {relatedProjects.map((project) => project && (
            <li>
              <a href={`/projects/${project.id}`}>{project.data.title}</a>
            </li>
          ))}
        </ul>
      </aside>
    )}
  </article>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(
      articleJsonLd({
        title: post.data.title,
        description,
        url: new URL(`/blog/${post.id}`, Astro.site).href,
        publishedAt: post.data.date,
        author: post.data.author,
        image: seo?.ogImage,
      })
    )}
  />
</Base>
