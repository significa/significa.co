---
import BaseLayout from "@/layouts/base.astro";
import Eyebrow from "@/components/ui/eyebrow.astro";
import LinkCall from "@/components/ui/link-call.astro";
---

<BaseLayout title="Page not found — Significa" description="The page you were looking for has moved or never existed.">
  <section class="lost" aria-labelledby="lost-h">
    <Eyebrow>Page not found</Eyebrow>
    <h1 id="lost-h" class="lost-heading type-display-2">Wrong turn,<br />same studio.</h1>
    <p class="lost-body">The page you were looking for has moved or never existed. The work is still here.</p>
    <nav class="lost-nav" aria-label="Navigation">
      <LinkCall href="/">Back to the homepage</LinkCall>
      <LinkCall href="/work">See our work</LinkCall>
    </nav>
  </section>
</BaseLayout>

<style>
  .lost {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-inline: var(--gutter);
    padding-block: clamp(8rem, 18vw, 18rem) clamp(6rem, 12vw, 12rem);
  }

  .lost-heading {
    font-weight: 300;
    margin: 0;
  }

  .lost-body {
    margin-block: 2.5rem 0;
    font-size: var(--text-xl);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
    max-width: var(--max-width-prose);
  }

  .lost-nav {
    margin-top: 3rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 3rem;
  }
</style>
