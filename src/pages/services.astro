---
/**
 * /services — How we work
 *
 * Differentiated from homepage. Homepage says WHY (rigour + beauty).
 * This page says HOW (one team, the working relationship, when
 * we're the wrong choice, and what disciplines we cover).
 *
 *   1. Position statement — one team, breadth in the deck.
 *   2. Three questions — with edge, including wrong-for-you.
 *   3. Disciplines — links to service sub-pages.
 *   4. Client voice.
 *   5. Selected work — editorial index.
 *   6. Numbers + close.
 */

import BaseLayout from "@/layouts/base.astro";
import Eyebrow from "@/components/ui/eyebrow.astro";
import SectionHeader from "@/components/ui/section-header.astro";
import LinkCall from "@/components/ui/link-call.astro";
import NumbersRow from "@/components/ui/numbers-row.astro";
import QaList from "@/components/ui/qa-list.astro";
import IndexList from "@/components/ui/index-list.astro";
import FeaturedVoice from "@/components/ui/featured-voice.astro";
import { getCollection } from "astro:content";
import { getProjects, getTestimonials } from "@/lib/collections";

const projects = (await getProjects()).slice(0, 5);
const testimonials = await getTestimonials();
const bestTestimonial = testimonials[1] ?? testimonials[0];
const services = await getCollection("services");

const questions = [
  {
    n: "01",
    q: "What if we disagree with the brief?",
    a: "It happens on most projects. The original spec usually contains assumptions that don't survive contact with real users or real constraints. We say so early, with reasoning, and have the honest conversation. The version of the project where we agree with everything is the version that fails.",
  },
  {
    n: "02",
    q: "When are you the wrong choice?",
    a: "When you need a team that executes a spec without questioning it. When the timeline doesn't allow for thinking. When the decision-maker isn't in the room and everything routes through three layers of approval. We can work within constraints, but we can't work without trust or access to the people who make the calls.",
  },
  {
    n: "03",
    q: "What happens after launch?",
    a: "We measure. We stay on call. We fix what needs fixing and improve what's underperforming. The relationship doesn't end at handover, because products don't stop needing judgement at handover. Most of our clients come back. Three in four engage us again.",
  },
];

const numbers = [
  { label: "Client NPS", value: "87" },
  { label: "Repeat engagements", value: "3 in 4" },
  { label: "Outsourced work", value: "0%" },
  { label: "In business since", value: "2015" },
];
---

<BaseLayout
  title="How we work — Significa"
  description="One team from first conversation to well after launch. Strategy, design, and engineering working in tight loops. Platforms, commerce, websites, design systems."
>
  <!-- ============================================================
       1. Position statement — breadth folded into the deck
       ============================================================ -->
  <section class="hero" aria-labelledby="hero-h">
    <Eyebrow>How we work</Eyebrow>
    <h1 id="hero-h" class="hero-statement type-display-2">One team from first conversation to well after launch.</h1>
    <p class="hero-deck">
      Strategy, design, and engineering working in tight loops. We make platforms, mobile apps, e-commerce, design systems, and
      websites for companies that want complexity met with care. No handoffs between departments, because there are no
      departments.
    </p>
  </section>

  <!-- ============================================================
       2. Three questions — with edge
       ============================================================ -->
  <section class="questions" aria-labelledby="questions-h">
    <header class="questions-header">
      <Eyebrow>What you should know</Eyebrow>
      <SectionHeader id="questions-h">Three questions worth asking before you hire anyone.</SectionHeader>
    </header>

    <QaList items={questions} />
  </section>

  <!-- ============================================================
       3. Disciplines — links to sub-pages
       ============================================================ -->
  <section class="disciplines" aria-labelledby="disciplines-h">
    <Eyebrow id="disciplines-h">What we do</Eyebrow>
    <ul class="discipline-list" role="list">
      {
        services.map((s) => (
          <li class="discipline">
            <a href={`/services/${s.id}`} class="discipline-link">
              <h2 class="discipline-title">{s.data.title}</h2>
              <p class="discipline-tagline">{s.data.tagline}</p>
              <span class="discipline-arrow" aria-hidden="true">
                &rarr;
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- ============================================================
       4. Client voice
       ============================================================ -->
  {
    bestTestimonial && (
      <section class="voice" aria-label="Client testimonial">
        <FeaturedVoice
          quote={bestTestimonial.data.quote}
          author={bestTestimonial.data.author}
          role={`${bestTestimonial.data.role} at ${bestTestimonial.data.company}`}
        />
      </section>
    )
  }

  <!-- ============================================================
       5. Selected work — editorial index
       ============================================================ -->
  {
    projects.length > 0 && (
      <section class="work" aria-labelledby="work-h">
        <header class="work-header">
          <Eyebrow>Selected work</Eyebrow>
          <SectionHeader id="work-h">Proof, not promises.</SectionHeader>
        </header>

        <IndexList
          items={projects.map((p, i) => ({
            href: `/projects/${p.id}`,
            title: p.data.title,
            tagline: p.data.tagline ?? "",
            date: String(new Date(p.data.date).getFullYear()),
            num: String(i + 1).padStart(2, "0"),
          }))}
        />

        <p class="work-link-row">
          <LinkCall href="/projects">All work</LinkCall>
        </p>
      </section>
    )
  }

  <!-- ============================================================
       6. Numbers + close
       ============================================================ -->
  <section class="numbers" aria-label="Studio in numbers">
    <NumbersRow items={numbers} />

    <p class="close-link">
      <LinkCall href="/say-hello">Start a conversation</LinkCall>
    </p>
  </section>
</BaseLayout>

<style>
  /* ============================================================
     Page rhythm
     ============================================================ */

  section {
    padding-inline: var(--gutter);
    padding-block: clamp(5rem, 10vw, 10rem);
  }

  /* ============================================================
     1. Hero
     ============================================================ */

  .hero {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-block: clamp(4rem, 8vw, 7rem) clamp(3rem, 6vw, 5rem);
  }

  .hero-statement {
    margin: 0;
    max-width: 22ch;
  }

  .hero-deck {
    margin-top: 2.5rem;
    font-size: var(--text-xl);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
    max-width: var(--max-width-prose);
  }

  /* ============================================================
     2. Questions
     ============================================================ */

  .questions {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .questions-header {
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  /* ============================================================
     3. Disciplines
     ============================================================ */

  .disciplines {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .discipline-list {
    list-style: none;
    margin: clamp(2rem, 4vw, 3rem) 0 0;
    padding: 0;
  }

  .discipline {
    border-top: 1px solid var(--color-rule);
  }

  .discipline:last-child {
    border-bottom: 1px solid var(--color-rule);
  }

  .discipline-link {
    display: grid;
    grid-template-columns: minmax(10rem, 1fr) 2fr auto;
    align-items: baseline;
    gap: 2rem;
    padding-block: 2rem;
    color: var(--color-ink);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .discipline-link:hover {
    color: var(--color-accent);
  }

  .discipline-title {
    font-weight: var(--weight-medium);
    font-size: var(--text-xl);
    line-height: var(--leading-snug);
    margin: 0;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .discipline-tagline {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    line-height: var(--leading-normal);
    margin: 0;
    max-width: 44ch;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .discipline-link:hover .discipline-tagline {
    color: var(--color-ink);
  }

  .discipline-link .discipline-arrow {
    color: var(--color-accent);
    opacity: 0;
    transform: translateX(-0.4em);
    transition:
      opacity var(--duration-normal) var(--ease-editorial),
      transform var(--duration-normal) var(--ease-editorial);
  }

  .discipline-link:hover .link-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  @media (max-width: 720px) {
    .discipline-link {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }

    .discipline-link .discipline-arrow {
      display: none;
    }
  }

  /* ============================================================
     4. Client voice
     ============================================================ */

  .voice {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  /* ============================================================
     5. Selected work
     ============================================================ */

  .work {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .work-header {
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .work-link-row {
    margin-top: 3rem;
  }

  /* ============================================================
     6. Numbers + close
     ============================================================ */

  .numbers {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .close-link {
    margin-top: clamp(3rem, 6vw, 5rem);
  }
</style>
