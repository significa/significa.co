---
import BaseLayout from "@/layouts/base.astro";
import { getClients, getProjects, getAwards, getTestimonials, getPosts, getPlayground } from "@/lib/collections";
import { cdnUrl } from "@/lib/cdn";

const featuredProjects = (await getProjects()).slice(0, 3);
const awards = await getAwards();
const testimonials = await getTestimonials();
const recentPost = (await getPosts())[0];
const recentPlayground = (await getPlayground())[0];

const pillars = [
  {
    id: "think",
    label: "Think.",
    description:
      "We ask the right questions to help you iterate, uncover critical challenges, and define a clear path forward. From product strategy to UX audits and technical planning, we work with you to map out what to build and why.",
    deliverables: ["Product Definition", "Migrations", "Operations"],
    href: "/services/think",
  },
  {
    id: "design",
    label: "Design.",
    description:
      "We transform insights into impact through design. From user interface design to brands and Design Systems, our work is built to function beautifully, scale purposefully, and guide users intentionally. Design decisions are business decisions, so our developers are involved early to align UI with technical possibilities.",
    deliverables: ["UI / UX Design", "Design Systems", "Branding"],
    href: "/services/design",
  },
  {
    id: "develop",
    label: "Develop.",
    description:
      "We combine critical thinking, agility, and curiosity to write code that goes beyond functionality, turning solid products into seamless, memorable experiences. Our custom development services follow two principles: clarity and speed.",
    deliverables: ["IT Architecture", "Headless", "Dev Ops", "Shopify"],
    href: "/services/develop",
  },
  {
    id: "launch",
    label: "Launch.",
    description:
      "We launch with confidence. We build software that's robust, easy to maintain, and ready to grow. Frameworks are set up for efficiency and consistency, while clear documentation and onboarding ensure smooth handover to your team and partners.",
    deliverables: ["Quality Assurance", "Product Governance", "On-call Maintenance"],
    href: "/services/launch",
  },
  {
    id: "scale",
    label: "Scale.",
    description:
      "Growth is a continuous process. We track performance, monitor user behaviour, and surface friction points to help you evolve based on evidence, not assumptions. From new features to technical improvements, we keep your product moving forward with momentum.",
    deliverables: ["Performance Insights", "Optimisations", "Retainers"],
    href: "/services/scale",
  },
] as const;

const productTypes = [
  {
    label: "E-commerce",
    description: "Shopify online shops to sell and manage all your products.",
    href: "/services/e-commerce",
  },
  { label: "Websites", description: "Corporate or marketing websites.", href: "/services/websites" },
  { label: "Desktop Apps", description: "Apps that run natively on computers." },
  { label: "Web Apps", description: "Apps that run on web browsers." },
  { label: "Watch & TV Apps", description: "Apps that run natively on smart watches and TVs." },
  { label: "Mobile Apps", description: "Apps that run natively on Android and iOS phones." },
];

const industries = [
  "Health & Wellness",
  "Sports & Entertainment",
  "Finance",
  "Hospitality & Real Estate",
  "HR & Comms",
  "Commerce",
  "Sustainability",
  "Education",
  "Mobility",
  "Culture & Community",
];
---

<BaseLayout
  title="What we do"
  description="Custom design and development services built to grow your business. Strategy-driven, design-led, code-savvy, from product strategy to launch and beyond."
>
  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="hero">
    <div class="hero-inner">
      <h1>
        Custom <strong>design and development&nbsp;services</strong> built to grow your business.
      </h1>
      <p class="hero-sub">Strategy-driven. Design-led. Code-savvy.</p>
      <p class="hero-description">
        We combine strategy, design and engineering to build bespoke digital products that are intuitive, user-centred, and
        built to last. Our process is collaborative, rooted in trust, curiosity and transparency.
      </p>
    </div>
  </section>

  <!-- ============================================================
       SERVICES INTRO
       ============================================================ -->
  <section class="services-intro">
    <div class="services-intro-inner">
      <p class="eyebrow">Our Design and Development services</p>
      <div class="services-intro-layout">
        <h2 class="services-intro-heading">Your go-to partner to think, design, develop and scale.</h2>
        <div class="services-intro-aside">
          <p>
            Backed by 10+ years of experience, 20+ international awards and a team of 30+ experts, with 100+ projects delivered,
            we are your go-to partner to build digital experiences that are intuitive, user-centred, and built to drive lasting
            growth.
          </p>
          <a href="/say-hello" class="cta-button">Get a quote</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SERVICE PILLARS
       ============================================================ -->
  <section class="pillars">
    <div class="pillars-inner">
      {
        pillars.map((pillar, i) => (
          <article class="pillar" id={pillar.id}>
            <div class="pillar-header">
              <span class="pillar-number" aria-hidden="true">
                0{i + 1}
              </span>
              <h2 class="pillar-title">{pillar.label}</h2>
            </div>
            <div class="pillar-body">
              <p class="pillar-description">{pillar.description}</p>
              <ul class="pillar-deliverables">
                {pillar.deliverables.map((d) => (
                  <li>{d}</li>
                ))}
              </ul>
              <a href={pillar.href} class="pillar-link">
                Learn more →
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- ============================================================
       TESTIMONIAL
       ============================================================ -->
  {
    testimonials[0] && (
      <section class="testimonial-section">
        <div class="testimonial-section-inner">
          <blockquote class="testimonial">
            <p class="testimonial-quote">&ldquo;{testimonials[0].data.quote}&rdquo;</p>
            <footer class="testimonial-author">
              <cite>
                <strong>{testimonials[0].data.author}</strong>
                <span>
                  {testimonials[0].data.role} at {testimonials[0].data.company}
                </span>
              </cite>
            </footer>
          </blockquote>
        </div>
      </section>
    )
  }

  <!-- ============================================================
       HOW WE WORK
       ============================================================ -->
  <section class="how-we-work">
    <div class="how-we-work-inner">
      <p class="eyebrow">How we work</p>
      <div class="how-we-work-layout">
        <h2>Collaborative, hands-on, and jargon-free.</h2>
        <div class="how-we-work-body">
          <p>
            Whether you're re-platforming an e-commerce business, launching a new mobile app, or refining a digital product, we
            bring clarity, focus, and intent to our process. We follow a hands-on collaborative approach where there's no room
            for micromanaging or technical jargon.
          </p>
          <a href="/handbook/how-we-collaborate" class="link-arrow">See how we collaborate →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       DELIVERABLES
       ============================================================ -->
  <section class="deliverables">
    <div class="deliverables-inner">
      <div class="deliverables-header">
        <p class="eyebrow">What we build</p>
        <h2>Every product type, end-to-end.</h2>
        <p class="deliverables-sub">Including but not limited to.</p>
      </div>
      <ul class="deliverables-grid">
        {
          productTypes.map((type) =>
            type.href ? (
              <li class="deliverable-item deliverable-item--linked">
                <a href={type.href}>
                  <h3 class="deliverable-label">{type.label} →</h3>
                  <p class="deliverable-description">{type.description}</p>
                </a>
              </li>
            ) : (
              <li class="deliverable-item">
                <h3 class="deliverable-label">{type.label}</h3>
                <p class="deliverable-description">{type.description}</p>
              </li>
            )
          )
        }
      </ul>
    </div>
  </section>

  <!-- ============================================================
       INDUSTRIES
       ============================================================ -->
  <section class="industries">
    <div class="industries-inner">
      <div class="industries-header">
        <p class="eyebrow">Industries</p>
        <h2>Industries we've shaped.</h2>
        <p>
          From regulated finance platforms to consumer mobile apps, we've designed and built products across a wide range of
          industries, bringing the same depth of thinking to each one.
        </p>
      </div>
      <ul class="industries-list">
        {
          industries.map((industry) => (
            <li class="industry-item">
              <span>{industry}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ============================================================
       AWARDS
       ============================================================ -->
  {
    awards.length > 0 && (
      <section class="awards">
        <div class="awards-inner">
          <div class="awards-header">
            <p class="eyebrow">Recognition</p>
            <h2>International recognition.</h2>
            <p class="awards-sub">+20 awards across design, development, and innovation.</p>
          </div>
          <ul class="awards-list">
            {awards.map((a) => (
              <li class="award-item">
                {a.url ? (
                  <a href={a.url} target="_blank" rel="noopener noreferrer">
                    <span class="award-name">{a.award}</span>
                    <span class="award-year">{a.year}</span>
                    <span class="award-project">{a.project?.data.client ?? a.project?.data.title}</span>
                  </a>
                ) : (
                  <span class="award-item-inner">
                    <span class="award-name">{a.award}</span>
                    <span class="award-year">{a.year}</span>
                    <span class="award-project">{a.project?.data.client ?? a.project?.data.title}</span>
                  </span>
                )}
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <!-- ============================================================
       PROJECTS + BLOG + PLAYGROUND
       ============================================================ -->
  <section class="content-crosssell">
    <div class="content-crosssell-inner">
      <p class="eyebrow">From Significa</p>
      <div class="content-crosssell-grid">
        {
          featuredProjects[0] && (
            <a href={`/projects/${featuredProjects[0].id}`} class="crosssell-card crosssell-card--project">
              {featuredProjects[0].data.thumbnail && (
                <div class="crosssell-image">
                  <img
                    src={cdnUrl(featuredProjects[0].data.thumbnail, { width: 800, quality: 80 })}
                    alt={featuredProjects[0].data.title}
                    width="800"
                    height="500"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              )}
              <div class="crosssell-content">
                <span class="crosssell-type">Project</span>
                <h3 class="crosssell-title">{featuredProjects[0].data.client ?? featuredProjects[0].data.title}</h3>
                {featuredProjects[0].data.tagline && <p class="crosssell-description">{featuredProjects[0].data.tagline}</p>}
              </div>
            </a>
          )
        }
        <div class="crosssell-secondary">
          {
            recentPost && (
              <a href={`/blog/${recentPost.id}`} class="crosssell-card">
                {recentPost.data.thumbnail && (
                  <div class="crosssell-image">
                    <img
                      src={cdnUrl(recentPost.data.thumbnail, { width: 600, quality: 80 })}
                      alt={recentPost.data.title}
                      width="600"
                      height="400"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                )}
                <div class="crosssell-content">
                  <span class="crosssell-type">Blog</span>
                  <h3 class="crosssell-title">{recentPost.data.title}</h3>
                  {recentPost.data.description && <p class="crosssell-description">{recentPost.data.description}</p>}
                </div>
              </a>
            )
          }
          {
            recentPlayground && (
              <a href={`/playground/${recentPlayground.id}`} class="crosssell-card">
                {recentPlayground.data.thumbnail && (
                  <div class="crosssell-image">
                    <img
                      src={cdnUrl(recentPlayground.data.thumbnail, { width: 600, quality: 80 })}
                      alt={recentPlayground.data.title}
                      width="600"
                      height="400"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                )}
                <div class="crosssell-content">
                  <span class="crosssell-type">Playground</span>
                  <h3 class="crosssell-title">{recentPlayground.data.title}</h3>
                  <p class="crosssell-description">{recentPlayground.data.description}</p>
                </div>
              </a>
            )
          }
        </div>
      </div>
      <div class="content-crosssell-cta">
        <a href="/projects" class="link-arrow">All projects →</a>
        <a href="/blog" class="link-arrow">All posts →</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FINAL CTA
       ============================================================ -->
  <section class="final-cta">
    <div class="final-cta-inner">
      <h2>Ready to build something great together?</h2>
      <p>Tell us about your project. We'll figure out whether we're the right fit. No pressure, no jargon.</p>
      <a href="/say-hello" class="cta-button-large">Get in touch</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============================================================
     Shared utilities
     ============================================================ */

  .eyebrow {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .link-arrow {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .link-arrow:hover {
    color: var(--color-text);
  }

  .cta-button {
    display: inline-block;
    padding: 0.8125rem 1.75rem;
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    border-radius: 0.375rem;
    background: var(--color-text);
    color: var(--color-surface);
    transition:
      opacity var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }
  .cta-button:hover {
    opacity: 0.82;
    transform: translateY(-1px);
  }

  .cta-button-large {
    display: inline-block;
    padding: 1rem 2.5rem;
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    border-radius: 0.375rem;
    background: var(--color-text);
    color: var(--color-surface);
    transition:
      opacity var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }
  .cta-button-large:hover {
    opacity: 0.82;
    transform: translateY(-1px);
  }

  /* ============================================================
     HERO
     ============================================================ */
  .hero {
    padding: 9rem var(--gutter) 6rem;
  }

  .hero-inner {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
  }

  .hero h1 {
    font-size: clamp(2rem, 1.25rem + 3vw, 3.25rem);
    font-weight: var(--weight-normal);
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin-bottom: 2.5rem;
  }

  .hero h1 strong {
    font-weight: var(--weight-bold);
  }

  .hero-sub {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
    margin-bottom: 1rem;
  }

  .hero-description {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    max-width: 58ch;
  }

  /* ============================================================
     SERVICES INTRO
     ============================================================ */
  .services-intro {
    padding: 7rem var(--gutter);
    border-top: 1px solid var(--color-border);
  }

  .services-intro-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .services-intro-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .services-intro-heading {
    font-size: clamp(1.75rem, 1.25rem + 2vw, 2.5rem);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
  }

  .services-intro-aside p {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
  }

  @media (max-width: 900px) {
    .services-intro-layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  /* ============================================================
     SERVICE PILLARS
     ============================================================ */
  .pillars {
    background: var(--color-surface-alt);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 0 var(--gutter);
  }

  .pillars-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .pillar {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 5rem;
    padding: 5rem 0;
    border-bottom: 1px solid var(--color-border);
    align-items: start;
  }

  .pillar:last-child {
    border-bottom: none;
  }

  .pillar-header {
    position: sticky;
    top: 3rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .pillar-number {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }

  .pillar-title {
    font-size: clamp(2rem, 1.5rem + 2vw, 3rem);
    font-weight: var(--weight-bold);
    line-height: 1;
    color: var(--color-text);
  }

  .pillar-body {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-top: 0.25rem;
  }

  .pillar-description {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    max-width: 60ch;
  }

  .pillar-deliverables {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
  }

  .pillar-deliverables li {
    padding: 0.4375rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 2rem;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text);
    background: var(--color-surface);
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .pillar-deliverables li:hover {
    border-color: var(--color-text);
  }

  .pillar-link {
    align-self: flex-start;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .pillar-link:hover {
    color: var(--color-text);
  }

  @media (max-width: 860px) {
    .pillar {
      grid-template-columns: 1fr;
      gap: 1.75rem;
      padding: 3.5rem 0;
    }

    .pillar-header {
      position: static;
      flex-direction: row;
      align-items: baseline;
      gap: 0.875rem;
    }

    .pillar-title {
      font-size: var(--text-2xl);
    }
  }

  /* ============================================================
     TESTIMONIAL
     ============================================================ */
  .testimonial-section {
    padding: 7rem var(--gutter);
  }

  .testimonial-section-inner {
    max-width: 44rem;
    margin: 0 auto;
    text-align: center;
  }

  .testimonial-quote {
    font-size: clamp(1.25rem, 1rem + 1vw, 1.75rem);
    font-weight: var(--weight-normal);
    line-height: var(--leading-relaxed);
    color: var(--color-text);
    margin-bottom: 2.5rem;
  }

  .testimonial-author cite {
    font-style: normal;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .testimonial-author strong {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  .testimonial-author span {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  /* ============================================================
     HOW WE WORK
     ============================================================ */
  .how-we-work {
    background: var(--color-surface-alt);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 7rem var(--gutter);
  }

  .how-we-work-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .how-we-work-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .how-we-work-layout h2 {
    font-size: clamp(1.5rem, 1.25rem + 1.5vw, 2.25rem);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
  }

  .how-we-work-body p {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    max-width: 50ch;
  }

  @media (max-width: 860px) {
    .how-we-work-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  /* ============================================================
     DELIVERABLES
     ============================================================ */
  .deliverables {
    padding: 7rem var(--gutter);
  }

  .deliverables-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .deliverables-header {
    margin-bottom: 3.5rem;
    max-width: var(--max-width-narrow);
  }

  .deliverables-header h2 {
    font-size: clamp(1.5rem, 1.25rem + 1.5vw, 2.25rem);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    margin-bottom: 0.5rem;
  }

  .deliverables-sub {
    font-size: var(--text-base);
    color: var(--color-text-muted);
  }

  .deliverables-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    list-style: none;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .deliverable-item {
    background: var(--color-surface);
    padding: 2.25rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .deliverable-item:hover {
    background: var(--color-surface-alt);
  }

  .deliverable-item--linked {
    padding: 0;
  }

  .deliverable-item--linked a {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 2.25rem 2rem;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .deliverable-label {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  .deliverable-description {
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
  }

  @media (max-width: 860px) {
    .deliverables-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
