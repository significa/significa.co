---
/**
 * /careers — Join us
 *
 * Editorial register. Not a recruitment template. The voice here
 * should make someone who'd thrive at Significa lean forward, and
 * someone who wouldn't self-select out.
 *
 *   1. Position statement — what the job actually is.
 *   2. Open positions — or honest "none right now."
 *   3. What you get — benefits as a compact list, not cards.
 *   4. How we hire — link-calls to handbook pages.
 *   5. Close — send application.
 */

import BaseLayout from "@/layouts/base.astro";
import Eyebrow from "@/components/ui/eyebrow.astro";
import SectionHeader from "@/components/ui/section-header.astro";
import QaList from "@/components/ui/qa-list.astro";
import LinkCall from "@/components/ui/link-call.astro";

const benefits = [
  {
    n: "01",
    q: "25+ vacation days",
    a: "22 of your choice, plus your birthday and the end-of-year days off. From your second year, you earn an extra day per year, up to 30.",
  },
  {
    n: "02",
    q: "Unlimited learning stipend",
    a: "Any course, conference, or book. No approval committee. We'd rather overspend on growth than explain why we didn't.",
  },
  {
    n: "03",
    q: "Health insurance + support",
    a: "Private health insurance. 24/7 support for legal, fiscal, nutrition, and mental health through an external partner. Period leave.",
  },
  {
    n: "04",
    q: "Equipment, no questions",
    a: "Whatever you need to do your best work. Laptop, monitor, peripherals, chair, standing desk. You tell us.",
  },
  {
    n: "05",
    q: "Career plan",
    a: "One-on-ones, OKRs, and a progression framework. Not the corporate kind. The kind where someone actually pays attention to where you want to go.",
  },
  {
    n: "06",
    q: "Flexible location",
    a: "Office-first in Porto. But you come and go as you like. We believe proximity makes better work, but we don't need to babysit schedules to prove it.",
  },
];

const hiring = [
  {
    n: "01",
    q: "Conversation",
    a: "No pitch deck, no HR screening. A real conversation about what you do, what you care about, and whether the fit makes sense. If it doesn't, we'll say so.",
  },
  {
    n: "02",
    q: "Challenge",
    a: "A short, paid exercise that mirrors the kind of work you'd actually do here. We don't believe in whiteboard interviews or trick questions.",
  },
  {
    n: "03",
    q: "Decision",
    a: "Fast, honest. We aim to close within two weeks. If we're not the right place for you, we'll tell you why.",
  },
];
---

<BaseLayout
  title="Careers — Significa"
  description="Designers and engineers in Porto, working on complex products with real care. See open positions and what it's like to work at Significa."
>
  <!-- ============================================================
       1. Position statement
       ============================================================ -->
  <section class="hero" aria-labelledby="hero-h">
    <Eyebrow>Careers <span class="sep">/</span> Porto</Eyebrow>
    <h1 id="hero-h" class="hero-heading type-display-2">We hire people who have opinions and do the work to back them up.</h1>
    <p class="hero-deck">
      Designers, engineers, and producers working together in Porto's centre. Small team, complex products, high bar. If you
      want a place where your judgement matters and the work is the proof, keep reading.
    </p>
  </section>

  <!-- ============================================================
       2. Open positions
       ============================================================ -->
  <section class="positions" aria-labelledby="positions-h">
    <Eyebrow>Open positions</Eyebrow>
    <div class="positions-empty">
      <h2 id="positions-h" class="positions-heading">Nothing open right now.</h2>
      <p class="positions-deck">
        We hire when there's a real need, not to hit a headcount target. If you think we should know about you anyway, send an
        email.
      </p>
      <p class="positions-link">
        <LinkCall href="mailto:jobs@significa.co">jobs@significa.co</LinkCall>
      </p>
    </div>
  </section>

  <!-- ============================================================
       3. Benefits — what you get
       ============================================================ -->
  <section class="benefits" aria-labelledby="benefits-h">
    <header class="benefits-header">
      <Eyebrow>What you get</Eyebrow>
      <SectionHeader id="benefits-h">The practical stuff.</SectionHeader>
    </header>
    <QaList items={benefits} />
  </section>

  <!-- ============================================================
       4. How we hire
       ============================================================ -->
  <section class="process" aria-labelledby="process-h">
    <header class="process-header">
      <Eyebrow>How we hire</Eyebrow>
      <SectionHeader id="process-h">Three steps. Two weeks.</SectionHeader>
    </header>
    <QaList items={hiring} />
    <div class="process-links">
      <LinkCall href="/handbook/hiring-criteria">Hiring criteria</LinkCall>
      <LinkCall href="/handbook/recruitment-process">Full recruitment process</LinkCall>
      <LinkCall href="/handbook/mission-and-values/equal-opportunities-statement">Equal opportunities</LinkCall>
    </div>
  </section>

  <!-- ============================================================
       5. Culture pointers
       ============================================================ -->
  <section class="culture" aria-labelledby="culture-h">
    <Eyebrow>How we work</Eyebrow>
    <h2 id="culture-h" class="culture-heading">Read the handbook before you apply.</h2>
    <p class="culture-deck">
      We wrote it down so you can see what you're signing up for. Culture, design ethos, engineering practices, feedback norms.
      No surprises.
    </p>
    <div class="culture-links">
      <LinkCall href="/handbook">Handbook</LinkCall>
      <LinkCall href="/about">About Significa</LinkCall>
    </div>
  </section>
</BaseLayout>

<style>
  section {
    padding-inline: var(--gutter);
    padding-block: clamp(5rem, 10vw, 10rem);
  }

  /* ── Hero ── */

  .hero {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-block: clamp(5rem, 8vw, 10rem) clamp(5rem, 10vw, 10rem);
  }

  .hero-heading {
    margin: 0;
    max-width: 20ch;
  }

  .hero-deck {
    margin-block: 2.5rem 0;
    font-size: var(--text-xl);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
    max-width: var(--max-width-prose);
  }

  @media (max-width: 768px) {
    .hero-heading {
      font-size: var(--text-4xl);
    }
  }

  /* ── Positions ── */

  .positions {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    border-block-start: 1px solid var(--color-rule);
  }

  .positions-empty {
    max-width: var(--max-width-prose);
  }

  .positions-heading {
    font-weight: var(--weight-medium);
    font-size: var(--text-3xl);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 1.5rem;
    color: var(--color-ink);
  }

  .positions-deck {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
  }

  .positions-link {
    margin-block-start: 2rem;
  }

  /* ── Benefits ── */

  .benefits {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    border-block-start: 1px solid var(--color-rule);
  }

  .benefits-header {
    margin-block-end: clamp(3rem, 6vw, 5rem);
  }

  /* ── Process ── */

  .process {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    border-block-start: 1px solid var(--color-rule);
  }

  .process-header {
    margin-block-end: clamp(3rem, 6vw, 5rem);
  }

  .process-links {
    margin-block-start: 3rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 3rem;
  }

  /* ── Culture ── */

  .culture {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    border-block-start: 1px solid var(--color-rule);
  }

  .culture-heading {
    font-weight: var(--weight-medium);
    font-size: var(--text-3xl);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 1.5rem;
    color: var(--color-ink);
    max-width: 24ch;
  }

  .culture-deck {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
    max-width: var(--max-width-prose);
  }

  .culture-links {
    margin-block-start: 2.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 3rem;
  }
</style>
