---
/**
 * /work/[slug] — Case study
 *
 * Judgment-led, not deliverable-led. Structure:
 *   1. Hook — eyebrow + editorial reframing.
 *   2. Hero image (or showreel).
 *   3. Metadata strip — featured-meta pattern.
 *   4. MDX body — prose.css.
 *   5. Related projects — editorial index, not cards.
 *   6. Close — single link-call.
 */

import { getEntry, render } from "astro:content";
import BaseLayout from "@/layouts/base.astro";
import Eyebrow from "@/components/ui/eyebrow.astro";
import LinkCall from "@/components/ui/link-call.astro";
import IndexList from "@/components/ui/index-list.astro";
import FeaturedMeta from "@/components/ui/featured-meta.astro";
import { mdxComponents } from "@/components/mdx/components";
import { getProjects, getAwardsForProject } from "@/lib/collections";
import { cdnUrl } from "@/lib/cdn";
import { pageWithProjectJsonLd } from "@/lib/seo";

export async function getStaticPaths() {
  const projects = await getProjects();
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const showreelVideo = project.data.showreelVideo;
const showreelCover = project.data.showreelCover ?? project.data.heroImage;

const seo = project.data.seo;
const title = seo?.metaTitle ?? project.data.title;
const description = seo?.metaDescription ?? project.data.tagline ?? project.data.title;
const ogImage = seo?.ogImage ?? project.data.heroImage ?? project.data.thumbnail;

const [relatedProjects, projectAwards] = await Promise.all([
  project.data.relatedProjects?.length
    ? Promise.all(project.data.relatedProjects.map((ref) => getEntry(ref)))
    : Promise.resolve([]),
  getAwardsForProject(project.id),
]);

const structuredData = pageWithProjectJsonLd(
  {
    title: project.data.title,
    description: project.data.tagline ?? project.data.title,
    url: `https://significa.co/work/${project.id}`,
    image: ogImage,
    datePublished: project.data.date,
    client: project.data.client,
    tags: project.data.tags,
    deliverable: project.data.deliverable,
    industry: project.data.industry,
    awards: projectAwards.map((a) => `${a.data.award} ${a.data.year}`),
  },
  [
    { name: "Home", url: "https://significa.co" },
    { name: "Work", url: "https://significa.co/work" },
    { name: project.data.title, url: `https://significa.co/work/${project.id}` },
  ]
);

const formattedDate = project.data.date.toLocaleDateString("en-GB", {
  year: "numeric",
  month: "long",
});

function formatLabel(str: string): string {
  return str
    .split("-")
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(" ");
}

// Build the metadata strip items
const metaItems: Array<{ label: string; value: string }> = [];
if (project.data.client) metaItems.push({ label: "Client", value: project.data.client });
metaItems.push({ label: "Year", value: formattedDate });
if (project.data.industry?.length)
  metaItems.push({ label: "Industry", value: project.data.industry.map(formatLabel).join(", ") });
if (project.data.deliverable?.length)
  metaItems.push({ label: "Deliverables", value: project.data.deliverable.map(formatLabel).join(", ") });
if (project.data.tags?.length) metaItems.push({ label: "Services", value: project.data.tags.map(formatLabel).join(", ") });
---

<BaseLayout title={title} description={description} ogImage={ogImage} structuredData={structuredData}>
  <article class="project">
    <!-- ============================================================
         1. Hook
         ============================================================ -->
    <header class="project-header">
      <Eyebrow>
        {project.data.client ?? project.data.title}
        <span class="sep">/</span>
        {new Date(project.data.date).getFullYear()}
      </Eyebrow>
      <h1 class="project-heading type-display-2">
        {project.data.hook ?? project.data.tagline ?? project.data.title}
      </h1>
    </header>

    <!-- ============================================================
         2. Hero image or showreel
         ============================================================ -->
    {
      showreelVideo ? (
        <section class="project-showreel">
          <div class="project-showreel-inner">
            <div class="project-showreel-media" data-showreel>
              <video src={showreelVideo} width="1920" height="1080" loop muted playsinline preload="none" data-showreel-video />
              {showreelCover && (
                <div class="showreel-cover" data-showreel-cover aria-hidden="true">
                  <img src={cdnUrl(showreelCover, { width: 1920, quality: 85 })} alt="" draggable="false" />
                </div>
              )}
              <button class="showreel-cursor" type="button" data-showreel-cursor aria-label="Play showreel video">
                <span class="showreel-cursor-icon" aria-hidden="true">
                  ▶
                </span>
              </button>
            </div>
          </div>
        </section>
      ) : (
        project.data.heroImage && (
          <div class="project-hero-image">
            <img
              src={cdnUrl(project.data.heroImage, { width: 1920, quality: 85 })}
              srcset={[
                `${cdnUrl(project.data.heroImage, { width: 960, quality: 85 })} 960w`,
                `${cdnUrl(project.data.heroImage, { width: 1280, quality: 85 })} 1280w`,
                `${cdnUrl(project.data.heroImage, { width: 1920, quality: 85 })} 1920w`,
              ].join(", ")}
              sizes="100vw"
              alt={project.data.altText ?? project.data.title}
              width="1920"
              height="1080"
              loading="eager"
              fetchpriority="high"
              decoding="sync"
            />
          </div>
        )
      )
    }

    <!-- ============================================================
         3. Metadata strip
         ============================================================ -->
    <div class="project-meta">
      <FeaturedMeta items={metaItems} />
    </div>

    <!-- ============================================================
         4. MDX body
         ============================================================ -->
    <div class="project-content">
      <div class="project-content-inner prose">
        <Content components={mdxComponents} />
      </div>
    </div>

    <!-- ============================================================
         5. Related projects — editorial index
         ============================================================ -->
    {
      relatedProjects.length > 0 && (
        <aside class="related" aria-labelledby="related-h">
          <div class="related-inner">
            <Eyebrow id="related-h">More work</Eyebrow>
            <IndexList
              items={relatedProjects.filter(Boolean).map((related, i) => ({
                href: `/work/${related!.id}`,
                title: related!.data.title,
                tagline: related!.data.tagline ?? "",
                date: String(new Date(related!.data.date).getFullYear()),
                num: String(i + 1).padStart(2, "0"),
              }))}
            />
          </div>
        </aside>
      )
    }

    <!-- ============================================================
         6. Close
         ============================================================ -->
    <div class="project-close">
      <LinkCall href="/hello">Start a conversation</LinkCall>
    </div>
  </article>
</BaseLayout>

<!-- Showreel cursor-following button — vanilla JS, no island needed -->
<script>
  function initShowreel() {
    const section = document.querySelector<HTMLElement>("[data-showreel]");
    const cursor = document.querySelector<HTMLButtonElement>("[data-showreel-cursor]");
    const video = document.querySelector<HTMLVideoElement>("[data-showreel-video]");
    if (!section || !cursor || !video) return;

    let isPlaying = false;

    function positionAt(e: MouseEvent) {
      if (!cursor) return;
      const x = e.clientX - cursor.offsetWidth / 2;
      const y = e.clientY - cursor.offsetHeight / 2;
      cursor.style.translate = `${x}px ${y}px`;
    }

    function updateCursorIcon() {
      if (!cursor) return;
      const icon = cursor.querySelector(".showreel-cursor-icon");
      if (icon) {
        icon.textContent = isPlaying ? "❚❚" : "▶";
      }
    }

    const cover = document.querySelector<HTMLElement>("[data-showreel-cover]");

    function toggleVideo() {
      if (!video) return;
      if (isPlaying) {
        video.pause();
        isPlaying = false;
      } else {
        video.play();
        isPlaying = true;
        if (cover) cover.style.display = "none";
      }
      updateCursorIcon();
    }

    section.addEventListener("mouseenter", (e: MouseEvent) => {
      positionAt(e);
      cursor.style.opacity = "1";
      cursor.style.scale = "1";
    });

    section.addEventListener("mouseleave", () => {
      cursor.style.opacity = "0";
      cursor.style.scale = "0.5";
    });

    section.addEventListener("mousemove", (e: MouseEvent) => {
      positionAt(e);
    });

    section.addEventListener("click", toggleVideo);
    cursor.addEventListener("click", (e) => {
      e.stopPropagation();
      toggleVideo();
    });

    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    if (prefersReducedMotion.matches) {
      cursor.style.display = "none";
    }
    prefersReducedMotion.addEventListener("change", (e) => {
      cursor.style.display = e.matches ? "none" : "";
    });
  }

  initShowreel();
  document.addEventListener("astro:after-swap", initShowreel);
</script>

<style>
  /* ============================================================
     1. Header
     ============================================================ */

  .project-header {
    max-width: var(--max-width-wide);
    margin-inline: auto;
    padding-inline: var(--gutter);
    padding-block: clamp(4rem, 8vw, 7rem) clamp(2rem, 4vw, 3rem);
  }

  .project-heading {
    margin: 0;
    max-width: 24ch;
  }

  /* ============================================================
     2. Hero image
     ============================================================ */

  .project-hero-image {
    max-width: var(--max-width-wide);
    margin-inline: auto;
    padding-inline: var(--gutter);
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .project-hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: var(--radius-image);
  }

  /* ============================================================
     Showreel
     ============================================================ */

  .project-showreel {
    padding: 0 var(--gutter);
  }

  .project-showreel-inner {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .project-showreel-media {
    position: relative;
    border-radius: var(--radius-image);
    overflow: hidden;
    cursor: none;
  }

  .project-showreel-media video {
    width: 100%;
    height: auto;
    display: block;
  }

  .project-showreel-media .showreel-cover {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .project-showreel-media .showreel-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .showreel-cursor {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 10;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--color-ink);
    color: var(--color-paper);
    border: none;
    border-radius: 2rem;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    pointer-events: none;
    opacity: 0;
    scale: 0.5;
    transition:
      opacity var(--duration-fast) var(--ease-out),
      scale var(--duration-fast) cubic-bezier(0.34, 1.56, 0.64, 1);
    will-change: translate, scale;
    white-space: nowrap;
  }

  .showreel-cursor-icon {
    font-size: 0.625rem;
  }

  @media (hover: none) {
    .project-showreel-media {
      cursor: default;
    }

    .showreel-cursor {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%) !important;
      opacity: 1 !important;
      pointer-events: auto;
    }
  }

  /* ============================================================
     3. Metadata strip
     ============================================================ */

  .project-meta {
    max-width: var(--max-width-wide);
    margin-inline: auto;
    padding-inline: var(--gutter);
    padding-block: clamp(2rem, 4vw, 3rem);
  }

  /* ============================================================
     4. MDX body
     ============================================================ */

  .project-content {
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .project-content-inner {
    max-width: var(--max-width-narrow);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* Awards list — rendered from MDX under a "## Awards" heading.
     Inline badges, no hairlines. */
  .project-content-inner :global(h2 + ul),
  .project-content-inner :global(h2 + ul li) {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .project-content-inner :global(h2 + ul) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-block-end: 1.5rem;
  }

  .project-content-inner :global(h2 + ul li) {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    padding: 0.4rem 1rem;
    background: var(--color-paper-alt);
    border-radius: 2rem;
    color: var(--color-ink);
  }

  .project-content-inner :global(h2 + ul li strong) {
    font-weight: var(--weight-medium);
  }

  /* ============================================================
     5. Related projects
     ============================================================ */

  .related {
    max-width: var(--max-width-wide);
    margin-inline: auto;
    padding-inline: var(--gutter);
    padding-block: clamp(3rem, 6vw, 5rem) clamp(2rem, 4vw, 3rem);
    border-block-start: 1px solid var(--color-rule);
  }

  .related-inner {
    max-width: var(--max-width-wide);
  }

  /* ============================================================
     6. Close
     ============================================================ */

  .project-close {
    max-width: var(--max-width-wide);
    margin-inline: auto;
    padding-inline: var(--gutter);
    padding-block: clamp(3rem, 6vw, 5rem);
    border-block-start: 1px solid var(--color-rule);
  }

  @media (max-width: 768px) {
    .project-heading {
      font-size: var(--text-3xl);
    }
  }
</style>
