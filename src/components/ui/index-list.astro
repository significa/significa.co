---
/**
 * Editorial index — compact numbered list with hover states.
 *
 * Two modes:
 *   1. Pass `items` for standard rendering.
 *   2. Omit `items` and use <slot> for custom list items (e.g. load-more).
 *      Each slotted <li> should contain an <a class="index-link"> with the
 *      standard index-num / index-title / index-tagline / index-year / index-mark spans.
 */
interface IndexItem {
  href: string;
  title: string;
  tagline: string;
  date: string;
  num: string;
}

interface Props {
  items?: IndexItem[];
  class?: string;
}

const { items, class: className } = Astro.props;
---

<ol class:list={["index-list", className]} role="list">
  {items
    ? items.map((item) => (
        <li>
          <a href={item.href} class="index-link">
            <span class="index-num">{item.num}</span>
            <span class="index-title">{item.title}</span>
            <span class="index-tagline">{item.tagline}</span>
            <span class="index-year">{item.date}</span>
            <span class="index-mark" aria-hidden="true">&rarr;</span>
          </a>
        </li>
      ))
    : <slot />
  }
</ol>

<style>
  .index-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .index-list :global(.index-link) {
    display: grid;
    grid-template-columns: 3rem minmax(10rem, 1fr) 2fr auto;
    align-items: baseline;
    column-gap: 2rem;
    padding-block: 1.4rem;
    padding-inline: 1rem;
    color: var(--color-ink);
    transition:
      background-color var(--duration-normal) var(--ease-out),
      color var(--duration-normal) var(--ease-out);
    margin-inline: -1rem;
    border-radius: 4px;
  }

  .index-list :global(.index-link:hover) {
    background: var(--color-paper-alt);
    color: var(--color-accent);
  }

  .index-list :global(.index-num) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    font-variant-numeric: tabular-nums;
    transition: color var(--duration-normal) var(--ease-out);
  }

  .index-list :global(.index-link:hover .index-num) {
    color: var(--color-accent);
  }

  .index-list :global(.index-title) {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-xl);
    line-height: 1;
    color: var(--color-ink);
    transition: color var(--duration-normal) var(--ease-out);
  }

  .index-list :global(.index-link:hover .index-title) {
    color: var(--color-accent);
  }

  .index-list :global(.index-tagline) {
    font-size: var(--text-sm);
    color: var(--color-ink-faint);
    line-height: var(--leading-snug);
    transition: color var(--duration-normal) var(--ease-out);
  }

  .index-list :global(.index-link:hover .index-tagline) {
    color: var(--color-ink-muted);
  }

  .index-list :global(.index-year),
  .index-list :global(.index-mark) {
    grid-column: 4;
    grid-row: 1;
    text-align: right;
    justify-self: end;
  }

  .index-list :global(.index-year) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    font-variant-numeric: tabular-nums;
    opacity: 1;
    transition:
      opacity var(--duration-normal) var(--ease-out),
      transform var(--duration-normal) var(--ease-out);
  }

  .index-list :global(.index-link:hover .index-year) {
    opacity: 0;
    transform: translateX(0.4em);
  }

  .index-list :global(.index-mark) {
    color: var(--color-accent);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    line-height: 1;
    opacity: 0;
    transform: translateX(-0.4em);
    transition:
      opacity var(--duration-normal) var(--ease-editorial),
      transform var(--duration-normal) var(--ease-editorial);
  }

  .index-list :global(.index-link:hover .index-mark) {
    opacity: 1;
    transform: translateX(0);
  }

  @media (max-width: 720px) {
    .index-list :global(.index-link) {
      grid-template-columns: 2.25rem 1fr auto;
      column-gap: 1rem;
      padding-inline: 0.5rem;
      margin-inline: -0.5rem;
    }

    .index-list :global(.index-tagline),
    .index-list :global(.index-mark) {
      display: none;
    }
  }
</style>
