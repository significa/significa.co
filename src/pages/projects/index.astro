---
import BaseLayout from "@/layouts/base.astro";
import { getProjects } from "@/lib/collections";
import { getCollection } from "astro:content";
import { cdnUrl } from "@/lib/cdn";

const projects = await getProjects();
const allAwards = await getCollection("awards");

// Group awards by project
const awardsByProject = new Map<string, Array<{ award: string; year: number; url?: string }>>();
for (const award of allAwards) {
  const projectId = award.data.project.id;
  if (!awardsByProject.has(projectId)) {
    awardsByProject.set(projectId, []);
  }
  awardsByProject.get(projectId)!.push({
    award: award.data.award,
    year: award.data.year,
    url: award.data.url,
  });
}

// Extract unique industries and deliverables
const industries = Array.from(new Set(projects.flatMap((p) => p.data.industry || []))).sort();
const deliverables = Array.from(new Set(projects.flatMap((p) => p.data.deliverable || []))).sort();

// Format label for display: "mobile-app" → "Mobile App"
function formatLabel(value: string): string {
  return value
    .split("-")
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");
}
---

<BaseLayout title="Projects — Significa" description="Selected work from Significa's portfolio.">
  <div class="page">
    <header class="page-header">
      <h1>Projects.</h1>
    </header>

    <section class="filters" aria-label="Project filters">
      <details id="filter-panel">
        <summary class="filter-toggle">
          <span>Filters</span>
          <span class="filter-count" data-filter-count hidden>0</span>
          <svg
            class="chevron"
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
            ></path>
          </svg>
        </summary>

        <div class="filter-panel-content">
          <div class="filter-header">
            <h3>Filter projects</h3>
            <button class="clear-button" type="button" data-clear-filters hidden>Clear all</button>
          </div>

          {
            industries.length > 0 && (
              <fieldset class="filter-group">
                <legend>Industry</legend>
                <div class="filter-options">
                  {industries.map((industry) => (
                    <label class="filter-option">
                      <input type="checkbox" name="industry" value={industry} />
                      <span class="checkbox-custom" />
                      <span class="filter-label">{formatLabel(industry)}</span>
                    </label>
                  ))}
                </div>
              </fieldset>
            )
          }

          {
            deliverables.length > 0 && (
              <fieldset class="filter-group">
                <legend>Deliverable</legend>
                <div class="filter-options">
                  {deliverables.map((deliverable) => (
                    <label class="filter-option">
                      <input type="checkbox" name="deliverable" value={deliverable} />
                      <span class="checkbox-custom" />
                      <span class="filter-label">{formatLabel(deliverable)}</span>
                    </label>
                  ))}
                </div>
              </fieldset>
            )
          }
        </div>
      </details>

      <p class="results-count" data-results-count>
        Showing {projects.length} of {projects.length} projects
      </p>
    </section>

    <div class="projects-grid" data-projects-grid>
      {
        projects.map((project) => {
          const projectAwards = awardsByProject.get(project.id) || [];
          const thumbnailUrl = project.data.thumbnail ? cdnUrl(project.data.thumbnail, { width: 800, quality: 85 }) : null;

          return (
            <article
              class="project-card"
              data-industries={(project.data.industry || []).join(",")}
              data-deliverables={(project.data.deliverable || []).join(",")}
            >
              <a href={`/projects/${project.id}`} class="project-link">
                {thumbnailUrl && (
                  <div class="project-thumbnail">
                    <img src={thumbnailUrl} alt={project.data.title} loading="lazy" decoding="async" />
                  </div>
                )}

                <div class="project-info">
                  <h2 class="project-title">{project.data.title}</h2>
                  {project.data.tagline && <p class="project-tagline">{project.data.tagline}</p>}

                  {projectAwards.length > 0 && (
                    <ul class="awards-list" role="list">
                      {projectAwards.slice(0, 5).map((award) => (
                        <li class="award-badge">
                          <span class="award-name">{award.award}</span>
                        </li>
                      ))}
                    </ul>
                  )}

                  <span class="view-project">View project →</span>
                </div>
              </a>
            </article>
          );
        })
      }
    </div>

    <div class="no-results" data-no-results hidden>
      <p>No projects match the selected filters.</p>
      <button class="clear-button-large" type="button" data-clear-filters>Clear filters</button>
    </div>
  </div>
</BaseLayout>

<script>
  function initFilters() {
    const cards = document.querySelectorAll<HTMLElement>("[data-projects-grid] .project-card");
    const checkboxes = document.querySelectorAll<HTMLInputElement>(".filter-option input[type='checkbox']");
    const countEl = document.querySelector<HTMLElement>("[data-filter-count]");
    const resultsEl = document.querySelector<HTMLElement>("[data-results-count]");
    const noResultsEl = document.querySelector<HTMLElement>("[data-no-results]");
    const clearButtons = document.querySelectorAll<HTMLButtonElement>("[data-clear-filters]");
    const total = cards.length;

    function getSelectedValues(name: string): Set<string> {
      const values = new Set<string>();
      checkboxes.forEach((cb) => {
        if (cb.name === name && cb.checked) values.add(cb.value);
      });
      return values;
    }

    function applyFilters() {
      const selectedIndustries = getSelectedValues("industry");
      const selectedDeliverables = getSelectedValues("deliverable");
      const activeCount = selectedIndustries.size + selectedDeliverables.size;

      // Update URL without reload
      const params = new URLSearchParams();
      selectedIndustries.forEach((v) => params.append("industry", v));
      selectedDeliverables.forEach((v) => params.append("deliverable", v));
      const qs = params.toString();
      const url = qs ? `${window.location.pathname}?${qs}` : window.location.pathname;
      history.replaceState(null, "", url);

      // Show/hide filter count badge
      if (countEl) {
        countEl.textContent = String(activeCount);
        countEl.hidden = activeCount === 0;
      }

      // Show/hide clear buttons
      clearButtons.forEach((btn) => {
        btn.hidden = activeCount === 0;
      });

      // Filter cards
      let visible = 0;
      cards.forEach((card) => {
        const cardIndustries = (card.dataset.industries || "").split(",").filter(Boolean);
        const cardDeliverables = (card.dataset.deliverables || "").split(",").filter(Boolean);

        const matchesIndustry = selectedIndustries.size === 0 || cardIndustries.some((i) => selectedIndustries.has(i));
        const matchesDeliverable = selectedDeliverables.size === 0 || cardDeliverables.some((d) => selectedDeliverables.has(d));

        const show = matchesIndustry && matchesDeliverable;
        card.hidden = !show;
        if (show) visible++;
      });

      // Update results count
      if (resultsEl) {
        resultsEl.textContent = `Showing ${visible} of ${total} projects`;
      }

      // No results message
      if (noResultsEl) {
        noResultsEl.hidden = visible > 0;
      }
    }

    function syncFromUrl() {
      const params = new URLSearchParams(window.location.search);
      const industries = new Set(params.getAll("industry"));
      const deliverableParams = new Set(params.getAll("deliverable"));

      checkboxes.forEach((cb) => {
        const values = cb.name === "industry" ? industries : deliverableParams;
        cb.checked = values.has(cb.value);
      });

      // Auto-open panel if filters are active
      if (industries.size > 0 || deliverableParams.size > 0) {
        const details = document.getElementById("filter-panel") as HTMLDetailsElement | null;
        if (details) details.open = true;
      }

      applyFilters();
    }

    function clearAll() {
      checkboxes.forEach((cb) => (cb.checked = false));
      applyFilters();
    }

    // Event listeners
    checkboxes.forEach((cb) => cb.addEventListener("change", applyFilters));
    clearButtons.forEach((btn) => btn.addEventListener("click", clearAll));
    window.addEventListener("popstate", syncFromUrl);

    // Initialize from URL on load
    syncFromUrl();
  }

  // Run on initial load and after view transitions
  document.addEventListener("astro:page-load", initFilters);
</script>

<style>
  .page {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--gutter);
    padding-block: 4rem 6rem;
  }

  .page-header {
    margin-block-end: 3rem;
  }

  .page-header h1 {
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
  }

  /* Filter section */
  .filters {
    margin-block-end: 2rem;
  }

  #filter-panel {
    margin-block-end: 1rem;
  }

  .filter-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-text);
    cursor: pointer;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out);
    list-style: none;
  }

  .filter-toggle::-webkit-details-marker {
    display: none;
  }

  .filter-toggle::marker {
    content: "";
  }

  .filter-toggle:hover {
    border-color: var(--color-primary);
    background: var(--color-surface-alt);
  }

  .filter-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.25rem;
    height: 1.25rem;
    padding: 0 0.375rem;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    background: var(--color-primary);
    color: white;
    border-radius: 10px;
  }

  .chevron {
    transition: transform var(--duration-fast) var(--ease-out);
  }

  #filter-panel[open] .chevron {
    transform: rotate(180deg);
  }

  /* Filter panel content */
  .filter-panel-content {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    margin-block-start: 1rem;
    animation: slideDown 0.2s var(--ease-out);
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .filter-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-block-end: 1.5rem;
    padding-block-end: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .filter-header h3 {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    margin: 0;
  }

  .clear-button {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-primary);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .clear-button:hover {
    color: var(--color-primary-hover);
  }

  /* Filter groups */
  .filter-group {
    margin: 0 0 1.5rem;
    padding: 0;
    border: none;
  }

  .filter-group:last-child {
    margin-block-end: 0;
  }

  .filter-group legend {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-block-end: 0.75rem;
    padding: 0;
  }

  .filter-options {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .filter-option {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 6px;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .filter-option:hover {
    background: var(--color-surface-alt);
  }

  .filter-option input[type="checkbox"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .checkbox-custom {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.25rem;
    height: 1.25rem;
    border: 2px solid var(--color-border);
    border-radius: 4px;
    background: var(--color-surface);
    transition: all var(--duration-fast) var(--ease-out);
    flex-shrink: 0;
  }

  .checkbox-custom::after {
    content: "";
    display: block;
    width: 0.5rem;
    height: 0.75rem;
    border: solid white;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg) scale(0);
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .filter-option input[type="checkbox"]:checked ~ .checkbox-custom {
    background: var(--color-primary);
    border-color: var(--color-primary);
  }

  .filter-option input[type="checkbox"]:checked ~ .checkbox-custom::after {
    transform: rotate(45deg) scale(1);
  }

  .filter-option input[type="checkbox"]:focus-visible ~ .checkbox-custom {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .filter-label {
    font-size: var(--text-sm);
    color: var(--color-text);
    user-select: none;
  }

  /* Results count */
  .results-count {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Projects grid */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 400px), 1fr));
    gap: 3rem 2rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
  }

  .project-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: var(--color-text);
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .project-link:hover {
    transform: translateY(-4px);
  }

  .project-thumbnail {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    background: var(--color-surface-alt);
    border-radius: 12px;
    overflow: hidden;
    margin-block-end: 1.25rem;
  }

  .project-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .project-link:hover .project-thumbnail img {
    transform: scale(1.05);
  }

  .project-info {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .project-title {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    margin: 0;
  }

  .project-tagline {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin: 0;
  }

  .awards-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
  }

  .award-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: var(--text-xs);
    padding: 0.375rem 0.75rem;
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    transition: all var(--duration-fast) var(--ease-out);
  }

  .project-link:hover .award-badge {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: white;
  }

  .award-name {
    font-weight: var(--weight-medium);
  }

  .view-project {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-primary);
    margin-top: auto;
    padding-top: 0.5rem;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .project-link:hover .view-project {
    color: var(--color-primary-hover);
  }

  /* No results */
  .no-results {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    text-align: center;
  }

  .no-results p {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    margin: 0 0 1.5rem;
  }

  .clear-button-large {
    padding: 0.75rem 1.5rem;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: white;
    background: var(--color-primary);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .clear-button-large:hover {
    background: var(--color-primary-hover);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .page {
      padding-block: 3rem 4rem;
    }

    .page-header h1 {
      font-size: var(--text-2xl);
    }

    .filter-panel-content {
      padding: 1.25rem;
    }

    .filter-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .projects-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .project-title {
      font-size: var(--text-lg);
    }

    .project-tagline {
      font-size: var(--text-sm);
    }
  }
</style>
