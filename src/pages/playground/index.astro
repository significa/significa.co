---
/**
 * /playground — Open source and experiments
 *
 * Editorial register. Not a portfolio page. A curated view of
 * what the studio builds when the client isn't watching.
 *
 *   1. Hero — what this section is.
 *   2. Foundations — the flagship OSS contribution.
 *   3. Commons — individual tools, editorial index.
 *   4. Labs — content collection items, if any.
 *   5. Close — GitHub link.
 */

import BaseLayout from "@/layouts/base.astro";
import Eyebrow from "@/components/ui/eyebrow.astro";
import SectionHeader from "@/components/ui/section-header.astro";
import LinkCall from "@/components/ui/link-call.astro";
import IndexList from "@/components/ui/index-list.astro";
import { getPlayground } from "@/lib/collections";

const labs = await getPlayground();

const commons = [
  {
    title: "Fly pg_dump to S3",
    desc: "Automates pg_dump backups of Fly.io Postgres databases to AWS S3.",
    href: "https://github.com/significa/fly-pg-dump-to-s3",
  },
  {
    title: "Storyblok assets cleanup",
    desc: "Utility to find and delete unused Storyblok assets.",
    href: "https://github.com/significa/storyblok-assets-cleanup",
  },
  {
    title: "Palette generator",
    desc: "A Svelte monochromatic palette generator.",
    href: "https://github.com/significa/palette-generator",
  },
  {
    title: "1Password secrets",
    desc: "CLI utility to sync 1Password secrets to local env files and Fly apps.",
    href: "https://github.com/significa/1password-secrets",
  },
  { title: "Signals icon font", desc: "An icon font based on Inter, with a keyboard map.", href: "https://si.gnifi.ca/s187" },
  {
    title: "Frontend challenge",
    desc: "Design-driven challenges for those looking to join our team.",
    href: "https://github.com/significa/frontend-challenge",
  },
  { title: "Svelte UI", desc: "Our internal Svelte UI library.", href: "https://github.com/significa/significa-svelte-ui" },
  {
    title: "Absinthe Utils",
    desc: "Utilities for Absinthe (Elixir's GraphQL library).",
    href: "https://github.com/significa/absinthe_utils",
  },
  {
    title: "App distribution server",
    desc: "Self-hosted tool for sharing internal iOS .ipa builds without TestFlight.",
    href: "https://github.com/significa/app-distribution-server",
  },
];
---

<BaseLayout
  title="Playground — Significa"
  description="Open source tools, experiments, and contributions from the Significa team. What we build when the client isn't watching."
>
  <!-- ============================================================
       1. Hero
       ============================================================ -->
  <section class="hero" aria-labelledby="hero-h">
    <Eyebrow>Playground</Eyebrow>
    <h1 id="hero-h" class="hero-heading">What we build when nobody's paying.</h1>
    <p class="hero-deck">
      Open source tools, internal experiments, community contributions. Our stack runs on open source. We contribute fixes,
      documentation, and new tools in return. Work created during company time is published under the Significa name with
      individual credit.
    </p>
  </section>

  <!-- ============================================================
       2. Foundations — flagship OSS
       ============================================================ -->
  <section class="foundations" aria-labelledby="foundations-h">
    <Eyebrow>Flagship project</Eyebrow>
    <h2 id="foundations-h" class="foundations-heading">Significa Foundations.</h2>
    <p class="foundations-deck">
      Our biggest open source contribution, used daily by our design and development teams. An opinionated, practical toolkit
      for building modern digital products. Components, interaction patterns, state management, content modelling. Tested,
      documented, production-ready.
    </p>
    <p class="foundations-link">
      <LinkCall href="https://foundations.significa.co/about">Explore Foundations</LinkCall>
    </p>
  </section>

  <!-- ============================================================
       3. Commons — tools as editorial index
       ============================================================ -->
  <section class="commons" aria-labelledby="commons-h">
    <header class="commons-header">
      <Eyebrow>Open source tools</Eyebrow>
      <SectionHeader id="commons-h">Significa Commons.</SectionHeader>
    </header>

    <IndexList
      items={commons.map((item, i) => ({
        href: item.href,
        title: item.title,
        tagline: item.desc,
        date: "",
        num: String(i + 1).padStart(2, "0"),
      }))}
    />
  </section>

  <!-- ============================================================
       4. Labs — content collection items
       ============================================================ -->
  {
    labs.length > 0 && (
      <section class="labs" aria-labelledby="labs-h">
        <header class="labs-header">
          <Eyebrow>From the lab</Eyebrow>
          <SectionHeader id="labs-h">Experiments and write-ups.</SectionHeader>
        </header>

        <IndexList
          items={labs.map((lab, i) => ({
            href: `/playground/${lab.id}`,
            title: lab.data.title,
            tagline: lab.data.description ?? "",
            date: String(new Date(lab.data.date).getFullYear()),
            num: String(i + 1).padStart(2, "0"),
          }))}
        />
      </section>
    )
  }

  <!-- ============================================================
       5. Close
       ============================================================ -->
  <footer class="close">
    <LinkCall href="https://github.com/significa">See everything on GitHub</LinkCall>
  </footer>
</BaseLayout>

<style>
  section {
    padding-inline: var(--gutter);
    padding-block: clamp(5rem, 10vw, 10rem);
  }

  /* ── Hero ── */

  .hero {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-block: clamp(5rem, 8vw, 10rem) clamp(5rem, 10vw, 10rem);
  }

  .hero-heading {
    font-family: var(--font-display);
    font-weight: 200;
    font-size: var(--text-display-2);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tighter);
    margin: 0;
    max-width: 18ch;
    color: var(--color-ink);
  }

  .hero-deck {
    margin-block: 2.5rem 0;
    font-size: var(--text-xl);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
    max-width: var(--max-width-prose);
  }

  @media (max-width: 768px) {
    .hero-heading {
      font-size: var(--text-4xl);
    }
  }

  /* ── Foundations ── */

  .foundations {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    border-block-start: 1px solid var(--color-rule);
  }

  .foundations-heading {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-3xl);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 1.5rem;
    color: var(--color-ink);
  }

  .foundations-deck {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
    max-width: var(--max-width-prose);
  }

  .foundations-link {
    margin-block-start: 2rem;
  }

  /* ── Commons ── */

  .commons {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .commons-header {
    margin-block-end: clamp(3rem, 6vw, 5rem);
  }

  /* ── Labs ── */

  .labs {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    border-block-start: 1px solid var(--color-rule);
  }

  .labs-header {
    margin-block-end: clamp(3rem, 6vw, 5rem);
  }

  /* ── Close ── */

  .close {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-inline: var(--gutter);
    padding-block: 0 clamp(5rem, 10vw, 8rem);
  }
</style>
