---
import BaseLayout from "@/layouts/base.astro";
import { getClients, getTestimonials, getAwards, getResolvedHighlights } from "@/lib/collections";
import { cdnUrl } from "@/lib/cdn";

const clients = await getClients();
const testimonials = await getTestimonials();
const highlights = await getResolvedHighlights();
const awards = (await getAwards()).slice(0, 18);

const featuredHighlights = highlights.slice(0, 3);
---

<BaseLayout
  title="Significa — Design and Development Agency"
  description="We are a design and development agency building digital products that work beautifully. From strategy to code, we deliver user-centred platforms for ambitious businesses."
>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <h1>
        We are a <strong>design and development agency</strong> building digital products that work beautifully.
      </h1>
    </div>
  </section>

  <!-- Showreel -->
  <section class="showreel">
    <div class="showreel-inner">
      <div class="showreel-media" data-showreel>
        <video
          src="https://assets.significa.co/fcp-reel-w-subtitles-2cDmSH.mp4"
          width="1920"
          height="1080"
          loop
          muted
          playsinline
          data-showreel-video></video>
        <button class="showreel-cursor" type="button" data-showreel-cursor aria-label="Play showreel video">
          <span class="showreel-cursor-icon" aria-hidden="true">▶</span>
        </button>
      </div>
    </div>
  </section>

  <!-- Selected Highlights -->
  {
    featuredHighlights.length > 0 && (
      <section class="highlights-grid">
        <div class="highlights-grid-inner">
          {featuredHighlights.map((highlight) => {
            const entry = highlight.entry;
            if (!entry) return null;

            const href =
              highlight.collection === "projects"
                ? `/projects/${entry.id}`
                : highlight.collection === "blog"
                  ? `/blog/${entry.id}`
                  : `/playground/${entry.id}`;

            let thumbnail: string | undefined;
            if (highlight.collection === "projects") {
              const data = entry.data as unknown as { thumbnail?: string; heroImage?: string };
              thumbnail = data.thumbnail || data.heroImage;
            } else {
              const data = entry.data as unknown as { thumbnail?: string };
              thumbnail = data.thumbnail;
            }

            const subtitle =
              highlight.collection === "projects"
                ? (entry.data as unknown as { tagline?: string }).tagline
                : (entry.data as unknown as { description?: string }).description;

            return (
              <article class="highlight-card">
                <a href={href}>
                  {thumbnail && (
                    <div class="highlight-image">
                      <img
                        src={cdnUrl(thumbnail, { width: 800, quality: 80 })}
                        alt={entry.data.title}
                        width="800"
                        height="600"
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                  )}
                  <div class="highlight-content">
                    {highlight.label && <span class="highlight-label">{highlight.label}</span>}
                    <h3 class="highlight-title">{entry.data.title}</h3>
                    {subtitle && <p class="highlight-tagline">{subtitle}</p>}
                  </div>
                </a>
              </article>
            );
          })}
        </div>
        <div class="cta-container">
          <a href="/projects" class="cta-link">
            View all projects →
          </a>
        </div>
      </section>
    )
  }

  <!-- Services -->
  <section class="services">
    <div class="services-inner">
      <h2>
        When you work with us, you get our whole team to <strong>Think</strong>, <strong>Design</strong>,{" "}
        <strong>Develop</strong>, <strong>Launch</strong> and <strong>Scale</strong> your ideas into seamless digital experiences.
      </h2>
      <p class="services-description">
        Whether it's an <strong>e-commerce shop</strong>, a <strong>mobile app</strong>, a{" "}
        <strong>ticketing platform</strong>, or a <strong>design system</strong>, we'll build it with care and curiosity, backed
        by +10 years of expertise, recognised by +20 international awards.
      </p>
      <a href="/what-we-do" class="cta-button">Explore our services</a>
    </div>
  </section>

  <!-- Client Logos -->
  {
    clients.length > 0 && (
      <section class="clients">
        <div class="clients-inner">
          <ul>
            {clients.map((client) => (
              <li>
                {client.data.url ? (
                  <a href={client.data.url} target="_blank" rel="noopener noreferrer" title={client.data.name}>
                    <span class="client-name">{client.data.name}</span>
                  </a>
                ) : (
                  <span class="client-name">{client.data.name}</span>
                )}
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <!-- Testimonials -->
  {
    testimonials.length > 0 && (
      <section class="testimonials">
        <div class="testimonials-inner">
          <h2>We love what we do, and so do our clients.</h2>
          <div class="testimonials-grid">
            {testimonials.slice(0, 2).map((testimonial) => (
              <blockquote class="testimonial-card">
                <p class="testimonial-quote">{testimonial.data.quote}</p>
                <footer class="testimonial-author">
                  <cite>
                    <strong>{testimonial.data.author}</strong>
                    <span>
                      {testimonial.data.role} at {testimonial.data.company}
                    </span>
                  </cite>
                </footer>
              </blockquote>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- Awards -->
  {
    awards.length > 0 && (
      <section class="awards">
        <div class="awards-inner">
          <h2>International recognition.</h2>
          <ul class="awards-list">
            {awards.map((a) => (
              <li class="award-item">
                {a.url ? (
                  <a href={a.url} target="_blank" rel="noopener noreferrer">
                    <span class="award-name">{a.award}</span>
                    <span class="award-year">{a.year}</span>
                    <span class="award-project">{a.project?.data.client ?? a.project?.data.title}</span>
                  </a>
                ) : (
                  <span class="award-item-inner">
                    <span class="award-name">{a.award}</span>
                    <span class="award-year">{a.year}</span>
                    <span class="award-project">{a.project?.data.client ?? a.project?.data.title}</span>
                  </span>
                )}
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <!-- FAQs -->
  <section class="faqs">
    <div class="faqs-inner">
      <h2>Frequently asked questions</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary class="faq-question">What services do you offer?</summary>
          <p class="faq-answer">
            We offer end-to-end product development: strategy, UX/UI design, development, and ongoing support. We specialise in
            web and mobile applications, e-commerce platforms, and design systems.
          </p>
        </details>

        <details class="faq-item">
          <summary class="faq-question">How long does a typical project take?</summary>
          <p class="faq-answer">
            Project timelines vary based on scope and complexity. A typical project ranges from 8–16 weeks, but we'll provide a
            detailed timeline during our initial discovery phase.
          </p>
        </details>

        <details class="faq-item">
          <summary class="faq-question">What's your process like?</summary>
          <p class="faq-answer">
            We follow a collaborative, iterative approach: Think (strategy and planning), Design (UI/UX and prototyping),
            Develop (engineering and QA), Launch (deployment and handover), and Scale (optimisation and growth).
          </p>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Do you work with startups or enterprises?</summary>
          <p class="faq-answer">
            Both! We've partnered with ambitious startups and established enterprises across various industries. What matters
            most is shared ambition and a commitment to building something exceptional.
          </p>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Where are you based?</summary>
          <p class="faq-answer">
            We're based in Porto, Portugal, but we work with clients globally. We're experienced in remote collaboration and
            have processes in place to ensure seamless communication across time zones.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- Ask AI -->
  <section class="ask-ai">
    <div class="ask-ai-inner">
      <h2 class="ask-ai-heading">Ask AI about Significa</h2>
      <p class="ask-ai-description">Curious about us? Start a conversation with your favourite AI.</p>
      <div class="ask-ai-links">
        <a
          href="https://chat.openai.com/?q=Tell%20me%20about%20Significa%2C%20a%20product%20design%20and%20development%20studio%20based%20in%20Porto%2C%20Portugal.%20What%20do%20they%20do%2C%20who%20have%20they%20worked%20with%2C%20and%20what%20makes%20them%20stand%20out%3F"
          target="_blank"
          rel="noopener noreferrer"
          class="ai-link"
        >
          <span class="ai-link-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path
                d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.91 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a5.998 5.998 0 0 0-3.998 2.9 6.05 6.05 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.997-2.9 6.056 6.056 0 0 0-.747-7.073zM13.26 22.43a4.476 4.476 0 0 1-2.876-1.04l.141-.081 4.779-2.758a.795.795 0 0 0 .392-.681v-6.737l2.02 1.168a.071.071 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494zM3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.759a.771.771 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646zM2.34 7.896a4.485 4.485 0 0 1 2.366-1.973V11.6a.766.766 0 0 0 .388.676l5.815 3.355-2.02 1.168a.076.076 0 0 1-.071 0l-4.83-2.786A4.504 4.504 0 0 1 2.34 7.872zm16.597 3.855l-5.833-3.387L15.119 7.2a.076.076 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.407-.667zm2.01-3.023l-.141-.085-4.774-2.782a.776.776 0 0 0-.785 0L9.409 9.23V6.897a.066.066 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zm-12.64 4.135l-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08L8.704 5.46a.795.795 0 0 0-.393.681zm1.097-2.365l2.602-1.5 2.607 1.5v2.999l-2.597 1.5-2.607-1.5z"
                fill="currentColor"></path>
            </svg>
          </span>
          Ask ChatGPT
        </a>
        <a
          href="https://claude.ai/new?q=Tell%20me%20about%20Significa%2C%20a%20product%20design%20and%20development%20studio%20based%20in%20Porto%2C%20Portugal.%20What%20do%20they%20do%2C%20who%20have%20they%20worked%20with%2C%20and%20what%20makes%20them%20stand%20out%3F"
          target="_blank"
          rel="noopener noreferrer"
          class="ai-link"
        >
          <span class="ai-link-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path
                d="M16.009 3L9.664 21h-1.67L14.337 3h1.672zM5.376 13.78L2 10.404l1.18-1.18 3.378 3.376-1.18 1.18zm13.248 0l-1.18-1.18 3.376-3.376L22 10.404l-3.376 3.376z"
                fill="currentColor"></path>
            </svg>
          </span>
          Ask Claude
        </a>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="final-cta">
    <div class="final-cta-inner">
      <h2>We are ready to grow your business.</h2>
      <p class="final-cta-description">
        Are you? Let's get the conversation going — or keep browsing and see if we're the right fit.
      </p>
      <a href="/work-with-us" class="cta-button-large">Get in touch</a>
    </div>
  </section>
</BaseLayout>

<!-- Showreel cursor-following button — vanilla JS, no island needed -->
<script>
  function initShowreel() {
    const section = document.querySelector<HTMLElement>("[data-showreel]");
    const cursor = document.querySelector<HTMLButtonElement>("[data-showreel-cursor]");
    const video = document.querySelector<HTMLVideoElement>("[data-showreel-video]");
    if (!section || !cursor || !video) return;

    let isPlaying = false;

    function positionAt(e: MouseEvent) {
      if (!cursor) return;
      const x = e.clientX - cursor.offsetWidth / 2;
      const y = e.clientY - cursor.offsetHeight / 2;
      cursor.style.translate = `${x}px ${y}px`;
    }

    function updateCursorIcon() {
      if (!cursor) return;
      const icon = cursor.querySelector(".showreel-cursor-icon");
      if (icon) {
        icon.textContent = isPlaying ? "❚❚" : "▶";
      }
    }

    function toggleVideo() {
      if (!video) return;
      if (isPlaying) {
        video.pause();
        isPlaying = false;
      } else {
        video.play();
        isPlaying = true;
      }
      updateCursorIcon();
    }

    section.addEventListener("mouseenter", (e: MouseEvent) => {
      positionAt(e);
      cursor.style.opacity = "1";
      cursor.style.scale = "1";
    });

    section.addEventListener("mouseleave", () => {
      cursor.style.opacity = "0";
      cursor.style.scale = "0.5";
    });

    section.addEventListener("mousemove", (e: MouseEvent) => {
      positionAt(e);
    });

    section.addEventListener("click", toggleVideo);
    cursor.addEventListener("click", (e) => {
      e.stopPropagation();
      toggleVideo();
    });

    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    if (prefersReducedMotion.matches) {
      cursor.style.display = "none";
    }
    prefersReducedMotion.addEventListener("change", (e) => {
      cursor.style.display = e.matches ? "none" : "";
    });
  }

  initShowreel();
  document.addEventListener("astro:after-swap", initShowreel);
</script>

<style>
  /* ============================================================
     Hero
     ============================================================ */
  .hero {
    padding: 8rem var(--gutter) 4rem;
  }

  .hero-inner {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
  }

  .hero h1 {
    font-size: var(--text-3xl);
    font-weight: var(--weight-normal);
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .hero h1 strong {
    font-weight: var(--weight-semibold);
  }

  /* ============================================================
     Showreel
     ============================================================ */
  .showreel {
    padding: 0 var(--gutter) 4rem;
  }

  .showreel-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .showreel-media {
    position: relative;
    border-radius: 0.5rem;
    overflow: hidden;
    cursor: none;
  }

  .showreel-media video {
    width: 100%;
    height: auto;
    display: block;
  }

  .showreel-cursor {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 10;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--color-text);
    color: var(--color-surface);
    border: none;
    border-radius: 2rem;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    pointer-events: none;
    opacity: 0;
    scale: 0.5;
    transition:
      opacity var(--duration-fast) var(--ease-out),
      scale var(--duration-fast) cubic-bezier(0.34, 1.56, 0.64, 1);
    will-change: translate, scale;
    white-space: nowrap;
  }

  .showreel-cursor-icon {
    font-size: 0.625rem;
  }

  @media (hover: none) {
    .showreel-media {
      cursor: default;
    }

    .showreel-cursor {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%) !important;
      opacity: 1 !important;
      pointer-events: auto;
    }
  }

  /* ============================================================
     Highlights Grid
     ============================================================ */
  .highlights-grid {
    padding: 2rem var(--gutter) 4rem;
  }

  .highlights-grid-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .highlight-card a {
    display: block;
    text-decoration: none;
    color: var(--color-text);
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .highlight-card a:hover {
    opacity: 0.8;
  }

  .highlight-image {
    border-radius: 0.5rem;
    overflow: hidden;
    background: var(--color-surface-alt);
    margin-bottom: 1rem;
  }

  .highlight-image img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .highlight-card a:hover .highlight-image img {
    transform: scale(1.02);
  }

  .highlight-label {
    display: block;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .highlight-title {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    margin-bottom: 0.5rem;
  }

  .highlight-tagline {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  /* ============================================================
     Services
     ============================================================ */
  .services {
    padding: 4rem var(--gutter);
    background: var(--color-surface-alt);
  }

  .services-inner {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
    text-align: center;
  }

  .services-inner h2 {
    font-size: var(--text-2xl);
    font-weight: var(--weight-normal);
    line-height: var(--leading-tight);
    margin-bottom: 1.5rem;
  }

  .services-inner h2 strong {
    font-weight: var(--weight-semibold);
  }

  .services-description {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .services-description strong {
    color: var(--color-text);
    font-weight: var(--weight-medium);
  }

  /* ============================================================
     Clients
     ============================================================ */
  .clients {
    padding: 4rem var(--gutter);
  }

  .clients-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .clients ul {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    list-style: none;
  }

  .clients li a {
    color: var(--color-text);
    text-decoration: none;
    opacity: 0.6;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .clients li a:hover {
    opacity: 1;
  }

  .client-name {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    white-space: nowrap;
  }

  /* ============================================================
     Testimonials
     ============================================================ */
  .testimonials {
    padding: 4rem var(--gutter);
    background: var(--color-surface-alt);
  }

  .testimonials-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .testimonials-inner h2 {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    margin-bottom: 3rem;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .testimonial-card {
    background: var(--color-surface);
    padding: 2rem;
    border-radius: 0.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .testimonial-quote {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    margin-bottom: 2rem;
  }

  .testimonial-author cite {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .testimonial-author strong {
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
  }

  .testimonial-author span {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  /* ============================================================
     Awards
     ============================================================ */
  .awards {
    padding: 4rem var(--gutter);
  }

  .awards-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .awards-inner h2 {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    margin-bottom: 3rem;
  }

  .awards-list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
  }

  .award-item {
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-surface-alt);
  }

  .award-item a,
  .award-item-inner {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    text-decoration: none;
    color: var(--color-text);
    transition: opacity var(--duration-fast) var(--ease-out);
    height: 100%;
  }

  .award-item a:hover {
    opacity: 0.7;
  }

  .award-name {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
  }

  .award-year {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .award-project {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: auto;
  }

  /* ============================================================
     FAQs
     ============================================================ */
  .faqs {
    padding: 4rem var(--gutter);
    background: var(--color-surface-alt);
  }

  .faqs-inner {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
  }

  .faqs-inner h2 {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    margin-bottom: 3rem;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
  }

  .faq-item {
    border-bottom: 1px solid var(--color-border);
  }

  .faq-item:first-child {
    border-top: 1px solid var(--color-border);
  }

