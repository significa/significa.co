---
/**
 * Homepage
 *
 * The position. Built per the brand docs (see docs/brand/), not as a
 * conventional agency hero+grid+CTA stack. Sections, top to bottom:
 *
 *   1. Hero — the manifesto opening sentence, set as a statement.
 *   2. Featured project — DIA, told as the call we made (not features).
 *   3. Services as questions — three honest questions, not a 5-step ladder.
 *   4. Manifesto moment — single line at display scale, italic.
 *   5. Wrong-for-you — anti-positioning, five honest disclosures.
 *   6. Recent work — compact editorial index, no metric overlays.
 *
 * Italics are reserved for the manifesto moment (and the footer pull
 * quote). Italic-on-serif at heading sizes is hard to scan; we earn its
 * use by making it rare.
 *
 * Links are not underlined by default. UI affordances use `.link-call`
 * — text + arrow that translates on hover with a slow editorial ease.
 */

import BaseLayout from "@/layouts/base.astro";
import Egg from "@/components/ui/egg.astro";
import { getEntry } from "astro:content";
import { getProjects } from "@/lib/collections";
import { cdnUrl } from "@/lib/cdn";
import { webSiteJsonLd } from "@/lib/seo";

const featured = await getEntry("projects", "dia");
const allProjects = (await getProjects()).filter((p) => p.id !== "dia").slice(0, 8);

const services = [
  {
    n: "01",
    q: "How do you decide what to push back on?",
    a: "We push back when the spec asks for a feature that solves the wrong problem, when the deadline forces a choice the team will regret, or when the brief assumes a user we have evidence doesn't exist. We don't push back to perform cleverness. The test is whether the project is better in six months because we said something now.",
  },
  {
    n: "02",
    q: "When do you say no?",
    a: "When the work would keep people busy and produce something nobody would be proud of. When the budget forces shortcuts we couldn't defend later. When the relationship is structured to make honest feedback impossible. Saying no to one project is how we stay capable of saying yes to a different one.",
  },
  {
    n: "03",
    q: "What does it cost when we're wrong?",
    a: "We're wrong sometimes. The cost shows up in extra rounds, missed assumptions, or features that didn't earn their place. We absorb that cost when it's ours and we say so. We don't externalise it as scope creep or invoice it as additional discovery.",
  },
];

const wrongFor = [
  {
    n: "I.",
    head: "You need someone to nod and ship the spec.",
    body: "We argue. We push back. We will tell you when we think you're solving the wrong problem. If that's friction you don't want, we're not it.",
  },
  {
    n: "II.",
    head: "The timeline can't accommodate honest discovery.",
    body: "Real understanding takes weeks, not days. If the launch date can't move, the discovery shrinks, and discovery is where the work earns its value.",
  },
  {
    n: "III.",
    head: "The budget assumes design and engineering are separate line items.",
    body: "We don't subcontract design or hand off engineering. The team is one team. Splitting the budget kills the model that makes the work good.",
  },
  {
    n: "IV.",
    head: "“Just make it look better” is the brief.",
    body: "Visual polish without a clear what-this-is-for is decoration. We do beauty in service of decisions, not as a finish.",
  },
  {
    n: "V.",
    head: "The decision-maker isn't in the room.",
    body: "We don't sell things to people who then pitch them to the people who actually decide. Direct access changes what's possible.",
  },
];

const featuredMeta = [
  { label: "Client", value: "The Fertility Partnership" },
  { label: "Year", value: "2022" },
  { label: "Role", value: "Strategy, design, build" },
  { label: "Awards", value: "Red Dot · iF · German Gold · Good Design · European Gold" },
];

const structuredData = [webSiteJsonLd()];
---

<BaseLayout
  title="Significa — A studio in Porto"
  description="Significa is a studio of designers and engineers in Porto. We work on complex digital products with clients who want them solved with care."
  structuredData={structuredData}
>
  <!-- ============================================================
       1. Hero — the position. One sentence. Lots of room. Roman.
       ============================================================ -->
  <section class="hero" aria-labelledby="hero-h">
    <p class="eyebrow">A studio in Porto <span class="eyebrow-sep">/</span> Since 2015</p>
    <h1 id="hero-h" class="hero-statement">
      We exist to prove that rigour and beauty are not opposites.
    </h1>
    <p class="hero-deck">
      Designers and engineers working as one team. We take on the kind of complex problems most
      teams retreat from, and we refuse to let the complexity be an excuse for mediocrity.
    </p>
  </section>

  <!-- ============================================================
       2. Featured project — DIA. Image earns its room.
       Structured metadata grid alongside the prose.
       ============================================================ -->
  {
    featured && (
      <section class="featured" aria-labelledby="featured-h">
        <div class="featured-inner">
          <p class="eyebrow">
            Recent work <span class="eyebrow-sep">/</span> {featured.data.client}{" "}
            <span class="eyebrow-sep">/</span> 2022
          </p>

          <h2 id="featured-h" class="featured-statement">
            The brief asked for a period tracker. We argued for a fertility companion.
          </h2>

          <figure class="featured-figure">
            <div class="featured-image">
              <img
                src={cdnUrl(featured.data.thumbnail, { width: 1800, quality: 88 })}
                alt={featured.data.altText ?? `${featured.data.title} — ${featured.data.tagline}`}
                width="1800"
                height="1200"
                loading="lazy"
                decoding="async"
              />
            </div>
          </figure>

          <div class="featured-grid">
            <div class="featured-prose">
              <p>
                TFP came to us with a request for another player in a market already full of period
                trackers. We pushed for a deeper product — daily logs, fertility forecasting,
                education, a tone of voice that felt like a friend rather than a database. The
                argument took weeks. The team agreed.
              </p>
              <p>
                Five international design awards later, including a <em>Red Dot</em>, the case for
                arguing back was clear.
              </p>
            </div>

            <dl class="featured-meta">
              {featuredMeta.map((m) => (
                <div class="featured-meta-row">
                  <dt class="featured-meta-label">{m.label}</dt>
                  <dd class="featured-meta-value">{m.value}</dd>
                </div>
              ))}
              <div class="featured-meta-link-row">
                <a href={`/projects/${featured.id}`} class="link-call">
                  <span class="link-label">Read the case study</span>
                  <span class="link-arrow" aria-hidden="true">&rarr;</span>
                </a>
              </div>
            </dl>
          </div>
        </div>
      </section>
    )
  }

  <!-- ============================================================
       3. Services as questions. Roman heads (italics overused on serif
       at this size). The question still does the work.
       ============================================================ -->
  <section class="services" aria-labelledby="services-h">
    <header class="services-header">
      <p class="eyebrow">What working with us means</p>
      <h2 id="services-h" class="section-statement">Three questions worth answering before we start.</h2>
      <p class="section-deck">
        Most agencies sell a process. We sell the judgment that goes into the work. The deliverables
        come from the answers below, not the other way round.
      </p>
    </header>

    <ol class="qa-list" role="list">
      {
        services.map((s) => (
          <li class="qa">
            <p class="qa-num">{s.n}</p>
            <h3 class="qa-q">{s.q}</h3>
            <p class="qa-a">{s.a}</p>
          </li>
        ))
      }
    </ol>

    <p class="services-link-row">
      <a href="/services" class="link-call">
        <span class="link-label">How we actually deliver</span>
        <span class="link-arrow" aria-hidden="true">&rarr;</span>
      </a>
    </p>
  </section>

  <!-- ============================================================
       4. Manifesto moment — display-2 italic. The one earned italic.
       ============================================================ -->
  <section class="moment" aria-labelledby="moment-h">
    <h2 id="moment-h" class="moment-line">
      <em>Disagreement<br />is the work.</em>
    </h2>
    <p class="moment-attr">
      <Egg variant="fill" class="moment-egg" />
      &nbsp; From the North Star <span class="eyebrow-sep">/</span>
      <a href="/about" class="moment-link">read what we believe</a>
    </p>
  </section>

  <!-- ============================================================
       5. Wrong-for-you. Roman heads. The list is doing the work.
       ============================================================ -->
  <section class="wrong" aria-labelledby="wrong-h">
    <header class="wrong-header">
      <p class="eyebrow">Honest disclosure</p>
      <h2 id="wrong-h" class="section-statement">We&rsquo;re the wrong choice when&hellip;</h2>
      <p class="section-deck">
        Saying yes to everything is how a studio loses what makes it choose-able. The list below is
        what we won&rsquo;t pretend to be. If any of it applies to your project, we&rsquo;ll save us
        both the conversation.
      </p>
    </header>

    <ol class="wrong-list" role="list">
      {
        wrongFor.map((w) => (
          <li class="wrong-row">
            <p class="wrong-num">{w.n}</p>
            <h3 class="wrong-head">&hellip;{w.head}</h3>
            <p class="wrong-body">{w.body}</p>
          </li>
        ))
      }
    </ol>
  </section>

  <!-- ============================================================
       6. Recent work — compact editorial index. No leader line, no
       per-row borders. Hover tints the row, shifts text colour, and
       reveals an accent egg sliding in from the right.
       ============================================================ -->
  {
    allProjects.length > 0 && (
      <section class="index" aria-labelledby="index-h">
        <header class="index-header">
          <p class="eyebrow">More work</p>
          <h2 id="index-h" class="section-statement">Recent projects.</h2>
        </header>

        <ol class="index-list" role="list">
          {allProjects.map((p, i) => (
            <li class="index-row">
              <a href={`/projects/${p.id}`} class="index-link">
                <span class="index-num">{String(i + 2).padStart(2, "0")}</span>
                <span class="index-title">{p.data.title}</span>
                <span class="index-tagline">{p.data.tagline}</span>
                <span class="index-year">{new Date(p.data.date).getFullYear()}</span>
                <span class="index-mark" aria-hidden="true">&rarr;</span>
              </a>
            </li>
          ))}
        </ol>

        <p class="index-link-row">
          <a href="/projects" class="link-call">
            <span class="link-label">All work</span>
            <span class="link-arrow" aria-hidden="true">&rarr;</span>
          </a>
        </p>
      </section>
    )
  }
</BaseLayout>

<style>
  /* ============================================================
     Page rhythm
     ============================================================ */

  section {
    padding-inline: var(--gutter);
    padding-block: clamp(5rem, 10vw, 10rem);
  }

  /* ============================================================
     Eyebrow — mono small label, no eggs. Slash separators.
     ============================================================ */

  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    line-height: var(--leading-relaxed);
    margin: 0 0 2.5rem;
  }

  .eyebrow-sep {
    color: var(--color-ink-faint);
    margin-inline: 0.35em;
  }

  /* ============================================================
     Section statement + deck
     ============================================================ */

  .section-statement {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-3xl);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    margin: 0;
    max-width: 28ch;
    color: var(--color-ink);
  }

  .section-deck {
    margin-block: 1.5rem 0;
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
    max-width: var(--max-width-prose);
  }

  /* ============================================================
     link-call — UI affordance. No underline. Arrow translates on hover
     with a slow editorial ease. Color shifts to accent.
     ============================================================ */

  .link-call {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5em;
    color: var(--color-ink);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .link-call:hover {
    color: var(--color-accent);
  }

  .link-arrow {
    display: inline-block;
    transition: transform var(--duration-slower) var(--ease-editorial);
  }

  .link-call:hover .link-arrow {
    transform: translateX(0.45em);
  }

  /* ============================================================
     1. Hero — Roman, no italics. The line is the line.
     ============================================================ */

  .hero {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-block: clamp(5rem, 12vw, 12rem);
  }

  .hero-statement {
    font-family: var(--font-display);
    font-weight: 200;
    font-size: var(--text-display-1);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tighter);
    margin: 0;
    max-width: 18ch;
    color: var(--color-ink);
  }

  .hero-deck {
    margin-top: 3rem;
    font-size: var(--text-xl);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
    max-width: var(--max-width-prose);
  }

  /* ============================================================
     2. Featured project — image full-width, prose + structured meta below
     ============================================================ */

  .featured {
    /* On paper, no gray container. The image is the centerpiece. */
  }

  .featured-inner {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .featured-statement {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-4xl);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 clamp(3rem, 6vw, 5rem);
    max-width: 22ch;
    color: var(--color-ink);
  }

  .featured-figure {
    margin: 0 0 clamp(3rem, 6vw, 5rem);
  }

  .featured-image {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border-radius: var(--radius-image);
    background: var(--color-paper-alt);
  }

  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--duration-slowest) var(--ease-editorial);
  }

  .featured-image:hover img {
    transform: scale(1.015);
  }

  .featured-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .featured-prose p {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    margin-block: 0 1.25em;
    max-width: 42ch;
  }

  .featured-prose p:last-child {
    margin-bottom: 0;
  }

  .featured-prose em {
    font-style: italic;
    color: var(--color-ink);
  }

  .featured-meta {
    margin: 0;
    display: grid;
    gap: 0;
    border-top: 1px solid var(--color-rule);
  }

  .featured-meta-row {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 1.5rem;
    padding-block: 0.95rem;
    border-bottom: 1px solid var(--color-rule);
    align-items: baseline;
  }

  .featured-meta-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    margin: 0;
    line-height: var(--leading-relaxed);
  }

  .featured-meta-value {
    font-size: var(--text-sm);
    color: var(--color-ink);
    line-height: var(--leading-normal);
    margin: 0;
  }

  .featured-meta-link-row {
    margin-top: 1.75rem;
  }

  @media (max-width: 880px) {
    .featured-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .featured-statement {
      font-size: var(--text-3xl);
    }
  }

  /* ============================================================
     3. Services as questions. Roman heads.
     ============================================================ */

  .services {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .services-header {
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .qa-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .qa {
    display: grid;
    grid-template-columns: 4rem 1fr;
    grid-template-rows: auto auto;
    column-gap: 2rem;
    row-gap: 1rem;
    padding-block: 3rem;
    border-top: 1px solid var(--color-rule);
  }

  .qa:last-child {
    border-bottom: 1px solid var(--color-rule);
  }

  .qa-num {
    grid-row: 1 / 3;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-accent);
    margin: 0;
    line-height: var(--leading-relaxed);
  }

  .qa-q {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-2xl);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    margin: 0;
    color: var(--color-ink);
  }

  .qa-a {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--color-ink);
    margin: 0;
    max-width: 56ch;
  }

  .services-link-row {
    margin-top: 3rem;
  }

  @media (max-width: 720px) {
    .qa {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .qa-num {
      grid-row: auto;
    }
  }

  /* ============================================================
     4. Manifesto moment — the only italic display on the page.
     ============================================================ */

  .moment {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-block: clamp(7rem, 16vw, 16rem);
    text-align: center;
  }

  .moment-line {
    font-family: var(--font-display);
    font-weight: 400;
    font-style: italic;
    font-size: var(--text-display-2);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tighter);
    margin: 0;
    color: var(--color-ink);
  }

  .moment-attr {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    margin-top: 4rem;
    display: inline-flex;
    align-items: center;
  }

  .moment-egg {
    color: var(--color-accent);
    height: 0.85em;
  }

  .moment-link {
    color: inherit;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .moment-link:hover {
    color: var(--color-accent);
  }

  /* ============================================================
     5. Wrong-for-you. Roman heads.
     ============================================================ */

  .wrong {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .wrong-header {
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .wrong-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .wrong-row {
    display: grid;
    grid-template-columns: 4rem 1fr;
    grid-template-rows: auto auto;
    column-gap: 2rem;
    row-gap: 0.85rem;
    padding-block: 2.5rem;
    border-top: 1px solid var(--color-rule);
  }

  .wrong-row:last-child {
    border-bottom: 1px solid var(--color-rule);
  }

  .wrong-num {
    grid-row: 1 / 3;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-accent);
    margin: 0;
    line-height: var(--leading-relaxed);
    font-variant-numeric: tabular-nums;
  }

  .wrong-head {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-xl);
    line-height: var(--leading-snug);
    margin: 0;
    color: var(--color-ink);
  }

  .wrong-body {
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
    margin: 0;
    max-width: 56ch;
  }

  @media (max-width: 720px) {
    .wrong-row {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .wrong-num {
      grid-row: auto;
    }
  }

  /* ============================================================
     6. Recent work index — no leader, no per-row borders, hover
     fills the row and reveals an accent egg from the right.
     ============================================================ */

  .index {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .index-header {
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .index-list {
    list-style: none;
    margin: 0;
    padding: 0;
    /* Single hairline at the top of the list. The rows themselves
       float on rhythm, not on per-row rules. */
    border-top: 1px solid var(--color-rule);
  }

  .index-row + .index-row {
    /* No per-row border. Spacing alone defines the rhythm. */
  }

  .index-list:last-child {
    border-bottom: 1px solid var(--color-rule);
  }

  /* The link is the row. Grid: number / title / tagline / year / mark.
     The mark column is reserved at all times so hover doesn't shift layout. */
  .index-link {
    display: grid;
    grid-template-columns: 3rem auto 1fr auto 1.5rem;
    align-items: baseline;
    column-gap: 1.5rem;
    padding-block: 1.4rem;
    padding-inline: 0.5rem;
    color: var(--color-ink);
    transition:
      background-color var(--duration-normal) var(--ease-out),
      color var(--duration-normal) var(--ease-out);
    margin-inline: -0.5rem;
  }

  .index-link:hover {
    background: var(--color-paper-alt);
    color: var(--color-accent);
  }

  .index-num {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    font-variant-numeric: tabular-nums;
    transition: color var(--duration-normal) var(--ease-out);
  }

  .index-link:hover .index-num {
    color: var(--color-accent);
  }

  .index-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-xl);
    line-height: 1;
    color: var(--color-ink);
    transition: color var(--duration-normal) var(--ease-out);
  }

  .index-link:hover .index-title {
    color: var(--color-accent);
  }

  .index-tagline {
    font-size: var(--text-sm);
    color: var(--color-ink-faint);
    text-align: right;
    line-height: var(--leading-snug);
    transition: color var(--duration-normal) var(--ease-out);
    max-width: 36ch;
    justify-self: end;
  }

  .index-link:hover .index-tagline {
    color: var(--color-ink-muted);
  }

  .index-year {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    font-variant-numeric: tabular-nums;
    min-width: 3rem;
    text-align: right;
    transition: color var(--duration-normal) var(--ease-out);
  }

  .index-link:hover .index-year {
    color: var(--color-accent);
  }

