---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/base.astro";
import { mdxComponents } from "@/components/mdx/components";

export async function getStaticPaths() {
  const pages = await getCollection("pages");

  // Validate no slug collisions with reserved routes
  const reserved = ["blog", "projects", "labs", "handbook", "about", "services", "say-hello", "b-corp"];

  for (const page of pages) {
    const topSegment = page.id.split("/")[0];
    if (reserved.includes(topSegment)) {
      throw new Error(`Page "${page.id}" collides with reserved route /${topSegment}. Rename it.`);
    }
  }

  return pages.map((page) => ({
    params: { slug: page.id },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content } = await render(page);

const seo = page.data.seo;
const title = seo?.metaTitle ?? page.data.title;
const description = seo?.metaDescription ?? `${page.data.title} — Significa`;
---

<BaseLayout title={title} description={description} ogImage={seo?.ogImage}>
  <article>
    <h1>{page.data.title}</h1>
    <Content components={mdxComponents} />
  </article>
</BaseLayout>
