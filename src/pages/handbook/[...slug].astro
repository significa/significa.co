---
/**
 * /handbook/[...slug] — Handbook page
 *
 * Editorial register. Eyebrow meta, display heading, prose.css body.
 * Sidebar navigation grouped by collection. No breadcrumbs (they
 * conflict with the eyebrow). Prev/next navigation at the bottom.
 */

import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/base.astro";
import Eyebrow from "@/components/ui/eyebrow.astro";
import LinkCall from "@/components/ui/link-call.astro";
import { mdxComponents } from "@/components/mdx/components";
import { getHandbookIndex, getHandbookChildren, getHandbookPages } from "@/lib/collections";
import { cdnUrl, cdnSrcset, DEFAULT_QUALITY } from "@/lib/cdn";

export async function getStaticPaths() {
  const pages = await getCollection("handbook");
  return pages.map((page) => ({
    params: { slug: page.id },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content } = await render(page);

const seo = page.data.seo;
const title = seo?.metaTitle ?? `${page.data.title} — Handbook`;
const description = seo?.metaDescription ?? page.data.description ?? `${page.data.title} — Significa Handbook`;

const isChild = page.id.includes("/");
const parentId = isChild ? page.id.split("/").slice(0, -1).join("/") : null;

const [children, indexGroups, allPages] = await Promise.all([
  getHandbookChildren(page.id),
  getHandbookIndex(),
  getHandbookPages(),
]);

// Build flat ordered list for prev/next
const flatPages = indexGroups.flatMap(({ pages }) =>
  pages.flatMap(({ page: p, children: c }) => [p, ...c])
);
const currentIdx = flatPages.findIndex((p) => p.id === page.id);
const prevPage = currentIdx > 0 ? flatPages[currentIdx - 1] : null;
const nextPage = currentIdx < flatPages.length - 1 ? flatPages[currentIdx + 1] : null;

const formattedDate = page.data.date.toLocaleDateString("en-GB", {
  year: "numeric",
  month: "long",
});
---

<BaseLayout title={title} description={description} ogImage={seo?.ogImage ?? page.data.coverImage}>
  <div class="layout">
    <!-- ============================================================
         Sidebar
         ============================================================ -->
    <nav class="sidebar" aria-label="Handbook navigation">
      <a href="/handbook" class="sidebar-home">
        <span class="sidebar-home-arrow" aria-hidden="true">&larr;</span>
        Handbook
      </a>

      <div class="nav-groups">
        {
          indexGroups.map(({ group, pages }) => {
            if (pages.length === 0) return null;

            const isActiveGroup = pages.some(
              ({ page: navPage, children: navChildren }) =>
                navPage.id === page.id || parentId === navPage.id || navChildren.some((child) => child.id === page.id)
            );

            return (
              <details class="nav-group" open={isActiveGroup || undefined}>
                <summary class="nav-group-label">{group.data.title}</summary>
                <ul role="list" class="nav-list">
                  {pages.map(({ page: navPage, children: navChildren }) => {
                    const isActivePage = navPage.id === page.id;
                    const isActiveParent = parentId === navPage.id;
                    const isExpanded = isActivePage || isActiveParent;

                    return (
                      <li>
                        <a
                          href={`/handbook/${navPage.id}`}
                          class:list={["nav-link", { active: isActivePage, "has-children": navChildren.length > 0 }]}
                          aria-current={isActivePage ? "page" : undefined}
                          data-expanded={navChildren.length > 0 ? isExpanded : undefined}
                        >
                          <span class="nav-link-text">{navPage.data.title}</span>
                          {navChildren.length > 0 && (
                            <svg
                              class="nav-chevron"
                              width="10"
                              height="10"
                              viewBox="0 0 10 10"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="1.5"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              aria-hidden="true"
                            >
                              <polyline points="2 3.5 5 6.5 8 3.5" />
                            </svg>
                          )}
                        </a>
                        {navChildren.length > 0 && (
                          <ul
                            role="list"
                            class="nav-children"
                            data-children-for={navPage.id}
                            data-open={isExpanded ? "true" : "false"}
                          >
                            {navChildren.map((child) => {
                              const isActiveChild = child.id === page.id;
                              return (
                                <li>
                                  <a
                                    href={`/handbook/${child.id}`}
                                    class:list={["nav-child-link", { active: isActiveChild }]}
                                    aria-current={isActiveChild ? "page" : undefined}
                                  >
                                    {child.data.title}
                                  </a>
                                </li>
                              );
                            })}
                          </ul>
                        )}
                      </li>
                    );
                  })}
                </ul>
              </details>
            );
          })
        }
      </div>
    </nav>

    <!-- ============================================================
         Main content
         ============================================================ -->
    <article class="content">
      <header class="page-header">
        <Eyebrow>
          Last updated <span class="sep">/</span>
          <time datetime={page.data.date.toISOString()}>{formattedDate}</time>
        </Eyebrow>
        <h1 class="page-title">{page.data.title}</h1>
        {page.data.description && <p class="page-deck">{page.data.description}</p>}
      </header>

      {
        page.data.coverImage && (
          <div class="cover-image">
            <img
              src={cdnUrl(page.data.coverImage, { width: 1200, quality: DEFAULT_QUALITY })}
              srcset={cdnSrcset(page.data.coverImage, { quality: DEFAULT_QUALITY })}
              sizes="(max-width: 768px) 100vw, 720px"
              alt=""
              loading="eager"
              fetchpriority="high"
              decoding="sync"
            />
          </div>
        )
      }

      <div class="prose">
        <Content components={mdxComponents} />
      </div>

      {
        children.length > 0 && (
          <aside class="child-pages" aria-labelledby="children-h">
            <h2 id="children-h" class="children-label">In this section</h2>
            <ul role="list" class="children-list">
              {children.map((child) => (
                <li>
                  <a href={`/handbook/${child.id}`} class="children-link">
                    <span class="children-title">{child.data.title}</span>
                    {child.data.description && <span class="children-desc">{child.data.description}</span>}
                  </a>
                </li>
              ))}
            </ul>
          </aside>
        )
      }

      <!-- Prev / Next -->
      <nav class="page-nav" aria-label="Article navigation">
        {
          prevPage ? (
            <a href={`/handbook/${prevPage.id}`} class="page-nav-link page-nav-prev">
              <span class="page-nav-label">&larr; Previous</span>
              <span class="page-nav-title">{prevPage.data.title}</span>
            </a>
          ) : <div />
        }
        {
          nextPage && (
            <a href={`/handbook/${nextPage.id}`} class="page-nav-link page-nav-next">
              <span class="page-nav-label">Next &rarr;</span>
              <span class="page-nav-title">{nextPage.data.title}</span>
            </a>
          )
        }
      </nav>
    </article>
  </div>

  <script>
    function initSidebar() {
      document.querySelectorAll<HTMLAnchorElement>(".nav-link.has-children").forEach((link) => {
        const fresh = link.cloneNode(true) as HTMLAnchorElement;
        link.parentNode!.replaceChild(fresh, link);

        fresh.addEventListener("click", (e) => {
          const childrenList = fresh.parentElement?.querySelector<HTMLElement>(".nav-children");
          if (!childrenList) return;

          const isOpen = childrenList.dataset.open === "true";

          if (isOpen) {
            e.preventDefault();
            childrenList.dataset.open = "false";
            fresh.dataset.expanded = "false";
          } else {
            childrenList.dataset.open = "true";
            fresh.dataset.expanded = "true";
          }
        });
      });
    }

    document.addEventListener("DOMContentLoaded", initSidebar);
    document.addEventListener("astro:after-swap", initSidebar);
  </script>
</BaseLayout>

<style>
  .layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    max-width: var(--max-width-wide);
    margin-inline: auto;
    padding-inline: var(--gutter);
    padding-block: clamp(3rem, 6vw, 5rem) clamp(5rem, 10vw, 8rem);
    gap: 4rem;
    align-items: start;
  }

  /* ============================================================
     Sidebar
     ============================================================ */

  .sidebar {
    position: sticky;
    top: 2rem;
    max-height: calc(100vh - 4rem);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    scrollbar-width: none;
  }

  .sidebar::-webkit-scrollbar {
    display: none;
  }

  .sidebar-home {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4em;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .sidebar-home:hover {
    color: var(--color-ink);
  }

  .sidebar-home-arrow {
    transition: transform var(--duration-normal) var(--ease-editorial);
  }

  .sidebar-home:hover .sidebar-home-arrow {
    transform: translateX(-0.25em);
  }

  .nav-groups {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .nav-group {
    border: none;
    padding: 0;
    margin: 0;
  }

  .nav-group-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-normal);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    margin: 0 0 0.375rem;
    list-style: none;
    cursor: pointer;
    user-select: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .nav-group-label:hover {
    color: var(--color-ink);
  }

  .nav-group-label::-webkit-details-marker {
    display: none;
  }

  .nav-group-label::after {
    content: "";
    display: block;
    width: 5px;
    height: 5px;
    border-right: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    transform: rotate(45deg);
    transition: transform var(--duration-fast) var(--ease-out);
    flex-shrink: 0;
  }

  .nav-group[open] > .nav-group-label::after {
    transform: rotate(225deg);
  }

  .nav-group:not([open]) > .nav-list {
    display: none;
  }

  .nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .nav-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: var(--text-sm);
    padding: 0.25rem 0;
    color: var(--color-ink-muted);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .nav-link-text {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .nav-chevron {
    flex-shrink: 0;
    opacity: 0.5;
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .nav-link[data-expanded="true"] > .nav-chevron {
    transform: rotate(180deg);
  }

  .nav-link:hover {
    color: var(--color-ink);
  }

  .nav-link.active {
    color: var(--color-accent);
    font-weight: var(--weight-medium);
  }

  .nav-children {
    list-style: none;
    padding: 0;
    margin: 0.25rem 0 0.25rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    border-left: 1px solid var(--color-rule);
    padding-left: 0.75rem;
  }

  .nav-children[data-open="false"] {
    display: none;
  }

  .nav-child-link {
    display: block;
    font-size: var(--text-sm);
    padding-block: 0.2rem;
    color: var(--color-ink-muted);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .nav-child-link:hover {
    color: var(--color-ink);
  }

  .nav-child-link.active {
    color: var(--color-accent);
    font-weight: var(--weight-medium);
  }

  /* ============================================================
     Content
     ============================================================ */

  .content {
    min-width: 0;
    max-width: 46rem;
    margin-inline: auto;
  }

  /* Page header */

  .page-header {
    margin-block-end: 2.5rem;
  }

  .page-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-3xl);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    margin: 0;
    color: var(--color-ink);
  }

  .page-deck {
    margin-block: 1rem 0;
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
  }

  /* Cover image */

  .cover-image {
    margin-block-end: 2.5rem;
    border-radius: var(--radius-image);
    overflow: hidden;
  }

  .cover-image img {
    width: 100%;
    height: auto;
    max-height: 320px;
    object-fit: cover;
    display: block;
  }

  /* Child pages */

  .child-pages {
    margin-block-start: 3rem;
    padding-block-start: 2rem;
    border-block-start: 1px solid var(--color-rule);
  }

  .children-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-normal);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    margin: 0 0 1rem;
  }

  .children-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .children-link {
    display: block;
    padding: 0.75rem 1rem;
    margin-inline: -1rem;
    border-radius: 6px;
    color: var(--color-ink);
    transition:
      background-color var(--duration-normal) var(--ease-out),
      color var(--duration-normal) var(--ease-out);
  }

  .children-link:hover {
    background: var(--color-paper-alt);
    color: var(--color-accent);
  }

  .children-title {
    display: block;
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
  }

  .children-desc {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    margin-block-start: 0.15rem;
  }

  /* Prev / Next navigation */

  .page-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-block-start: 3rem;
    padding-block-start: 2rem;
    border-block-start: 1px solid var(--color-rule);
  }

  .page-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem;
    margin-inline: -1rem;
    border-radius: 6px;
    color: var(--color-ink);
    transition:
      background-color var(--duration-normal) var(--ease-out),
      color var(--duration-normal) var(--ease-out);
  }

  .page-nav-link:hover {
    background: var(--color-paper-alt);
    color: var(--color-accent);
  }

  .page-nav-next {
    text-align: right;
    grid-column: 2;
  }

  .page-nav-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
  }

  .page-nav-link:hover .page-nav-label {
    color: var(--color-accent);
  }

  .page-nav-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
  }

  /* ============================================================
     Responsive
     ============================================================ */

  @media (max-width: 768px) {
    .layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .sidebar {
      position: static;
      max-height: none;
      overflow: visible;
    }

    .page-title {
      font-size: var(--text-2xl);
    }

    .page-nav {
      grid-template-columns: 1fr;
    }

    .page-nav-next {
      text-align: left;
      grid-column: 1;
    }
  }
</style>
