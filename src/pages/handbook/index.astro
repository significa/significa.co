---
import BaseLayout from "@/layouts/base.astro";
import { getHandbookIndex } from "@/lib/collections";
import HandbookSearch from "@/components/handbook-search.astro";
import HandbookGroup from "@/components/handbook-group.astro";

const groups = await getHandbookIndex();
---

<BaseLayout title="Handbook — Significa" description="How we work, what we believe in, and everything in between.">
  <div class="page">
    <header class="hero">
      <h1>Handbook</h1>
      <p>How we work, what we believe in, and everything in between.</p>
      <div class="search">
        <HandbookSearch />
      </div>
    </header>

    <div class="groups">
      {
        groups.map(({ group, pages }) =>
          pages.length > 0 ? <HandbookGroup groupTitle={group.data.title} groupId={group.id} pages={pages} /> : null
        )
      }
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: var(--max-width-narrow);
    margin-inline: auto;
    padding-inline: var(--gutter);
    padding-block: 4rem 6rem;
  }

  .hero {
    margin-block-end: 4rem;
  }

  .hero h1 {
    font-size: var(--text-3xl);
    margin-block-end: 0.5rem;
  }

  .hero p {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-block-end: 1.5rem;
  }

  .search {
    max-width: 28rem;
  }

  .groups {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }
</style>
