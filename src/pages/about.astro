---
import BaseLayout from "@/layouts/base.astro";
import { getClients, getTestimonials } from "@/lib/collections";

const clients = await getClients();
const testimonials = await getTestimonials();
---

<BaseLayout
  title="Who we are"
  description="Significa is a digital product agency based in Porto, Portugal. We design and build products for companies that care about craft."
>
  <!-- Intro -->
  <section class="intro">
    <div class="intro-inner">
      <h1>
        <span class="intro-muted">We're a digital product agency based in Porto.</span>{" "}
        We design and build digital products that people genuinely enjoy using.
      </h1>
    </div>
  </section>

  <!-- Values -->
  <section class="values">
    <div class="values-inner">
      <div class="values-grid">
        <div class="value-card">
          <h2 class="value-title">Craft</h2>
          <p class="value-description">
            Every pixel, every interaction, every line of code — we care about the details because users feel them even when
            they can't name them.
          </p>
        </div>
        <div class="value-card">
          <h2 class="value-title">Honesty</h2>
          <p class="value-description">
            We tell you what we think, not what you want to hear. If something won't work, we say so early — before it costs
            time and money.
          </p>
        </div>
        <div class="value-card">
          <h2 class="value-title">Ownership</h2>
          <p class="value-description">
            Small teams, high accountability. Everyone involved in a project owns the outcome, not just their slice of it.
          </p>
        </div>
        <div class="value-card">
          <h2 class="value-title">Simplicity</h2>
          <p class="value-description">
            The best solution is usually the simplest one. We resist complexity and fight feature bloat on behalf of the people
            who use what we build.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Numbers -->
  <section class="numbers">
    <div class="numbers-inner">
      <dl class="numbers-grid">
        <div class="number-item">
          <dt>Founded</dt>
          <dd>2015</dd>
        </div>
        <div class="number-item">
          <dt>Team members</dt>
          <dd>20+</dd>
        </div>
        <div class="number-item">
          <dt>Projects delivered</dt>
          <dd>80+</dd>
        </div>
        <div class="number-item">
          <dt>Based in</dt>
          <dd>Porto</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- Team photo -->
  <section class="team-photo">
    <div class="team-photo-inner">
      <img
        src="https://assets.significa.co/website/test-TKzoOc.png"
        alt="The Significa team"
        width="1920"
        height="1080"
        loading="lazy"
        decoding="async"
      />
    </div>
  </section>

  <!-- Testimonials -->
  {
    testimonials.length > 0 && (
      <section class="testimonials">
        <div class="testimonials-inner">
          <h2 class="section-heading">What our clients say</h2>
          <div class="testimonials-grid">
            {testimonials.map((t) => (
              <blockquote class="testimonial-card">
                <p class="testimonial-quote">{t.data.quote}</p>
                <footer class="testimonial-author">
                  <cite>
                    <strong>{t.data.author}</strong>
                    <span>
                      {t.data.role} at {t.data.company}
                    </span>
                  </cite>
                </footer>
              </blockquote>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- Clients -->
  {
    clients.length > 0 && (
      <section class="clients">
        <div class="clients-inner">
          <h2 class="section-heading">Companies we've worked with</h2>
          <ul>
            {clients.map((client) => (
              <li>
                {client.data.url ? (
                  <a href={client.data.url} target="_blank" rel="noopener noreferrer" title={client.data.name}>
                    <span class="client-name">{client.data.name}</span>
                  </a>
                ) : (
                  <span class="client-name">{client.data.name}</span>
                )}
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <!-- CTA -->
  <section class="cta">
    <div class="cta-inner">
      <h2>Want to work with us?</h2>
      <p>We're always looking for interesting projects and good people to collaborate with.</p>
      <a href="/say-hello" class="cta-link">Get in touch →</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* --------------------------------------------------------
       Intro
       -------------------------------------------------------- */
  .intro {
    padding: 8rem var(--gutter) 4rem;
  }

  .intro-inner {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
  }

  .intro h1 {
    font-size: var(--text-3xl);
    font-weight: var(--weight-normal);
    line-height: var(--leading-tight);
  }

  .intro-muted {
    color: var(--color-text-muted);
  }

  /* --------------------------------------------------------
       Values
       -------------------------------------------------------- */
  .values {
    padding: 0 var(--gutter) 4rem;
  }

  .values-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .value-card {
    background: var(--color-surface-alt);
    padding: 2rem;
    border-radius: 0.5rem;
  }

  .value-title {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    margin-bottom: 0.75rem;
  }

  .value-description {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  @media (max-width: 640px) {
    .values-grid {
      grid-template-columns: 1fr;
    }
  }

  /* --------------------------------------------------------
       Numbers
       -------------------------------------------------------- */
  .numbers {
    padding: 0 var(--gutter) 4rem;
  }

  .numbers-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .numbers-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .number-item {
    text-align: center;
    padding: 2rem 1rem;
  }

  .number-item dt {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .number-item dd {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    line-height: 1;
  }

  @media (max-width: 768px) {
    .numbers-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* --------------------------------------------------------
       Team photo
       -------------------------------------------------------- */
  .team-photo {
    padding: 0 var(--gutter) 4rem;
  }

  .team-photo-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .team-photo-inner img {
    width: 100%;
    height: auto;
    border-radius: 0.5rem;
    display: block;
  }

  /* --------------------------------------------------------
       Section heading
       -------------------------------------------------------- */
  .section-heading {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 2rem;
  }

  /* --------------------------------------------------------
       Testimonials
       -------------------------------------------------------- */
  .testimonials {
    padding: 0 var(--gutter) 4rem;
  }

  .testimonials-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
    gap: 1rem;
  }

  .testimonial-card {
    background: var(--color-surface-alt);
    padding: 2rem;
    border-radius: 0.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .testimonial-quote {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    margin-bottom: 2rem;
  }

  .testimonial-author cite {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .testimonial-author strong {
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
  }

  .testimonial-author span {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  /* --------------------------------------------------------
       Clients
       -------------------------------------------------------- */
  .clients {
    padding: 0 var(--gutter) 4rem;
  }

  .clients-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .clients ul {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    list-style: none;
  }

  .clients li a {
    color: var(--color-text);
    text-decoration: none;
    opacity: 0.7;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .clients li a:hover {
    opacity: 1;
    color: var(--color-text);
  }

  .client-name {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    white-space: nowrap;
  }

  /* --------------------------------------------------------
       CTA
       -------------------------------------------------------- */
  .cta {
    padding: 4rem var(--gutter) 8rem;
  }

  .cta-inner {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
    text-align: center;
  }

  .cta h2 {
    font-size: var(--text-2xl);
    margin-bottom: 1rem;
  }

  .cta p {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    line-height: var(--leading-normal);
  }

  .cta-link {
    display: inline-block;
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 0.15em;
    text-decoration-thickness: 1px;
    transition: text-decoration-thickness var(--duration-fast) var(--ease-out);
  }

  .cta-link:hover {
    color: var(--color-text);
    text-decoration-thickness: 2px;
  }
</style>
