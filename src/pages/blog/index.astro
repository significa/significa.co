---
import Base from "@/layouts/base.astro";
import { getPublishedPosts } from "@/lib/collections";

const posts = await getPublishedPosts();
---

<Base title="Blog" description="Thoughts on design, engineering, and building products.">
  <section>
    <h1>Blog</h1>
    {
      posts.length === 0 ? (
        <p>No posts yet.</p>
      ) : (
        <ul>
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}`}>
                <h2>{post.data.title}</h2>
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</Base>
