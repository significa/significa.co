---
/**
 * /projects — Work index
 *
 * Editorial index for now. Image treatment TBD — needs a concept
 * that isn't a generic grid, a hover gimmick, or an arbitrary
 * alternation. Revisit when we have a clear direction.
 */

import BaseLayout from "@/layouts/base.astro";
import Eyebrow from "@/components/ui/eyebrow.astro";
import SectionHeader from "@/components/ui/section-header.astro";
import IndexList from "@/components/ui/index-list.astro";
import { getProjects } from "@/lib/collections";

const projects = await getProjects();
---

<BaseLayout
  title="Work — Significa"
  description="Selected work from Significa. Design and engineering projects across healthcare, finance, commerce, and more."
>
  <section class="page" aria-labelledby="page-h">
    <header class="page-header">
      <Eyebrow>Work</Eyebrow>
      <SectionHeader as="h1" id="page-h">Selected projects.</SectionHeader>
    </header>

    <IndexList items={projects.map((p, i) => ({
      href: `/projects/${p.id}`,
      title: p.data.title,
      tagline: p.data.tagline ?? "",
      date: String(new Date(p.data.date).getFullYear()),
      num: String(i + 1).padStart(2, "0"),
    }))} />
  </section>
</BaseLayout>

<style>
  .page {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-inline: var(--gutter);
    padding-block: clamp(4rem, 8vw, 7rem) clamp(5rem, 10vw, 10rem);
  }

  .page-header {
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }
</style>
