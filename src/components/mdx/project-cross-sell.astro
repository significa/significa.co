---
import { getEntry } from "astro:content";
import { cdnUrl, DEFAULT_QUALITY } from "@/lib/cdn";
import { contentError } from "@/lib/content-errors";

interface Props {
  project: string;
  title?: string;
  description?: string;
}

const { project: slug, title, description } = Astro.props;

if (!slug) {
  contentError("ProjectCrossSell", Astro.url.pathname, "Missing required prop: project");
}

const project = await getEntry("projects", slug);

if (!project) {
  contentError(
    "ProjectCrossSell",
    Astro.url.pathname,
    `Project "${slug}" not found. Check the slug exists in src/content/projects/.`
  );
}

const thumbnailSrc = cdnUrl(project.data.thumbnail, {
  width: 640,
  quality: DEFAULT_QUALITY,
});
---

<aside class="cross-sell">
  <a href={`/projects/${project.id}`} class="cross-sell-link">
    {
      project.data.thumbnail && (
        <div class="cross-sell-image-wrap">
          <img
            src={thumbnailSrc}
            alt={project.data.title}
            loading="lazy"
            decoding="async"
            class="cross-sell-image"
            style="width:100%;height:100%;object-fit:cover;display:block;margin:0;max-width:100%;"
          />
        </div>
      )
    }
    <div class="cross-sell-content">
      {title && <span class="cross-sell-label">{title}</span>}
      <span class="cross-sell-title">{project.data.title}</span>
      {(description || project.data.tagline) && <span class="cross-sell-tagline">{description || project.data.tagline}</span>}
      <span class="cross-sell-cta">View case study →</span>
    </div>
  </a>
</aside>

<style>
  .cross-sell {
    margin: 3rem 0;
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .cross-sell-link {
    display: grid;
    grid-template-columns: 220px 1fr;
    align-items: stretch;
    text-decoration: none;
    color: var(--color-text);
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .cross-sell-link:hover {
    opacity: 0.8;
  }

  .cross-sell-image-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 2;
    flex-shrink: 0;
  }

  .cross-sell-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
    padding: 2rem;
  }

  .cross-sell-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .cross-sell-title {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
  }

  .cross-sell-tagline {
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
  }

  .cross-sell-cta {
    margin-top: 0.5rem;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text);
  }

  @media (max-width: 640px) {
    .cross-sell-link {
      grid-template-columns: 1fr;
    }

    .cross-sell-image-wrap {
      aspect-ratio: 16 / 9;
      width: 100%;
    }
  }
</style>
