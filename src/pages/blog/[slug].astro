---
/**
 * /blog/[slug] — Blog post
 *
 * Editorial register. Eyebrow meta, display title, prose.css body,
 * simplified author line, index-pattern related posts.
 */

import { render } from "astro:content";
import BaseLayout from "@/layouts/base.astro";
import Eyebrow from "@/components/ui/eyebrow.astro";
import IndexList from "@/components/ui/index-list.astro";
import { mdxComponents } from "@/components/mdx/components";
import { articleJsonLd } from "@/lib/seo";
import { getPosts, getRelatedPosts } from "@/lib/collections";
import { cdnUrl } from "@/lib/cdn";

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const seo = post.data.seo;
const title = seo?.metaTitle ?? post.data.title;
const description = seo?.metaDescription ?? post.data.description ?? `${post.data.title} — Significa Blog`;

const relatedPosts = await getRelatedPosts(post);

const wordCount = post.body?.split(/\s+/).length ?? 0;
const readingTime = wordCount > 0 ? Math.ceil(wordCount / 200) : 5;

const formattedDate = post.data.date.toLocaleDateString("en-GB", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

function formatShortDate(date: Date): string {
  return date.toLocaleDateString("en-GB", { year: "numeric", month: "short" });
}
---

<BaseLayout
  title={title}
  description={description}
  ogImage={seo?.ogImage ?? post.data.thumbnail}
  type="article"
  publishedAt={post.data.date}
>
  <article class="post">
    <!-- ============================================================
         Header
         ============================================================ -->
    <header class="post-header">
      <Eyebrow>
        <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
        <span class="sep">/</span>
        {readingTime} min read
        {
          post.data.tags?.[0] && (
            <>
              <span class="sep">/</span>
              {post.data.tags[0]}
            </>
          )
        }
      </Eyebrow>
      <h1 class="post-title">{post.data.title}</h1>
      {post.data.description && <p class="post-description">{post.data.description}</p>}
    </header>

    <!-- ============================================================
         Hero image
         ============================================================ -->
    {
      post.data.thumbnail && (
        <div class="post-hero">
          <img
            src={cdnUrl(post.data.thumbnail, { width: 1600, quality: 85 })}
            alt={post.data.altText ?? post.data.title}
            width="1600"
            height="900"
            loading="eager"
            decoding="async"
          />
        </div>
      )
    }

    <!-- ============================================================
         Body
         ============================================================ -->
    <div class="post-content">
      <div class="post-content-inner prose">
        <Content components={mdxComponents} />
      </div>
    </div>

    <!-- ============================================================
         Author
         ============================================================ -->
    {
      post.data.author && (
        <footer class="post-author">
          <Eyebrow>Written by {post.data.author}</Eyebrow>
        </footer>
      )
    }

    <!-- ============================================================
         Related posts — editorial index
         ============================================================ -->
    {
      relatedPosts.length > 0 && (
        <aside class="related" aria-labelledby="related-h">
          <Eyebrow id="related-h">
            More articles
          </Eyebrow>
          <IndexList items={relatedPosts.map((related, i) => ({
            href: `/blog/${related.id}`,
            title: related.data.title,
            tagline: related.data.description
              ? related.data.description.length > 80
                ? related.data.description.slice(0, 80) + "..."
                : related.data.description
              : "",
            date: formatShortDate(related.data.date),
            num: String(i + 1).padStart(2, "0"),
          }))} />
        </aside>
      )
    }
  </article>

  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(
      articleJsonLd({
        title: post.data.title,
        description,
        url: new URL(`/blog/${post.id}`, Astro.site).href,
        publishedAt: post.data.date,
        author: post.data.author,
        image: seo?.ogImage || post.data.thumbnail,
      })
    )}
  />
</BaseLayout>

<style>
  /* ============================================================
     Header
     ============================================================ */

  .post-header {
    max-width: var(--max-width-narrow);
    margin-inline: auto;
    padding-inline: var(--gutter);
    padding-block: clamp(4rem, 8vw, 7rem) clamp(2rem, 4vw, 3rem);
  }

  .post-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-4xl);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0;
    color: var(--color-ink);
  }

  .post-description {
    margin-top: 1.5rem;
    font-size: var(--text-xl);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
  }

  @media (max-width: 768px) {
    .post-title {
      font-size: var(--text-3xl);
    }

    .post-description {
      font-size: var(--text-lg);
    }
  }

  /* ============================================================
     Hero image
     ============================================================ */

  .post-hero {
    max-width: var(--max-width-narrow);
    margin-inline: auto;
    padding-inline: var(--gutter);
    padding-block-end: clamp(2rem, 4vw, 3rem);
  }

  .post-hero img {
    width: 100%;
    height: auto;
    max-height: 480px;
    object-fit: cover;
    display: block;
    border-radius: var(--radius-image);
  }

  /* ============================================================
     Body
     ============================================================ */

  .post-content {
    padding-block: 0 clamp(3rem, 6vw, 5rem);
  }

  .post-content-inner {
    max-width: var(--max-width-narrow);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ============================================================
     Author
     ============================================================ */

  .post-author {
    max-width: var(--max-width-narrow);
    margin-inline: auto;
    padding-inline: var(--gutter);
    padding-block: clamp(2rem, 4vw, 3rem);
    border-block-start: 1px solid var(--color-rule);
  }

  /* ============================================================
     Related
     ============================================================ */

  .related {
    max-width: var(--max-width-wide);
    margin-inline: auto;
    padding-inline: var(--gutter);
    padding-block: clamp(3rem, 6vw, 5rem);
    border-block-start: 1px solid var(--color-rule);
  }
</style>
