---
/**
 * /about — Who we are
 *
 * The identity page. The interesting thing about Significa is the
 * tension they manage. This page names it.
 *
 *   1. Position statement — who, not what.
 *   2. The overlap — the honest tension, named out loud.
 *   3. How this shows up — 3 convictions with real teeth.
 *   4. Who we're not — the three negations.
 *   5. Manifesto moment — earned by the argument above.
 *   6. The studio — numbers + team photo + client voice, one section.
 */

import BaseLayout from "@/layouts/base.astro";
import Egg from "@/components/ui/egg.astro";
import Eyebrow from "@/components/ui/eyebrow.astro";
import SectionHeader from "@/components/ui/section-header.astro";
import NumbersRow from "@/components/ui/numbers-row.astro";
import QaList from "@/components/ui/qa-list.astro";
import Moment from "@/components/ui/moment.astro";
import FeaturedVoice from "@/components/ui/featured-voice.astro";
import { getTestimonials } from "@/lib/collections";
import { cdnUrl } from "@/lib/cdn";

const testimonials = await getTestimonials();
const bestTestimonial = testimonials[0];

const convictions = [
  {
    n: "01",
    q: "We back our opinions with reasoning and work.",
    a: "If we think the brief is solving the wrong problem, we'll say so in the first week, not after three months of billing. Every recommendation has a reason you can question. The trust isn't built by agreeing. It's built by being right often enough that disagreement carries weight.",
  },
  {
    n: "02",
    q: "We use AI to move faster, not to move cheaper.",
    a: "AI can generate a hundred variations without knowing which one is right for this brand, this user, this moment. That judgement is what we've been building for years. The time AI saves us goes into craft and thinking, not into squeezing margins or cutting headcount.",
  },
  {
    n: "03",
    q: "We say no to money.",
    a: "Not always. Not even often. But sometimes a project would keep people busy, pay the bills, and produce work nobody would be proud of. Every time we say yes to that, we make it harder to attract the work that defines us. The portfolio drifts. The reputation drifts. The people who joined because of what we stood for start looking elsewhere.",
  },
];

const numbers = [
  { label: "In business since", value: "2015" },
  { label: "Team", value: "30+" },
  { label: "Projects shipped", value: "100+" },
  { label: "Outsourced work", value: "0%" },
];
---

<BaseLayout
  title="About — Significa"
  description="Significa is a design and engineering studio in Porto. We exist in the space between idealism and revenue. Designers and engineers who think together."
>
  <!-- ============================================================
       1. Position statement
       ============================================================ -->
  <section class="hero" aria-labelledby="hero-h">
    <Eyebrow>About</Eyebrow>
    <h1 id="hero-h" class="hero-statement">We get inside the problem until we can see what's actually best for it.</h1>
    <p class="hero-deck">
      Significa is a digital product studio in Porto. Designers and engineers in one team, not two departments
      pretending to collaborate. The person who made the decision is the person you can talk to.
      That's how you get work that ages well instead of work that ships fast and needs a rewrite in eighteen months.
    </p>
  </section>

  <!-- ============================================================
       2. The overlap — the honest tension, named
       ============================================================ -->
  <section class="overlap" aria-labelledby="overlap-h">
    <Eyebrow>The space between</Eyebrow>
    <h2 id="overlap-h" class="overlap-heading type-heading-lg">We live in the overlap between idealism and revenue.</h2>
    <div class="overlap-prose">
      <p>
        There is a version of this company that is easy to run. It takes corporate clients with clear scopes and comfortable
        budgets. It delivers good work on time. Nobody is embarrassed. Nobody is inspired either, but that's the trade.
      </p>
      <p>
        There is another version that does extraordinary things. Products built with obsessive care. The portfolio is the kind
        that makes talented people want to join. It is also, frequently, the kind of work that doesn't pay enough.
      </p>
      <p>
        We live in the overlap. The commercial work funds the capacity to do ambitious, identity-defining projects. The
        ambitious projects attract the clients who value what we actually do. The balance between those two tracks is a decision
        we make together, every quarter, in every pitch we accept or refuse. That's the work. Not the apps, not the pitches. The
        work is deciding, over and over, what this place is for.
      </p>
    </div>
  </section>

  <!-- ============================================================
       3. Convictions — specific, with teeth
       ============================================================ -->
  <section class="convictions" aria-labelledby="convictions-h">
    <header class="convictions-header">
      <Eyebrow>How this shows up</Eyebrow>
      <SectionHeader id="convictions-h">Three things we actually do, not just believe.</SectionHeader>
    </header>

    <QaList items={convictions} />
  </section>

  <!-- ============================================================
       4. Who we're not — the boundaries
       ============================================================ -->
  <section class="boundaries" aria-labelledby="boundaries-h">
    <Eyebrow>Who we're not</Eyebrow>
    <SectionHeader id="boundaries-h">Three things we will never be.</SectionHeader>
    <ol class="boundaries-list" role="list">
      <li class="boundary">
        <p class="boundary-head">A software house that churns out features to spec.</p>
        <p class="boundary-body">
          If you need a team that executes without questioning, we're the wrong choice. We will push back when we think the spec
          is solving the wrong problem.
        </p>
      </li>
      <li class="boundary">
        <p class="boundary-head">A creative agency that hands off pretty pictures and walks away.</p>
        <p class="boundary-body">
          We build what we design. The person who made the design decision is in the room when it gets engineered. No handoffs
          between departments, because there are no departments.
        </p>
      </li>
      <li class="boundary">
        <p class="boundary-head">Consultants who write decks instead of building things.</p>
        <p class="boundary-body">
          Strategy without execution is a hobby. We think, then we build, then we measure whether the thinking was right. If it
          wasn't, we absorb that cost.
        </p>
      </li>
    </ol>
  </section>

  <!-- ============================================================
       5. Manifesto moment — earned by the argument above
       ============================================================ -->
  <Moment id="moment-h">
    <em>We give<br />a damn.</em>
    <p slot="attr" class="moment-attr">
      <Egg variant="outline" class="moment-egg" />
      &nbsp; From the North Star <span class="sep">/</span>
      <a href="/say-hello" class="moment-link">say hello</a>
    </p>
  </Moment>

  <!-- ============================================================
       6. The studio — numbers, photo, client voice as one section
       ============================================================ -->
  <section class="studio" aria-labelledby="studio-h">
    <Eyebrow id="studio-h">The studio</Eyebrow>

    <NumbersRow items={numbers} />

    <div class="studio-photo">
      <img
        src={cdnUrl("website/test-TKzoOc.png", { width: 1920, quality: 85 })}
        alt="The Significa team at the Porto studio"
        width="1920"
        height="1080"
        loading="lazy"
        decoding="async"
      />
    </div>

    {
      bestTestimonial && (
        <FeaturedVoice
          quote={bestTestimonial.data.quote}
          author={bestTestimonial.data.author}
          role={`${bestTestimonial.data.role} at ${bestTestimonial.data.company}`}
          class="studio-voice"
        />
      )
    }
  </section>
</BaseLayout>

<style>
  /* ============================================================
     Page rhythm
     ============================================================ */

  section {
    padding-inline: var(--gutter);
    padding-block: clamp(5rem, 10vw, 10rem);
  }

  /* ============================================================
     1. Hero
     ============================================================ */

  .hero {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-block: clamp(4rem, 8vw, 7rem) clamp(3rem, 6vw, 5rem);
  }

  .hero-statement {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: var(--text-display-2);
    line-height: var(--leading-tight);
    margin: 0;
    max-width: 22ch;
    color: var(--color-ink);
  }

  .hero-deck {
    margin-top: 2.5rem;
    font-size: var(--text-xl);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
    max-width: var(--max-width-prose);
  }

  /* ============================================================
     2. The overlap
     ============================================================ */

  .overlap {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .overlap-heading {
    margin: 0 0 clamp(2rem, 4vw, 3rem);
    max-width: 24ch;
  }

  .overlap-prose {
    max-width: 52ch;
  }

  .overlap-prose p {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    margin-block: 0 1.25em;
    color: var(--color-ink);
  }

  .overlap-prose p:last-child {
    margin-bottom: 0;
  }

  /* ============================================================
     3. Convictions
     ============================================================ */

  .convictions {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .convictions-header {
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  /* ============================================================
     4. Boundaries / who we're not
     ============================================================ */

  .boundaries {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .boundaries-list {
    list-style: none;
    margin: clamp(3rem, 6vw, 5rem) 0 0;
    padding: 0;
  }

  .boundary {
    display: grid;
    grid-template-columns: 1fr;
    row-gap: 0.75rem;
    padding-block: 2.5rem;
    border-top: 1px solid var(--color-rule);
  }

  .boundary:last-child {
    border-bottom: 1px solid var(--color-rule);
  }

  .boundary-head {
    font-weight: var(--weight-medium);
    font-size: var(--text-xl);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    margin: 0;
    color: var(--color-ink);
    max-width: 36ch;
  }

  .boundary-body {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
    margin: 0;
    max-width: 52ch;
  }

  /* ============================================================
     6. The studio — one cohesive section
     ============================================================ */

  .studio {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .studio-photo {
    margin-block: clamp(3rem, 6vw, 5rem);
    overflow: hidden;
    border-radius: var(--radius-image);
  }

  .studio-photo img {
    width: 100%;
    height: auto;
    display: block;
  }

  .studio-voice {
    margin-top: clamp(2rem, 4vw, 3rem);
  }
</style>
