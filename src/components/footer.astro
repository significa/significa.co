---
/**
 * Footer
 *
 * Editorial close. Same paper as the page (no separate gray surface).
 * Three-cell top with the pull quote as the visual centerpiece, then
 * a mono nav row, then legal/marks. Contact email gets prominence;
 * the manifesto line provides the moment.
 *
 * No "ready to grow your business" CTA. We close on point of view +
 * direct contact, not on a sales line.
 */

import Egg from "@/components/ui/egg.astro";

const currentYear = new Date().getFullYear();

const navItems = [
  { label: "Work", href: "/projects" },
  { label: "About", href: "/about" },
  { label: "Services", href: "/services" },
  { label: "Journal", href: "/blog" },
  { label: "Handbook", href: "/handbook" },
  { label: "Hello", href: "/say-hello" },
];
---

<footer class="site-footer">
  <div class="footer-shell">
    <!-- Top: pull quote on the left, contact info on the right, the
         whole middle left as breathing room. Differentiated from the
         homepage manifesto by using a different brand-doc axis —
         steadiness, not judgment. -->
    <div class="footer-top">
      <div class="footer-cell footer-cell-quote">
        <p class="footer-quote"><em>Calm<br />in complexity.</em></p>
        <p class="footer-quote-attr">
          <Egg variant="fill" class="footer-quote-egg" />
          North Star
        </p>
      </div>

      <div class="footer-cell footer-cell-contact">
        <dl class="footer-rows">
          <div class="footer-row">
            <dt class="footer-eyebrow">Hello</dt>
            <dd>
              <a href="mailto:newbusiness@significa.co">newbusiness@significa.co</a>
            </dd>
          </div>
          <div class="footer-row">
            <dt class="footer-eyebrow">Studio</dt>
            <dd>
              <a href="https://maps.app.goo.gl/Y9fLYR12K7iKjYpA9" target="_blank" rel="noopener noreferrer"
                >Rua Morgado Mateus 45, Porto</a
              >
            </dd>
          </div>
          <div class="footer-row">
            <dt class="footer-eyebrow">Currently</dt>
            <dd class="footer-current">designing for healthcare</dd>
          </div>
        </dl>
      </div>
    </div>

    <!-- Mono nav row -->
    <nav class="footer-nav" aria-label="Footer navigation">
      <ul role="list">
        {
          navItems.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Legal + marks -->
    <div class="footer-legal">
      <div class="footer-marks">
        <a href="/b-corp" class="footer-mark">B Corp</a>
        <span class="footer-mark">1% for the Planet</span>
      </div>
      <p class="footer-legal-text">
        <Egg variant="fill" class="footer-legal-egg" />
        {currentYear} Significa <span class="footer-sep">/</span>
        <a href="/legal">Terms &amp; privacy</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-rule);
    background: var(--color-paper);
    padding-block: clamp(5rem, 10vw, 9rem) clamp(2rem, 4vw, 4rem);
    margin-top: clamp(4rem, 8vw, 8rem);
  }

  .footer-shell {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-inline: var(--gutter);
  }

  /* ============================================================
     Mono utility — used in eyebrows, nav, marks, legal
     ============================================================ */

  .footer-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .footer-sep {
    color: var(--color-ink-faint);
    margin-inline: 0.35em;
  }

  /* ============================================================
     Top: 3-cell editorial. Quote in the middle is the centerpiece.
     ============================================================ */

  /* Two cells at opposite ends: quote left, contact right,
     the middle is deliberate breathing room. */
  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: clamp(3rem, 8vw, 8rem);
    margin-bottom: clamp(4rem, 8vw, 6rem);
  }

  .footer-cell {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    min-width: 0;
  }

  /* Pull quote ---------------------------------------- */

  .footer-cell-quote {
    align-items: flex-start;
  }

  .footer-quote {
    font-family: var(--font-display);
    font-weight: 200;
    font-style: italic;
    font-size: var(--text-4xl);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tighter);
    color: var(--color-ink);
    margin: 0;
  }

  .footer-quote-attr {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    margin: 0.5rem 0 0;
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
  }

  .footer-quote-egg {
    color: var(--color-accent);
    height: 0.85em;
  }

  /* Contact rows -------------------------------------- */

  .footer-rows {
    margin: 0;
    display: grid;
    gap: 1rem;
  }

  .footer-row {
    display: grid;
    gap: 0.2rem;
  }

  .footer-row dt {
    margin: 0;
  }

  .footer-row dd {
    margin: 0;
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-ink);
  }

  .footer-row dd a {
    color: inherit;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .footer-row dd a:hover {
    color: var(--color-accent);
  }

  .footer-current {
    color: var(--color-accent) !important;
  }

  /* ============================================================
     Mono nav row
     ============================================================ */

  .footer-nav {
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
    padding-top: 2rem;
    border-top: 1px solid var(--color-rule);
  }

  .footer-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .footer-nav a {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .footer-nav a:hover {
    color: var(--color-ink);
  }

  /* ============================================================
     Legal row — marks left, copyright right
     ============================================================ */

  .footer-legal {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .footer-marks {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .footer-mark {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    transition: color var(--duration-fast) var(--ease-out);
  }

  a.footer-mark:hover {
    color: var(--color-ink);
  }

  .footer-legal-text {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-ink-muted);
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
  }

  .footer-legal-text a {
    color: inherit;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .footer-legal-text a:hover {
    color: var(--color-ink);
  }

  .footer-legal-egg {
    height: 0.85em;
    color: var(--color-accent);
  }

  /* ============================================================
     Responsive
     ============================================================ */

  @media (max-width: 640px) {
    .footer-top {
      flex-direction: column;
      gap: 3rem;
    }

    .footer-quote {
      font-size: var(--text-3xl);
    }

    .footer-legal {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.25rem;
    }
  }
</style>
