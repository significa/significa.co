---
import Base from "../layouts/Base.astro";
import { getClients, getTestimonials } from "../lib/collections";

const clients = await getClients();
const testimonials = await getTestimonials();
---

<Base
    title="Work with us"
    description="Let's build something meaningful together. Get in touch to start a conversation about your next digital product."
>
    <!-- Intro -->
    <section class="intro">
        <div class="intro-inner">
            <h1>
                <span class="intro-muted"
                    >We partner with companies that care about craft.</span
                >
                {" "}
                Let's build something meaningful together.
            </h1>
        </div>
    </section>

    <!-- Contact -->
    <section class="contact">
        <div class="contact-inner">
            <div class="contact-card">
                <h2>Get in touch</h2>
                <p>
                    Drop us a line and tell us about your project. We'll get
                    back to you within two business days.
                </p>
                <a href="mailto:hello@significa.co" class="contact-email">
                    hello@significa.co
                </a>
            </div>
            <div class="contact-details">
                <div class="contact-detail">
                    <h3>Based in</h3>
                    <p>Porto, Portugal</p>
                </div>
                <div class="contact-detail">
                    <h3>Working hours</h3>
                    <p>Mon–Fri, 9am–6pm WET</p>
                </div>
                <div class="contact-detail">
                    <h3>Working with</h3>
                    <p>Teams worldwide, remotely and on-site</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Process -->
    <section class="process">
        <div class="process-inner">
            <h2 class="section-heading">How we work together</h2>
            <ol class="process-steps">
                <li class="process-step">
                    <span class="step-number">01</span>
                    <h3>Conversation</h3>
                    <p>
                        We start by listening. Tell us about your business, your
                        users, and what you're trying to achieve. No
                        commitments, no pitches — just an honest conversation
                        about whether we're the right fit.
                    </p>
                </li>
                <li class="process-step">
                    <span class="step-number">02</span>
                    <h3>Proposal</h3>
                    <p>
                        If there's a fit, we scope the work together. You get a
                        clear proposal with timeline, deliverables, and pricing.
                        No surprises, no hidden costs.
                    </p>
                </li>
                <li class="process-step">
                    <span class="step-number">03</span>
                    <h3>Kick-off</h3>
                    <p>
                        A small, dedicated team gets assigned to your project.
                        We set up communication channels, align on goals, and
                        hit the ground running.
                    </p>
                </li>
                <li class="process-step">
                    <span class="step-number">04</span>
                    <h3>Build</h3>
                    <p>
                        Design and engineering work in tight loops. You see
                        progress weekly, give feedback early, and stay involved
                        throughout. No big reveals — just steady, visible
                        progress.
                    </p>
                </li>
                <li class="process-step">
                    <span class="step-number">05</span>
                    <h3>Launch & iterate</h3>
                    <p>
                        We ship, measure, and improve. The work doesn't end at
                        launch — we stick around to make sure what we built
                        actually works in the real world.
                    </p>
                </li>
            </ol>
        </div>
    </section>

    <!-- What we look for -->
    <section class="criteria">
        <div class="criteria-inner">
            <div class="criteria-text">
                <h2>Projects we're a good fit for</h2>
                <p>
                    We're selective about the work we take on. Not because we're
                    precious about it, but because focus produces better
                    outcomes for everyone.
                </p>
            </div>
            <ul class="criteria-list">
                <li>
                    <strong>Digital products</strong> — apps, platforms, and
                    tools that solve real problems for real users.
                </li>
                <li>
                    <strong>E-commerce</strong> — online stores and platforms
                    where design directly impacts revenue.
                </li>
                <li>
                    <strong>Design systems</strong> — scalable component
                    libraries and design foundations that grow with your team.
                </li>
                <li>
                    <strong>Websites</strong> — marketing sites, corporate
                    sites, and web experiences where craft matters.
                </li>
            </ul>
        </div>
    </section>

    <!-- Testimonials -->
    {
        testimonials.length > 0 && (
            <section class="testimonials">
                <div class="testimonials-inner">
                    <h2 class="section-heading">What our clients say</h2>
                    <div class="testimonials-grid">
                        {testimonials.map((t) => (
                            <blockquote class="testimonial-card">
                                <p class="testimonial-quote">
                                    {t.data.quote}
                                </p>
                                <footer class="testimonial-author">
                                    <cite>
                                        <strong>{t.data.author}</strong>
                                        <span>
                                            {t.data.role} at {t.data.company}
                                        </span>
                                    </cite>
                                </footer>
                            </blockquote>
                        ))}
                    </div>
                </div>
            </section>
        )
    }

    <!-- Clients -->
    {
        clients.length > 0 && (
            <section class="clients">
                <div class="clients-inner">
                    <h2 class="section-heading">
                        Companies we've worked with
                    </h2>
                    <ul>
                        {clients.map((client) => (
                            <li>
                                {client.data.url ? (
                                    <a
                                        href={client.data.url}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        title={client.data.name}
                                    >
                                        <span class="client-name">
                                            {client.data.name}
                                        </span>
                                    </a>
                                ) : (
                                    <span class="client-name">
                                        {client.data.name}
                                    </span>
                                )}
                            </li>
                        ))}
                    </ul>
                </div>
            </section>
        )
    }
</Base>

<style>
    /* --------------------------------------------------------
       Intro
       -------------------------------------------------------- */
    .intro {
        padding: var(--space-32) var(--gutter) var(--space-16);
    }

    .intro-inner {
        max-width: var(--max-width-narrow);
        margin: 0 auto;
    }

    .intro h1 {
        font-size: var(--text-3xl);
        font-weight: var(--weight-normal);
        line-height: var(--leading-tight);
    }

    .intro-muted {
        color: var(--color-text-muted);
    }

    /* --------------------------------------------------------
       Contact
       -------------------------------------------------------- */
    .contact {
        padding: 0 var(--gutter) var(--space-16);
    }

    .contact-inner {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-4);
        max-width: var(--max-width);
        margin: 0 auto;
    }

    .contact-card {
        background: var(--color-surface-alt);
        padding: var(--space-8);
        border-radius: var(--space-2);
    }

    .contact-card h2 {
        font-size: var(--text-xl);
        font-weight: var(--weight-bold);
        margin-bottom: var(--space-4);
    }

    .contact-card p {
        font-size: var(--text-base);
        color: var(--color-text-muted);
        line-height: var(--leading-normal);
        margin-bottom: var(--space-6);
    }

    .contact-email {
        display: inline-block;
        font-size: var(--text-lg);
        font-weight: var(--weight-medium);
        color: var(--color-text);
        text-decoration: underline;
        text-underline-offset: 0.15em;
        text-decoration-thickness: 1px;
    }

    .contact-email:hover {
        color: var(--color-text);
        text-decoration-thickness: 2px;
    }

    .contact-details {
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
    }

    .contact-detail {
        background: var(--color-surface-alt);
        padding: var(--space-6);
        border-radius: var(--space-2);
        flex: 1;
    }

    .contact-detail h3 {
        font-size: var(--text-sm);
        font-weight: var(--weight-normal);
        color: var(--color-text-muted);
        margin-bottom: var(--space-1);
    }

    .contact-detail p {
        font-size: var(--text-base);
        font-weight: var(--weight-medium);
    }

    @media (max-width: 768px) {
        .contact-inner {
            grid-template-columns: 1fr;
        }
    }

    /* --------------------------------------------------------
       Process
       -------------------------------------------------------- */
    .process {
        padding: 0 var(--gutter) var(--space-16);
    }

    .process-inner {
        max-width: var(--max-width);
        margin: 0 auto;
    }

    .section-heading {
        font-size: var(--text-sm);
        font-weight: var(--weight-medium);
        color: var(--color-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: var(--space-8);
    }

    .process-steps {
        list-style: none;
        display: grid;
        gap: var(--space-4);
    }

    .process-step {
        display: grid;
        grid-template-columns: auto 1fr;
        grid-template-rows: auto auto;
        column-gap: var(--space-6);
        row-gap: var(--space-2);
        padding: var(--space-6) 0;
        border-bottom: 1px solid var(--color-border);
    }

    .step-number {
        grid-row: 1 / -1;
        font-size: var(--text-sm);
        font-weight: var(--weight-medium);
        color: var(--color-text-muted);
        padding-top: var(--space-1);
    }

    .process-step h3 {
        font-size: var(--text-lg);
        font-weight: var(--weight-semibold);
    }

    .process-step p {
        font-size: var(--text-base);
        color: var(--color-text-muted);
        line-height: var(--leading-normal);
        max-width: 50ch;
    }

    /* --------------------------------------------------------
       Criteria
       -------------------------------------------------------- */
    .criteria {
        padding: 0 var(--gutter) var(--space-16);
    }

    .criteria-inner {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-16);
        max-width: var(--max-width);
        margin: 0 auto;
    }

    .criteria-text h2 {
        font-size: var(--text-2xl);
        font-weight: var(--weight-bold);
        line-height: var(--leading-tight);
        margin-bottom: var(--space-4);
    }

    .criteria-text p {
        font-size: var(--text-base);
        color: var(--color-text-muted);
        line-height: var(--leading-normal);
    }

    .criteria-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: var(--space-6);
    }

    .criteria-list li {
        font-size: var(--text-base);
        line-height: var(--leading-normal);
        color: var(--color-text-muted);
    }

    .criteria-list strong {
        color: var(--color-text);
        font-weight: var(--weight-medium);
    }

    @media (max-width: 768px) {
        .criteria-inner {
            grid-template-columns: 1fr;
            gap: var(--space-8);
        }
    }

    /* --------------------------------------------------------
       Testimonials
       -------------------------------------------------------- */
    .testimonials {
        padding: 0 var(--gutter) var(--space-16);
    }

    .testimonials-inner {
        max-width: var(--max-width);
        margin: 0 auto;
    }

    .testimonials-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
        gap: var(--space-4);
    }

    .testimonial-card {
        background: var(--color-surface-alt);
        padding: var(--space-8);
        border-radius: var(--space-2);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .testimonial-quote {
        font-size: var(--text-lg);
        line-height: var(--leading-normal);
        margin-bottom: var(--space-8);
    }

    .testimonial-author cite {
        font-style: normal;
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
    }

    .testimonial-author strong {
        font-size: var(--text-base);
        font-weight: var(--weight-medium);
    }

    .testimonial-author span {
        font-size: var(--text-sm);
        color: var(--color-text-muted);
    }

    /* --------------------------------------------------------
       Clients
       -------------------------------------------------------- */
    .clients {
        padding: 0 var(--gutter) var(--space-16);
    }

    .clients-inner {
        max-width: var(--max-width);
        margin: 0 auto;
    }

    .clients ul {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: var(--space-8);
        list-style: none;
    }

    .clients li a {
        color: var(--color-text);
        text-decoration: none;
        opacity: 0.7;
        transition: opacity var(--duration-fast) var(--ease-out);
    }

    .clients li a:hover {
        opacity: 1;
        color: var(--color-text);
    }

    .client-name {
        font-size: var(--text-sm);
        font-weight: var(--weight-semibold);
        white-space: nowrap;
    }
</style>
