---
/**
 * /projects — Work index
 *
 * Editorial index. Each row: number, title, tagline, year, arrow.
 * No filters, no vanilla JS. Images TBD — needs a treatment that
 * isn't a generic card grid.
 */

import BaseLayout from "@/layouts/base.astro";
import { getProjects } from "@/lib/collections";

const projects = await getProjects();
---

<BaseLayout
  title="Work — Significa"
  description="Selected work from Significa. Design and engineering projects across healthcare, finance, commerce, and more."
>
  <section class="page" aria-labelledby="page-h">
    <header class="page-header">
      <p class="eyebrow">Work</p>
      <h1 id="page-h" class="section-statement">Selected projects.</h1>
    </header>

    <ol class="index-list" role="list">
      {
        projects.map((p, i) => (
          <li>
            <a href={`/projects/${p.id}`} class="index-link">
              <span class="index-num">{String(i + 1).padStart(2, "0")}</span>
              <span class="index-title">{p.data.title}</span>
              <span class="index-tagline">{p.data.tagline}</span>
              <span class="index-year">{new Date(p.data.date).getFullYear()}</span>
              <span class="index-mark" aria-hidden="true">&rarr;</span>
            </a>
          </li>
        ))
      }
    </ol>
  </section>
</BaseLayout>

<style>
  .page {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-inline: var(--gutter);
    padding-block: clamp(4rem, 8vw, 7rem) clamp(5rem, 10vw, 10rem);
  }

  .page-header {
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }
</style>
