---
import { getCollection, getEntry, render } from "astro:content";
import BaseLayout from "@/layouts/base.astro";
import { mdxComponents } from "@/components/mdx/components";
import { cdnUrl } from "@/lib/cdn";
import { getAwards } from "@/lib/collections";

export async function getStaticPaths() {
  const services = await getCollection("services");
  return services.map((service) => ({
    params: { slug: service.id },
    props: { service },
  }));
}

const { service } = Astro.props;
const { Content } = await render(service);

const seo = service.data.seo;
const title = seo?.metaTitle ?? service.data.title;
const description = seo?.metaDescription ?? service.data.tagline;
const ogImage = seo?.ogImage ?? service.data.thumbnail;

const featuredProjects = service.data.featuredProjects?.length
  ? await Promise.all(service.data.featuredProjects.map((ref) => getEntry(ref)))
  : [];

const allAwards = await getAwards();
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <article class="service">
    <!-- Hero -->
    <header class="service-hero">
      <div class="service-hero-inner">
        <p class="service-eyebrow">Services</p>
        <h1 class="service-title">{service.data.title}</h1>
        {service.data.tagline && <p class="service-tagline">{service.data.tagline}</p>}
        {service.data.heroTagline && <p class="service-hero-tagline">{service.data.heroTagline}</p>}
        <div class="service-hero-cta">
          <a href="/say-hello" class="cta-button-large">Get a quote</a>
        </div>
      </div>
    </header>

    <!-- Featured projects -->
    {
      featuredProjects.length > 0 && (
        <section class="featured-projects">
          <div class="featured-projects-inner">
            <p class="section-eyebrow">Our work</p>
            <ul class="featured-projects-list" role="list">
              {featuredProjects.map(
                (project) =>
                  project && (
                    <li class="featured-project-card">
                      <a href={`/projects/${project.id}`}>
                        {project.data.thumbnail && (
                          <div class="featured-project-image">
                            <img
                              src={cdnUrl(project.data.thumbnail, { width: 1200, quality: 85 })}
                              srcset={[
                                `${cdnUrl(project.data.thumbnail, { width: 600, quality: 85 })} 600w`,
                                `${cdnUrl(project.data.thumbnail, { width: 900, quality: 85 })} 900w`,
                                `${cdnUrl(project.data.thumbnail, { width: 1200, quality: 85 })} 1200w`,
                              ].join(", ")}
                              sizes="(max-width: 768px) 100vw, 50vw"
                              alt={project.data.title}
                              width="1200"
                              height="800"
                              loading="lazy"
                              decoding="async"
                            />
                          </div>
                        )}
                        <div class="featured-project-body">
                          <div class="featured-project-meta">
                            <h3 class="featured-project-title">{project.data.client ?? project.data.title}</h3>
                            {project.data.tagline && <p class="featured-project-tagline">{project.data.tagline}</p>}
                          </div>
                          {project.data.metrics.length > 0 && (
                            <dl class="featured-project-metrics">
                              {project.data.metrics.slice(0, 3).map((m) => (
                                <div class="featured-project-metric">
                                  <dd class="metric-value">{m.value}</dd>
                                  <dt class="metric-label">{m.label}</dt>
                                </div>
                              ))}
                            </dl>
                          )}
                          <span class="featured-project-cta">View project →</span>
                        </div>
                      </a>
                    </li>
                  )
              )}
            </ul>
          </div>
        </section>
      )
    }

    <!-- MDX body -->
    <div class="service-content">
      <div class="service-content-inner">
        <Content components={mdxComponents} />
      </div>
    </div>

    <!-- Awards (filtered to relevant ones if possible, otherwise show all) -->
    {
      allAwards.length > 0 && (
        <section class="service-awards">
          <div class="service-awards-inner">
            <p class="section-eyebrow">Recognition</p>
            <h2>International recognition.</h2>
            <ul class="awards-list" role="list">
              {allAwards.slice(0, 12).map((a) => (
                <li class="award-row">
                  {a.url ? (
                    <a href={a.url} target="_blank" rel="noopener noreferrer" class="award-link">
                      <span class="award-name">{a.award}</span>
                      <span class="award-divider" aria-hidden="true" />
                      <span class="award-project">{a.project?.data.client ?? a.project?.data.title}</span>
                      <span class="award-year">{a.year}</span>
                    </a>
                  ) : (
                    <span class="award-link">
                      <span class="award-name">{a.award}</span>
                      <span class="award-divider" aria-hidden="true" />
                      <span class="award-project">{a.project?.data.client ?? a.project?.data.title}</span>
                      <span class="award-year">{a.year}</span>
                    </span>
                  )}
                </li>
              ))}
            </ul>
          </div>
        </section>
      )
    }

    <!-- CTA -->
    <section class="service-cta">
      <div class="service-cta-inner">
        <p class="service-cta-label">Ready to get started?</p>
        <h2 class="service-cta-heading">Let's build something great together.</h2>
        <a href="/say-hello" class="cta-button-large">Get a quote</a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  /* ============================================================
     Shared utilities
     ============================================================ */

  .cta-button-large {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    background: var(--color-text);
    color: var(--color-surface);
    border-radius: 99px;
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .cta-button-large:hover {
    opacity: 0.8;
  }

  .section-eyebrow {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-block-end: 1rem;
  }

  /* ============================================================
     Hero
     ============================================================ */

  .service-hero {
    padding: 8rem var(--gutter) 5rem;
  }

  .service-hero-inner {
    max-width: var(--max-width-narrow);
    margin-inline: auto;
  }

  .service-eyebrow {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-block-end: 1.5rem;
  }

  .service-title {
    font-size: var(--text-3xl);
    font-weight: var(--weight-normal);
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin-block-end: 1.25rem;
  }

  .service-tagline {
    font-size: var(--text-xl);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
    margin-block-end: 0.75rem;
  }

  .service-hero-tagline {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
    font-style: italic;
    margin-block-end: 2.5rem;
  }

  .service-hero-cta {
    margin-block-start: 2.5rem;
  }

  @media (max-width: 768px) {
    .service-hero {
      padding-block-start: 5rem;
    }

    .service-title {
      font-size: var(--text-2xl);
    }
  }

  /* ============================================================
     Featured projects
     ============================================================ */

  .featured-projects {
    padding: 4rem var(--gutter);
    border-block-start: 1px solid var(--color-border);
  }

  .featured-projects-inner {
    max-width: var(--max-width);
    margin-inline: auto;
  }

  .featured-projects-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .featured-project-card a {
    display: grid;
    grid-template-columns: 1fr 1fr;
    text-decoration: none;
    color: inherit;
    background: var(--color-surface);
    transition: background var(--duration-fast) var(--ease-out);
  }

  .featured-project-card a:hover {
    background: var(--color-surface-alt);
  }

  .featured-project-image {
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .featured-project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: scale var(--duration-slow) var(--ease-out);
  }

  .featured-project-card a:hover .featured-project-image img {
    scale: 1.03;
  }

  .featured-project-body {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2rem;
    padding: 2.5rem;
  }

  .featured-project-title {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    margin-block-end: 0.5rem;
  }

  .featured-project-tagline {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  .featured-project-metrics {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .featured-project-metric {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .metric-value {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--color-text);
    line-height: 1;
  }

  .metric-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-weight: var(--weight-medium);
  }

  .featured-project-cta {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    transition: opacity var(--duration-fast) var(--ease-out);
    align-self: flex-start;
  }

  .featured-project-card a:hover .featured-project-cta {
    opacity: 0.6;
  }

  @media (max-width: 860px) {
    .featured-project-card a {
      grid-template-columns: 1fr;
    }

    .featured-project-image {
      aspect-ratio: 16 / 9;
    }
  }

  /* ============================================================
     MDX content
     ============================================================ */

  .service-content {
    padding-block: 5rem;
    padding-inline: var(--gutter);
    border-block-start: 1px solid var(--color-border);
  }

  .service-content-inner {
    max-width: var(--max-width-narrow);
    margin-inline: auto;
  }

  /* Prose typography */
  .service-content-inner :global(p) {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text);
    margin-block-end: 1.5rem;
  }

  .service-content-inner :global(h2) {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin-block-start: 3.5rem;
    margin-block-end: 1.25rem;
  }

  .service-content-inner :global(h3) {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin-block-start: 2.5rem;
    margin-block-end: 1rem;
  }

  .service-content-inner :global(ul),
  .service-content-inner :global(ol) {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text);
    padding-inline-start: 1.5rem;
    margin-block-end: 1.5rem;
  }

  .service-content-inner :global(li) {
    margin-block-end: 0.5rem;
  }

  .service-content-inner :global(a) {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 0.15em;
    text-decoration-thickness: 1px;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .service-content-inner :global(a:hover) {
    opacity: 0.7;
  }

  .service-content-inner :global(strong) {
    font-weight: var(--weight-semibold);
  }

  .service-content-inner :global(blockquote) {
    border-inline-start: 3px solid var(--color-border);
    padding-inline-start: 1.5rem;
    margin-block: 2.5rem;
    margin-inline: 0;
  }

  .service-content-inner :global(blockquote p) {
    font-size: var(--text-xl);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
    font-style: italic;
    margin-block-end: 0.75rem;
  }

  .service-content-inner :global(blockquote strong) {
    display: block;
    font-size: var(--text-base);
    font-style: normal;
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  .service-content-inner :global(hr) {
    border: none;
    border-block-start: 1px solid var(--color-border);
    margin-block: 3rem;
  }

  /* Media — same breakout system as project pages */
  .service-content-inner :global(figure),
  .service-content-inner :global(div:has(> video)),
  .service-content-inner :global(img[data-layout]) {
    margin-block: 3rem;
  }

  .service-content-inner :global(figure img),
  .service-content-inner :global(figure video),
  .service-content-inner :global(div:has(> video) video),
  .service-content-inner :global(img[data-layout]) {
    width: 100%;
    height: auto;
    display: block;
  }

  .service-content-inner :global([data-layout="full"]),
  .service-content-inner :global(figure:not([data-layout])),
  .service-content-inner :global(img:not([data-layout]):not(figure img)),
  .service-content-inner :global(div:has(> video):not([data-layout])) {
    width: 100vw;
    max-width: 100vw;
    margin-inline-start: calc(50% - 50vw);
  }

  /* Cross-sell: stay within prose column, undo full-bleed from project page styles */
  .service-content-inner :global(.cross-sell) {
    width: 100%;
    max-width: 100%;
    margin-inline-start: 0;
    padding-inline: 0;
  }

  .service-content-inner :global([data-layout="wide"]) {
    width: min(var(--max-width), 100vw);
    max-width: 100vw;
    margin-inline-start: calc(50% - min(var(--max-width), 100vw) / 2);
  }

  .service-content-inner :global([data-layout="medium"]) {
    width: 100%;
  }

  .service-content-inner :global([data-layout="small"]) {
    width: 50%;
    margin-inline: auto;
    display: block;
  }

  .service-content-inner :global(figcaption) {
    max-width: var(--max-width-narrow);
    margin-inline: auto;
    padding-inline: var(--gutter);
    padding-block-start: 0.75rem;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-align: center;
  }

  .service-content-inner :global(.metrics) {
    padding-inline: var(--gutter);
    padding-block: 3rem;
    background: var(--color-surface-alt);
    border-block: 1px solid var(--color-border);
    margin-block: 2.5rem;
  }

  .service-content-inner :global(.metrics > *) {
    max-width: var(--max-width);
    margin-inline: auto;
  }

  @media (max-width: 768px) {
    .service-content {
      padding-block: 3rem;
    }

    .service-content-inner :global(p) {
      font-size: var(--text-base);
    }
  }

  /* ============================================================
     Awards
     ============================================================ */

  .service-awards {
    padding: 4rem var(--gutter);
    border-block-start: 1px solid var(--color-border);
  }

  .service-awards-inner {
    max-width: var(--max-width);
    margin-inline: auto;
  }

  .service-awards-inner h2 {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--color-text);
    margin-block-end: 2.5rem;
  }

  .awards-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-block-start: 1px solid var(--color-border);
  }

  .award-row {
    border-block-end: 1px solid var(--color-border);
  }

  .award-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-block: 0.875rem;
    text-decoration: none;
    color: var(--color-text);
    font-size: var(--text-sm);
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  a.award-link:hover {
    opacity: 0.6;
  }

  .award-name {
    font-weight: var(--weight-semibold);
    flex-shrink: 0;
  }

  .award-divider {
    flex: 1;
    height: 1px;
    background: var(--color-border);
    min-width: 1rem;
  }

  .award-project {
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .award-year {
    color: var(--color-text-muted);
    flex-shrink: 0;
    min-width: 3rem;
    text-align: right;
  }

  /* ============================================================
     CTA
     ============================================================ */

  .service-cta {
    padding: 6rem var(--gutter);
    border-block-start: 1px solid var(--color-border);
  }

  .service-cta-inner {
    max-width: var(--max-width-narrow);
    margin-inline: auto;
  }

  .service-cta-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-block-end: 1rem;
  }

  .service-cta-heading {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin-block-end: 2rem;
  }

  @media (max-width: 768px) {
    .service-cta {
      padding-block: 4rem;
    }

    .service-cta-heading {
      font-size: var(--text-xl);
    }
  }
</style>
