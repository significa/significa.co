---
/**
 * /impact — How we build with impact
 *
 * Not a CSR report. An honest account of what we do, what we
 * measure, and where we fall short. Structure:
 *   1. Position — what impact means to a digital studio.
 *   2. B Corp — the accountability mechanism.
 *   3. 1% for the Planet — where the money goes.
 *   4. Operations — what we actually do day-to-day.
 *   5. Team — how we look after people.
 *   6. Close.
 */

import BaseLayout from "@/layouts/base.astro";
import Eyebrow from "@/components/ui/eyebrow.astro";
import SectionHeader from "@/components/ui/section-header.astro";
import QaList from "@/components/ui/qa-list.astro";
import LinkCall from "@/components/ui/link-call.astro";

const commitments = [
  {
    n: "01",
    q: "B Corp certified",
    a: "External audit across five areas: governance, workers, community, environment, customers. Not a self-assessment. Someone checks.",
  },
  {
    n: "02",
    q: "1% for the Planet",
    a: "1% of gross revenue goes to vetted environmental partners every year. The team helps choose where. Recently: Smart Shelter Foundation, Rewilding Portugal, Light Humanity.",
  },
  {
    n: "03",
    q: "Carbon reduction plan",
    a: "We've measured Scopes 1, 2, and 3 emissions. Year-on-year reduction targets. Net zero goal by 2050 or sooner, with a verified target set by 2027.",
  },
  {
    n: "04",
    q: "Responsible operations",
    a: "Renewable electricity. E-waste disposal. Low-impact suppliers. Public transport subsidy. The footprint of a digital studio is smaller than a factory's, but it's not nothing.",
  },
];

const team = [
  {
    n: "01",
    q: "Engagement surveys",
    a: "Twice a year. Results shared with the whole team. Findings become actions with names and deadlines attached, not a slide deck that gets filed.",
  },
  {
    n: "02",
    q: "Health and support",
    a: "Private health insurance. 24/7 external support for legal, fiscal, nutrition, and mental health. Period leave. Because looking after people means specifics, not slogans.",
  },
  {
    n: "03",
    q: "Growth",
    a: "Unlimited learning stipend. Career plans with one-on-ones. Extra vacation day per year of service. The kind of investment that compounds.",
  },
];
---

<BaseLayout
  title="Impact — Significa"
  description="B Corp certified. 1% for the Planet member. Carbon reduction plan in place. How Significa builds with accountability, not just intention."
>
  <!-- ============================================================
       1. Position statement
       ============================================================ -->
  <section class="hero" aria-labelledby="hero-h">
    <Eyebrow>Impact</Eyebrow>
    <h1 id="hero-h" class="hero-heading">
      Intention is cheap.<br />Accountability is the work.
    </h1>
    <p class="hero-deck">
      Every studio says they care about impact. We went and got audited. B Corp certified, 1% for the Planet member, carbon
      footprint measured and reduced year on year. Here's what that actually looks like.
    </p>
  </section>

  <!-- ============================================================
       2. Commitments — what we've committed to
       ============================================================ -->
  <section class="commitments" aria-labelledby="commitments-h">
    <header class="commitments-header">
      <Eyebrow>What we've committed to</Eyebrow>
      <SectionHeader id="commitments-h">Four things we measure, not just claim.</SectionHeader>
    </header>
    <QaList items={commitments} />
    <div class="commitments-links">
      <LinkCall href="/b-corp">B Corp certification</LinkCall>
      <LinkCall href="https://a.storyblok.com/f/198185/x/1d008574fd/significa_public-carbon-reduction-plan.pdf">
        Carbon reduction plan
      </LinkCall>
    </div>
  </section>

  <!-- ============================================================
       3. Team — how we look after people
       ============================================================ -->
  <section class="team" aria-labelledby="team-h">
    <header class="team-header">
      <Eyebrow>Our people</Eyebrow>
      <SectionHeader id="team-h">Looking after the team is not a perk. It's the baseline.</SectionHeader>
    </header>
    <QaList items={team} />
    <p class="team-link">
      <LinkCall href="/careers">Careers at Significa</LinkCall>
    </p>
  </section>

  <!-- ============================================================
       4. Reading — related writing
       ============================================================ -->
  <section class="reading" aria-labelledby="reading-h">
    <Eyebrow>Further reading</Eyebrow>
    <h2 id="reading-h" class="reading-heading">We write about this, too.</h2>
    <div class="reading-links">
      <LinkCall href="/blog/continuing-our-commitment-with-1-for-the-planet">
        Continuing our commitment with 1% for the Planet
      </LinkCall>
      <LinkCall href="/blog/we-partnered-with-1-for-the-planet"> We partnered with 1% for the Planet </LinkCall>
      <LinkCall href="/handbook/sustainability"> Sustainability in the handbook </LinkCall>
    </div>
  </section>

  <!-- ============================================================
       5. Close
       ============================================================ -->
  <footer class="close">
    <LinkCall href="/say-hello">Work with a team that holds itself to a higher standard</LinkCall>
  </footer>
</BaseLayout>

<style>
  section {
    padding-inline: var(--gutter);
    padding-block: clamp(5rem, 10vw, 10rem);
  }

  /* ── Hero ── */

  .hero {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-block: clamp(5rem, 8vw, 10rem) clamp(5rem, 10vw, 10rem);
  }

  .hero-heading {
    font-family: var(--font-display);
    font-weight: 200;
    font-size: var(--text-display-2);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tighter);
    margin: 0;
    max-width: 18ch;
    color: var(--color-ink);
  }

  .hero-deck {
    margin-block: 2.5rem 0;
    font-size: var(--text-xl);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
    max-width: var(--max-width-prose);
  }

  @media (max-width: 768px) {
    .hero-heading {
      font-size: var(--text-4xl);
    }
  }

  /* ── Commitments ── */

  .commitments {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .commitments-header {
    margin-block-end: clamp(3rem, 6vw, 5rem);
  }

  .commitments-links {
    margin-block-start: 3rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 3rem;
  }

  /* ── Team ── */

  .team {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    border-block-start: 1px solid var(--color-rule);
  }

  .team-header {
    margin-block-end: clamp(3rem, 6vw, 5rem);
  }

  .team-link {
    margin-block-start: 3rem;
  }

  /* ── Reading ── */

  .reading {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    border-block-start: 1px solid var(--color-rule);
  }

  .reading-heading {
    font-weight: var(--weight-medium);
    font-size: var(--text-3xl);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 2rem;
    color: var(--color-ink);
  }

  .reading-links {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ── Close ── */

  .close {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-inline: var(--gutter);
    padding-block: 0 clamp(5rem, 10vw, 8rem);
  }
</style>
