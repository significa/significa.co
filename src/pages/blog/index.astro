---
/**
 * /blog — Journal
 *
 * Editorial index. Featured post as display heading, then a compact
 * numbered list. No tag filters, no card grid, no newsletter CTA.
 *
 *   1. Header — "Writing from the studio."
 *   2. Featured post — display heading + description + link-call.
 *   3. All posts — editorial index with load-more.
 */

import BaseLayout from "@/layouts/base.astro";
import Eyebrow from "@/components/ui/eyebrow.astro";
import LinkCall from "@/components/ui/link-call.astro";
import IndexList from "@/components/ui/index-list.astro";
import { getPosts } from "@/lib/collections";

const allPosts = await getPosts();
const featuredPost = allPosts[0];
const remainingPosts = allPosts.slice(1);

const INITIAL_COUNT = 20;

function formatShortDate(date: Date): string {
  return date.toLocaleDateString("en-GB", { year: "numeric", month: "short" });
}
---

<BaseLayout
  title="Journal — Significa"
  description="Writing from the studio. On design, engineering, and the decisions between."
>
  <!-- ============================================================
       1. Featured post (page lead)
       ============================================================ -->
  {
    featuredPost && (
      <section class="featured" aria-labelledby="featured-h">
        <Eyebrow>
          Journal <span class="sep">/</span> Latest <span class="sep">/</span>
          {formatShortDate(featuredPost.data.date)}
        </Eyebrow>
        <h1 id="featured-h" class="featured-heading type-display-2">
          {featuredPost.data.title}
        </h1>
        {featuredPost.data.description && <p class="featured-description">{featuredPost.data.description}</p>}
        <p class="featured-link-row">
          <LinkCall href={`/blog/${featuredPost.id}`}>Read</LinkCall>
        </p>
      </section>
    )
  }

  <!-- ============================================================
       3. All posts — editorial index
       ============================================================ -->
  {
    remainingPosts.length > 0 && (
      <section class="posts" aria-labelledby="posts-h">
        <Eyebrow id="posts-h">All articles</Eyebrow>

        <IndexList stacked>
          {remainingPosts.map((post, i) => (
            <li class="post-item" data-index={i} style={i >= INITIAL_COUNT ? "display: none;" : ""}>
              <a href={`/blog/${post.id}`} class="index-link">
                <span class="index-num">{String(i + 1).padStart(2, "0")}</span>
                <span class="index-title">{post.data.title}</span>
                <span class="index-year">{formatShortDate(post.data.date)}</span>
                <span class="index-mark" aria-hidden="true">
                  &rarr;
                </span>
              </a>
            </li>
          ))}
        </IndexList>

        {remainingPosts.length > INITIAL_COUNT && (
          <p class="load-more-row">
            <button class="load-more" type="button" id="load-more-btn">
              Load more articles
            </button>
          </p>
        )}
      </section>
    )
  }
</BaseLayout>

<script define:vars={{ INITIAL_COUNT }} is:inline>
  function initLoadMore() {
    const btn = document.getElementById("load-more-btn");
    if (!btn) return;

    const items = document.querySelectorAll(".post-item");
    let visible = INITIAL_COUNT;

    btn.addEventListener("click", () => {
      const next = visible + INITIAL_COUNT;
      items.forEach((item, i) => {
        if (i < next) item.style.display = "";
      });
      visible = next;
      if (visible >= items.length) btn.style.display = "none";
    });
  }

  initLoadMore();
  document.addEventListener("astro:after-swap", initLoadMore);
</script>

<style>
  /* ============================================================
     Page rhythm
     ============================================================ */

  section {
    padding-inline: var(--gutter);
    padding-block: clamp(5rem, 10vw, 10rem);
  }

  /* ============================================================
     1. Featured post (page lead)
     ============================================================ */

  .featured {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    padding-block: clamp(4rem, 8vw, 7rem) clamp(5rem, 10vw, 10rem);
  }

  .featured-heading {
    margin: 0;
    max-width: 24ch;
  }

  .featured-description {
    margin-block: 1.5rem 0;
    font-size: var(--text-xl);
    line-height: var(--leading-normal);
    color: var(--color-ink-muted);
    max-width: var(--max-width-prose);
  }

  .featured-link-row {
    margin-top: 2rem;
  }

  @media (max-width: 768px) {
    .featured-heading {
      font-size: var(--text-3xl);
    }
  }

  /* ============================================================
     3. Posts
     ============================================================ */

  .posts {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .load-more-row {
    margin-top: 3rem;
  }

  .load-more {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    line-height: 1;
    color: var(--color-ink-muted);
    background: none;
    border: 1px solid var(--color-rule);
    border-radius: 2rem;
    padding: 0.85rem 2rem 0.75rem;
    cursor: pointer;
    transition:
      color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .load-more:hover {
    color: var(--color-ink);
    border-color: var(--color-ink);
  }
</style>
