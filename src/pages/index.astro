---
import BaseLayout from "@/layouts/base.astro";
import { getClients, getTestimonials, getPosts, getAwards, getPlayground, getResolvedHighlights } from "@/lib/collections";
import { cdnUrl } from "@/lib/cdn";

const clients = await getClients();
const testimonials = await getTestimonials();
const recentPosts = (await getPosts()).slice(0, 3);
const highlights = await getResolvedHighlights();
const awards = (await getAwards()).slice(0, 18);
const playgroundProjects = (await getPlayground()).slice(0, 3);

// Get featured highlight projects (can be projects, blog, or playground)
const featuredHighlights = highlights.slice(0, 3);
---

<BaseLayout
  title="Significa — Design and Development Agency"
  description="We are a design and development agency building digital products that work beautifully. From strategy to code, we deliver user-centred platforms for ambitious businesses."
>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <h1>
        We are a <strong>design and development agency</strong> building digital products that work beautifully.
      </h1>
    </div>
  </section>

  <!-- Showreel -->
  <section class="showreel">
    <div class="showreel-inner">
      <div class="showreel-media" data-showreel>
        <video
          src="https://assets.significa.co/fcp-reel-w-subtitles-2cDmSH.mp4"
          width="1920"
          height="1080"
          loop
          muted
          playsinline
          data-showreel-video></video>
        <button class="showreel-cursor" type="button" data-showreel-cursor aria-label="Play showreel video">
          <span class="showreel-cursor-icon" aria-hidden="true">▶</span>
        </button>
      </div>
    </div>
  </section>

  <!-- Section: Strategy -->
  <section class="section-intro">
    <div class="section-intro-inner">
      <h2>From strategy to code, we deliver user-centred platforms for ambitious businesses.</h2>
    </div>
  </section>

  <!-- Selected Highlights -->
  {
    featuredHighlights.length > 0 && (
      <section class="highlights-grid">
        <div class="highlights-grid-inner">
          {featuredHighlights.map((highlight) => {
            const entry = highlight.entry;
            if (!entry) return null;

            const href =
              highlight.collection === "projects"
                ? `/projects/${entry.id}`
                : highlight.collection === "blog"
                  ? `/blog/${entry.id}`
                  : `/playground/${entry.id}`;

            // Get thumbnail based on collection type
            let thumbnail: string | undefined;
            if (highlight.collection === "projects") {
              const data = entry.data as unknown as { thumbnail?: string; heroImage?: string };
              thumbnail = data.thumbnail || data.heroImage;
            } else {
              const data = entry.data as unknown as { thumbnail?: string };
              thumbnail = data.thumbnail;
            }

            // Get tagline/description based on collection type
            const subtitle =
              highlight.collection === "projects"
                ? (entry.data as unknown as { tagline?: string }).tagline
                : (entry.data as unknown as { description?: string }).description;

            return (
              <article class="highlight-card">
                <a href={href}>
                  {thumbnail && (
                    <div class="highlight-image">
                      <img
                        src={cdnUrl(thumbnail, { width: 800, quality: 80 })}
                        alt={entry.data.title}
                        width="800"
                        height="600"
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                  )}
                  <div class="highlight-content">
                    {highlight.label && <span class="highlight-label">{highlight.label}</span>}
                    <h3 class="highlight-title">{entry.data.title}</h3>
                    {subtitle && <p class="highlight-tagline">{subtitle}</p>}
                  </div>
                </a>
              </article>
            );
          })}
        </div>
        <div class="cta-container">
          <a href="/projects" class="cta-link">
            View all projects →
          </a>
        </div>
      </section>
    )
  }

  <!-- Service Pillars Intro -->
  <section class="services-intro">
    <div class="services-intro-inner">
      <h2>
        When you work with us, you get our whole team to <strong>Think</strong>, <strong>Design</strong>,{" "}
        <strong>Develop</strong>, <strong>Launch</strong> and <strong>Scale</strong> your ideas into seamless digital experiences.
      </h2>
      <p class="services-description">
        Whether it's an <strong>e-commerce shop</strong>, a <strong>mobile app</strong>, a{" "}
        <strong>ticketing platform</strong>, or a <strong>design system</strong>, we'll build it with care and curiosity, backed
        by +10 years of expertise, recognised by +20 international awards.
      </p>
      <a href="/what-we-do" class="cta-button">Explore our Services</a>
    </div>
  </section>

  <!-- Service Pillars -->
  <section class="service-pillars">
    <div class="service-pillars-inner">
      <article class="pillar">
        <h3 class="pillar-title">Think.</h3>
        <p class="pillar-description">
          We ask the right questions to uncover the real challenges and set a clear plan, spanning product strategy, UX audits
          and technical planning, so you know what to build and why.
        </p>
      </article>

      <article class="pillar">
        <h3 class="pillar-title">Design.</h3>
        <p class="pillar-description">
          We transform insights into impact through UI, brands and Design Systems that function beautifully, scale purposefully
          and guide users.
        </p>
      </article>

      <article class="pillar">
        <h3 class="pillar-title">Develop.</h3>
        <p class="pillar-description">
          We apply critical thinking, agility and curiosity to write clear, reliable code that turns solid products into
          seamless experiences.
        </p>
      </article>

      <article class="pillar">
        <h3 class="pillar-title">Launch.</h3>
        <p class="pillar-description">
          We build robust, easy to maintain software that's ready to scale, with efficient, consistent frameworks and clear
          documentation for a smooth handover.
        </p>
      </article>

      <article class="pillar">
        <h3 class="pillar-title">Scale.</h3>
        <p class="pillar-description">
          We track performance and user behaviour, defining evidence-led features and technical improvements for continuous
          growth.
        </p>
      </article>
    </div>
  </section>

  <!-- Team CTA -->
  <section class="team-intro">
    <div class="team-intro-inner">
      <h2>We are a team of designers, developers, and product managers working as one.</h2>
      <a href="/work-with-us" class="cta-button">Work with us</a>
    </div>
  </section>

  <!-- Blog Section -->
  {
    recentPosts.length > 0 && (
      <section class="blog-section">
        <div class="blog-section-inner">
          <h2 class="section-title">We think things through.</h2>
          <div class="blog-grid">
            {recentPosts.map((post) => (
              <article class="blog-card">
                <a href={`/blog/${post.id}`}>
                  {post.data.thumbnail && (
                    <div class="blog-image">
                      <img
                        src={cdnUrl(post.data.thumbnail, { width: 600, quality: 80 })}
                        alt={post.data.title}
                        width="600"
                        height="400"
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                  )}
                  <div class="blog-content">
                    <h3 class="blog-title">{post.data.title}</h3>
                    {post.data.description && <p class="blog-description">{post.data.description}</p>}
                    <time class="blog-date" datetime={post.data.date.toISOString()}>
                      {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
                    </time>
                  </div>
                </a>
              </article>
            ))}
          </div>
          <div class="cta-container">
            <a href="/blog" class="cta-link">
              View all posts →
            </a>
          </div>
        </div>
      </section>
    )
  }

  <!-- Impact Section -->
  <section class="impact-section">
    <div class="impact-section-inner">
      <h2>
        We do business for good, <strong>building with impact in mind.</strong>
      </h2>
      <p class="impact-description">
        As a <strong>certified B Corp</strong> and member of 1% for the Planet, we are committed to designing and building ethically,
        inclusively, and sustainably.
      </p>
      <a href="/impact" class="cta-button-outline">Learn more about our impact</a>
    </div>
  </section>

  <!-- Playground Section -->
  {
    playgroundProjects.length > 0 && (
      <section class="playground-section">
        <div class="playground-section-inner">
          <h2 class="section-title">We have fun! Our Playground is where we let our creativity run wild.</h2>
          <p class="section-description">
            As avid contributors to the Open Source community, we are proud to share some of the tools we've built.
          </p>
          <div class="playground-grid">
            {playgroundProjects.map((project) => (
              <article class="playground-card">
                <a href={`/playground/${project.id}`}>
                  {project.data.thumbnail && (
                    <div class="playground-image">
                      <img
                        src={cdnUrl(project.data.thumbnail, { width: 600, quality: 80 })}
                        alt={project.data.title}
                        width="600"
                        height="400"
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                  )}
                  <div class="playground-content">
                    <h3 class="playground-title">{project.data.title}</h3>
                    <p class="playground-description">{project.data.description}</p>
                  </div>
                </a>
              </article>
            ))}
          </div>
          <div class="cta-container">
            <a href="/playground" class="cta-link">
              View all projects →
            </a>
          </div>
        </div>
      </section>
    )
  }

  <!-- Social Proof / Testimonials -->
  <section class="social-proof">
    <div class="social-proof-inner">
      <h2 class="section-title">We love what we do, and so do our clients.</h2>
      <p class="section-description">
        Our clients enjoy our process as much as they enjoy the products we build for them. An independent entity runs customer
        satisfaction surveys and interviews to help us understand how we can keep continuously improving.
      </p>

      <div class="social-proof-content">
        <div class="stats-card">
          <span class="stats-label">Customer experience</span>
          <span class="stats-value">84.7%</span>
          <p class="stats-description">
            Bring your specs to Significa but give them the creative freedom to unleash the best possible design and solution
            for your product needs and users.
          </p>
        </div>

        {
          testimonials[0] && (
            <blockquote class="testimonial-card">
              <p class="testimonial-quote">{testimonials[0].data.quote}</p>
              <footer class="testimonial-author">
                <cite>
                  <strong>{testimonials[0].data.author}</strong>
                  <span>
                    {testimonials[0].data.role} at {testimonials[0].data.company}
                  </span>
                </cite>
              </footer>
            </blockquote>
          )
        }
      </div>
    </div>
  </section>

  <!-- Awards -->
  {
    awards.length > 0 && (
      <section class="awards">
        <div class="awards-inner">
          <div class="awards-header">
            <h2>International recognition.</h2>
          </div>
          <ul class="awards-list">
            {awards.map((a) => (
              <li class="award-item">
                {a.url ? (
                  <a href={a.url} target="_blank" rel="noopener noreferrer">
                    <span class="award-name">{a.award}</span>
                    <span class="award-year">{a.year}</span>
                    <span class="award-project">{a.project?.data.client ?? a.project?.data.title}</span>
                  </a>
                ) : (
                  <span class="award-item-inner">
                    <span class="award-name">{a.award}</span>
                    <span class="award-year">{a.year}</span>
                    <span class="award-project">{a.project?.data.client ?? a.project?.data.title}</span>
                  </span>
                )}
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <!-- Final CTA -->
  <section class="final-cta">
    <div class="final-cta-inner">
      <h2>We are ready to grow your business.</h2>
      <p class="final-cta-description">
        Are you? Let's get the conversation going… or keep browsing and see if we're the right fit!
      </p>
      <a href="/work-with-us" class="cta-button-large">Get in touch</a>
    </div>
  </section>

  <!-- FAQs Section -->
  <section class="faqs">
    <div class="faqs-inner">
      <h2 class="section-title">Frequently asked questions</h2>
      <dl class="faq-list">
        <div class="faq-item">
          <dt class="faq-question">What services do you offer?</dt>
          <dd class="faq-answer">
            We offer end-to-end product development: strategy, UX/UI design, development, and ongoing support. We specialize in
            web and mobile applications, e-commerce platforms, and design systems.
          </dd>
        </div>

        <div class="faq-item">
          <dt class="faq-question">How long does a typical project take?</dt>
          <dd class="faq-answer">
            Project timelines vary based on scope and complexity. A typical project ranges from 8-16 weeks, but we'll provide a
            detailed timeline during our initial discovery phase.
          </dd>
        </div>

        <div class="faq-item">
          <dt class="faq-question">What's your process like?</dt>
          <dd class="faq-answer">
            We follow a collaborative, iterative approach: Think (strategy and planning), Design (UI/UX and prototyping),
            Develop (engineering and QA), Launch (deployment and handover), and Scale (optimization and growth).
          </dd>
        </div>

        <div class="faq-item">
          <dt class="faq-question">Do you work with startups or enterprises?</dt>
          <dd class="faq-answer">
            Both! We've partnered with ambitious startups and established enterprises across various industries. What matters
            most is shared ambition and a commitment to building something exceptional.
          </dd>
        </div>

        <div class="faq-item">
          <dt class="faq-question">Where are you based?</dt>
          <dd class="faq-answer">
            We're based in Porto, Portugal, but we work with clients globally. We're experienced in remote collaboration and
            have processes in place to ensure seamless communication across time zones.
          </dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- Client Logos -->
  {
    clients.length > 0 && (
      <section class="clients">
        <div class="clients-inner">
          <ul>
            {clients.map((client) => (
              <li>
                {client.data.url ? (
                  <a href={client.data.url} target="_blank" rel="noopener noreferrer" title={client.data.name}>
                    <span class="client-name">{client.data.name}</span>
                  </a>
                ) : (
                  <span class="client-name">{client.data.name}</span>
                )}
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }
</BaseLayout>

<!-- Showreel cursor-following button — vanilla JS, no island needed -->
<script>
  function initShowreel() {
    const section = document.querySelector<HTMLElement>("[data-showreel]");
    const cursor = document.querySelector<HTMLButtonElement>("[data-showreel-cursor]");
    const video = document.querySelector<HTMLVideoElement>("[data-showreel-video]");
    if (!section || !cursor || !video) return;

    let isPlaying = false;

    function positionAt(e: MouseEvent) {
      if (!cursor) return;

      const x = e.clientX - cursor.offsetWidth / 2;
      const y = e.clientY - cursor.offsetHeight / 2;
      cursor.style.translate = `${x}px ${y}px`;
    }

    function updateCursorIcon() {
      if (!cursor) return;
      const icon = cursor.querySelector(".showreel-cursor-icon");
      if (icon) {
        icon.textContent = isPlaying ? "❚❚" : "▶";
      }
    }

    function toggleVideo() {
      if (!video) return;
      if (isPlaying) {
        video.pause();
        isPlaying = false;
      } else {
        video.play();
        isPlaying = true;
      }
      updateCursorIcon();
    }

    section.addEventListener("mouseenter", (e: MouseEvent) => {
      positionAt(e);
      cursor.style.opacity = "1";
      cursor.style.scale = "1";
    });

    section.addEventListener("mouseleave", () => {
      cursor.style.opacity = "0";
      cursor.style.scale = "0.5";
    });

    section.addEventListener("mousemove", (e: MouseEvent) => {
      positionAt(e);
    });

    section.addEventListener("click", toggleVideo);
    cursor.addEventListener("click", (e) => {
      e.stopPropagation();
      toggleVideo();
    });

    // Respect reduced motion
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    if (prefersReducedMotion.matches) {
      cursor.style.display = "none";
    }
    prefersReducedMotion.addEventListener("change", (e) => {
      cursor.style.display = e.matches ? "none" : "";
    });
  }

  // Run on initial load and after View Transition navigation
  initShowreel();
  document.addEventListener("astro:after-swap", initShowreel);
</script>

<style>
  /* ============================================================
       Hero
       ============================================================ */
  .hero {
    padding: 8rem var(--gutter) 4rem;
  }

  .hero-inner {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
  }

  .hero h1 {
    font-size: var(--text-3xl);
    font-weight: var(--weight-normal);
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .hero h1 strong {
    font-weight: var(--weight-semibold);
  }

  /* ============================================================
       Showreel
       ============================================================ */
  .showreel {
    padding: 0 var(--gutter) 4rem;
  }

  .showreel-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .showreel-media {
    position: relative;
    border-radius: 0.5rem;
    overflow: hidden;
    cursor: none;
  }

  .showreel-media video {
    width: 100%;
    height: auto;
    display: block;
  }

  .showreel-cursor {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 10;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--color-text);
    color: var(--color-surface);
    border: none;
    border-radius: 2rem;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    pointer-events: none;
    opacity: 0;
    scale: 0.5;
    transition:
      opacity var(--duration-fast) var(--ease-out),
      scale var(--duration-fast) cubic-bezier(0.34, 1.56, 0.64, 1);
    will-change: translate, scale;
    white-space: nowrap;
  }

  .showreel-cursor-icon {
    font-size: 0.625rem;
  }

  @media (hover: none) {
    .showreel-media {
      cursor: default;
    }

    .showreel-cursor {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%) !important;
      opacity: 1 !important;
      pointer-events: auto;
    }
  }

  /* ============================================================
       Section Intro
       ============================================================ */
  .section-intro {
    padding: 4rem var(--gutter) 2rem;
  }

  .section-intro-inner {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
  }

  .section-intro h2 {
    font-size: var(--text-2xl);
    font-weight: var(--weight-medium);
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  /* ============================================================
       Highlights Grid
       ============================================================ */
  .highlights-grid {
    padding: 2rem var(--gutter) 4rem;
  }

  .highlights-grid-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .highlight-card a {
    display: block;
    text-decoration: none;
    color: var(--color-text);
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .highlight-card a:hover {
    opacity: 0.8;
  }

  .highlight-image {
    border-radius: 0.5rem;
    overflow: hidden;
    background: var(--color-surface-alt);
    margin-bottom: 1rem;
  }

  .highlight-image img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .highlight-card a:hover .highlight-image img {
    transform: scale(1.02);
  }

  .highlight-label {
    display: block;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .highlight-title {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    margin-bottom: 0.5rem;
  }

  .highlight-tagline {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  /* ============================================================
       Services Intro
       ============================================================ */
  .services-intro {
    padding: 4rem var(--gutter);
    background: var(--color-surface-alt);
  }

  .services-intro-inner {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
    text-align: center;
  }

  .services-intro h2 {
    font-size: var(--text-2xl);
    font-weight: var(--weight-normal);
    line-height: var(--leading-tight);
    margin-bottom: 1.5rem;
  }

  .services-intro h2 strong {
    font-weight: var(--weight-semibold);
  }

  .services-description {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .services-description strong {
    color: var(--color-text);
    font-weight: var(--weight-medium);
  }

  /* ============================================================
       Service Pillars
       ============================================================ */
  .service-pillars {
    padding: 0 var(--gutter) 4rem;
    background: var(--color-surface-alt);
  }

  .service-pillars-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 3rem;
  }

  .pillar {
    border-top: 2px solid var(--color-border);
    padding-top: 1.5rem;
  }

  .pillar-title {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .pillar-description {
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .service-pillars-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  /* ============================================================
       Team Intro
       ============================================================ */
  .team-intro {
    padding: 4rem var(--gutter);
  }

  .team-intro-inner {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
    text-align: center;
  }

  .team-intro h2 {
    font-size: var(--text-2xl);
    font-weight: var(--weight-medium);
    line-height: var(--leading-tight);
    margin-bottom: 2rem;
  }

  /* ============================================================
       Blog Section
       ============================================================ */
  .blog-section {
    padding: 4rem var(--gutter);
  }

  .blog-section-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section-title {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    margin-bottom: 3rem;
    text-align: center;
  }

  .section-description {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
    margin-bottom: 3rem;
    text-align: center;
    max-width: 60ch;
    margin-left: auto;
    margin-right: auto;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .blog-card a {
    display: block;
    text-decoration: none;
    color: var(--color-text);
    transition: opacity var(--duration-fast) var(--ease-out);
  }

